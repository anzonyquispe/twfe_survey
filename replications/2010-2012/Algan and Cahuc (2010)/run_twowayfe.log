.     di "  feTR succeeded (rc=" _rc "): beta=`tw_beta_fe', pos=`tw_npos_fe', neg=`tw_nneg_fe'"
  feTR succeeded (rc=402): beta=., pos=., neg=.
. }

. else {
.     di as error "  feTR failed with rc = " _rc
.     local tw_beta_fe   = .
.     local tw_npos_fe   = .
.     local tw_nneg_fe   = .
. }

