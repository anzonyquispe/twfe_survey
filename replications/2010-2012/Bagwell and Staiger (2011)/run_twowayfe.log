. * Helper program: compute significance stars from t-stat
. cap program drop _stars

. program define _stars, rclass
  1.     args b se
  2.     local s ""
  3.     if `se' > 0 & `se' < . {
  4.         local t = abs(`b'/`se')
  5.         if `t' > 2.576      local s "***"
  6.         else if `t' > 1.960 local s "**"
  7.         else if `t' > 1.645 local s "*"
  8.     }
  9.     return local s "`s'"
 10. end

. 
. * Industry labels
. local lab0  "All"

. local lab1  "HS0"

. local lab2  "HS1"

. local lab3  "HS2"

. local lab4  "HS3"

. local lab5  "HS4"

. local lab6  "HS5"

. local lab7  "HS6"

. local lab8  "HS7"

. local lab9  "HS8"

. local lab10 "HS9"

. 
. * Industry product code bounds
. local lo0 = 0

. local hi0 = 1000000

. forvalues j = 1/10 {
  2.     local lo`j' = (`j' - 1) * 100000
  3.     local hi`j' = `j' * 100000
  4. }

. 
. * Initialize result storage
. forvalues k = 0/10 {
  2.     local b1_`k' = .
  3.     local se1_`k' = .
  4.     local b2_`k' = .
  5.     local se2_`k' = .
  6.     local r2_`k' = .
  7.     local nn_`k' = 0
  8. }

. 
. * --- Run regressions: All + 10 industries ---
. forvalues k = 0/10 {
  2.     * Build if-condition (empty for All)
.     if `k' == 0 {
  3.         local ifcond ""
  4.     }
  5.     else {
  6.         local ifcond "if product >= `lo`k'' & product < `hi`k''"
  7.     }
  8. 
.     di _n "--- `lab`k'' ---"
  9.     qui count `ifcond'
 10.     local nn_`k' = r(N)
 11. 
.     if `nn_`k'' > 20 {
 12.         * Check TariffBase variance for subsample
.         qui summ TariffBase `ifcond'
 13.         local tvar = r(Var)
 14.         local has_base = (`tvar' > 0)
 15. 
.         if `has_base' {
 16.             cap noisily qui reg TariffFinal Import_M TariffBase ///
>                 ibn.HS2 i.country_num `ifcond', noconstant vce(robust)
 17.         }
 18.         else {
 19.             cap noisily qui reg TariffFinal Import_M ///
>                 ibn.HS2 i.country_num `ifcond', noconstant vce(robust)
 20.         }
 21. 
.         if !_rc & e(N) > 0 {
 22.             if `has_base' {
 23.                 local b1_`k' = _b[TariffBase]
 24.                 local se1_`k' = _se[TariffBase]
 25.             }
 26.             local b2_`k' = _b[Import_M]
 27.             local se2_`k' = _se[Import_M]
 28.             local r2_`k' = e(r2)
 29.             local nn_`k' = e(N)
 30. 
.             if `has_base' {
 31.                 di "  beta1 (TariffBase): " %9.4f `b1_`k'' " (" %7.4f `se1_`k'' ")"
 32.             }
 33.             di "  beta2 (Import_M):   " %9.4f `b2_`k'' " (" %7.4f `se2_`k'' ")"
 34.             di "  R2:                 " %9.3f `r2_`k''
 35.             di "  N:                  " %9,0gc `nn_`k''
 36.         }
 37.         else {
 38.             di "  Regression failed"
 39.             local nn_`k' = 0
 40.         }
 41.     }
 42.     else {
 43.         di "  Insufficient observations (`nn_`k'')"
 44.         local nn_`k' = 0
 45.     }
 46. }

