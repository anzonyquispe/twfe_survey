 10.             local se1fmt : di %7.4f `se1_`k''
 11.             local se1fmt = strtrim("`se1fmt'")
 12.             _stars `b1_`k'' `se1_`k''
 13.             local s1 "`r(s)'"
 14.         }
 15.         else {
 16.             local b1fmt "---"
 17.             local se1fmt "---"
 18.             local s1 ""
 19.         }
 20. 
.         * Format and star beta2 (Import_M)
.         local b2fmt : di %7.4f `b2_`k''
 21.         local b2fmt = strtrim("`b2fmt'")
 22.         local se2fmt : di %7.4f `se2_`k''
 23.         local se2fmt = strtrim("`se2fmt'")
 24.         _stars `b2_`k'' `se2_`k''
 25.         local s2 "`r(s)'"
 26. 
.         * Write coefficient row
.         file write texfile "`lab`k'' & `nfmt' & `b1fmt'`s1' & `b2fmt'`s2' & `r2fmt' \\" _n
 27. 
.         * Write SE row
.         if "`b1fmt'" != "---" {
 28.             file write texfile " & & (`se1fmt') & (`se2fmt') & \\" _n
 29.         }
 30.         else {
 31.             file write texfile " & & --- & (`se2fmt') & \\" _n
 32.         }
 33. 
.         * Spacing between rows
.         if `k' == 0 {
 34.             file write texfile "\addlinespace[6pt]" _n
 35.         }
 36.         else if `k' < 10 {
 37.             file write texfile "\addlinespace" _n
 38.         }
 39.     }
 40. }

