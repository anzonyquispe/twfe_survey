. 
. use "replication_appxdata5",clear

. 
. 
. 
. /* DOUBLE DIFFERENCES and Pre-accession trends*/
. xtset hs6 year

Panel variable: hs6 (unbalanced)
 Time variable: year, 1996 to 2006, but with gaps
         Delta: 1 unit

.         
.                         local x=5

.                         local year=2005

. 
.                         local prex=3

.                         local preyear=`year'-`x'-1 

.                         
.                         local outregfile tableA7.out

. local replace replace

. 
.             gen dd_`x'=(ln(imports)-ln(L`x'.imports))/`x' - (ln(L6.imports)-l
> n(L9.imports))/3 if ye==`year'
(53,022 missing values generated)

.             gen unc_2000=unc_pre/`x' if ye==`year'
(51,532 missing values generated)

.             gen dd_tc`x'=(ln_tcost-L`x'.ln_tcost)/`x' - (L6.ln_tcost-L9.ln_tc
> ost)/3 if ye==`year'
(53,024 missing values generated)

.                 
.                 
.                 
.               gen dd_adv`x'=(advalorem_mfn-L`x'.advalorem_mfn)/`x' - (L6.adva
> lorem_mfn-L9.advalorem_mfn)/3 if ye==`year'
(51,257 missing values generated)

.                 
.             gen dd_TTB`x'=(TTB-L5.TTB)/5 - (L6.TTB-L9.TTB)/3 if ye==`year'
(50,847 missing values generated)

.             gen dd_MFA`x'=(MFA-L5.MFA)/5 - (L6.MFA-L9.MFA)/3 if ye==`year'
(50,847 missing values generated)

. 
.                 gen predefined=(L9.unc_adv_mfn_col2_zero!=.)

.         
.                 
.                 /*set sample*/
.                 qui reg  dd_5 unc_2000  dd_adv5 dd_tc5  if year==`year'  &  o
> ut_tc_`prex'_`preyear'~=1 , r

.                                 
.                 capture drop ddsample common            

.                 gen ddsample =1 if e(sample)
(53,295 missing values generated)

.                 bysort hs6: egen common=min(ddsample)
(27,445 missing values generated)

.         
.         
.                 /* unified pre and post sample */
.                 
.                 rreg  dd_5 unc_2000 dd_adv5 dd_tc5  if year==`year' &  out_tc
