> 5tails==1,degree(0) bw(.1)  ) ,/*
>         *//*title (Change in HS6 price index (ln) 2005-2000) *//*
>         */xtitle(ln({&tau}{sub:2V}/{&tau}{sub:1V})) /*
>                 */xlabel(0(0.1)0.7)  legend(off)

.         
