. do regs_twn_chn_compare_replicate.do

. 
. clear all

. 
. 
. use replication_maindata2.dta,clear

. 
. 
.         
.         local outregfile table3_panelA

.         local replace replace

.         
.         
. 
.         local keepvars "unc_pre  dif_advalorem_mfn_5  dif_ln_tcost_5"

.         
.                 *tercile  subsamples and restricted
.         
.         foreach cc in "CHINA" "TAIWAN"{ 
  2.                         foreach criteria in "sunk_hs4_coeff_stat_t" {
  3.                         foreach xtile in "1"  {
  4.                         *avoid var-cov singularity by dropping sections wi
> th single obs (those w/  0are dropped by stata)*
.                         
.                         qui reg dif_ln_imp_5  unc_pre  dif_advalorem_mfn_5  d
> if_ln_tcost_5 i.section  if ct_twn_chn ==2 & `criteria'==`xtile' & country=="
> `cc'",        
  5.                                 capture drop cnt
  6.                                 capture drop sample
