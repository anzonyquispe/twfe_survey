set more 1

set memory 700000

log using otc0305.log

* figure out which drugs in our top group are otc

* we are using 2003 medicaid util data but 2005 drug product data
* b/c 2003 drug product data was not available - should be very very similar
* to comparable 2003 data - allows us to determine which ndcs are otc

* more recent version of drug product data is available on cms website at:
* http://www.cms.hhs.gov/MedicaidDrugRebateProgram/09_DrugProdData.asp
* can find utilization data at that same site

* this file aggregates ndcs to drug level to determine fraction of each drug's
* spending that are for otc ndcs

use otc05info
gen str11 ndc = labcode + prodcode + packcode
keep prodname ndc drugtype
replace prodname = upper(ltrim(prodname))
tab drugtype, missing
destring drugtype, replace
list if drugtype==.
drop if drugtype==.
gen str9 ndc9 = substr(ndc,1,9)
sort ndc9
egen mintype = min(drugtype), by(ndc9)
egen maxtype = max(drugtype), by(ndc9)
count
count if mintype!=maxtype
sort ndc9
quietly by ndc9: gen temp = _n
keep if temp==1 
keep if mintype==maxtype
keep ndc9 prodname drugtype
sort ndc9
save otc0305
d, fullname
sum
quietly by ndc9: gen temp = _n
tab temp
clear

use mcd2003us
replace paidamt = paidamt / 100
collapse (sum) paidamt numpresc, by(labcode prodcode)
gen str9 ndc9 = labcode + prodcode
drop labcode prodcode
sort ndc9
merge ndc9 using otc0305
tab _merge
sum paidamt if _merge==3
sum paidamt if _merge!=3

keep if _merge==3
drop _merge

count
tab drugtype, missing
gen otcpaid = paidamt if drugtype==2

