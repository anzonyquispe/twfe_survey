> ****** 
. 
. *** For some reason, Stata won't let us do bootstrap with weights, so do it w
> ith a loop
. *** If xtpoisson doesn't converge, resample and reestimate
. set seed 210
 26. local i = 1
 27. 
. matrix bsc = J(500,4,0) 
 28. matrix bnc = J(500,4,0) 
 29. while `i' <=500 {
 30.   disp `i'
 31.   use temps2.dta, clear
 32.   local x = 1
 33.   while `x'==1 {
 34.     local x = 0
 35.     bsample, cluster(msa) 
 36.     cap xtpoisson `1' imp_post`2' _Iyear_* [w=wgt] if dis1==1, fe iterate(
> 25)
 37.     if e(ic)==25 {
 38.       local x = 1 
 39.     }
 40.     cap matrix bsc[`i',1] = _b[imp_post`2']
 41.     cap xtpoisson `1' imp_post`2' _Iyear_* [w=wgt] if dis2==1, fe iterate(
> 25)
 42.     if e(ic)==25 {
 43.       local x = 1 
 44.     }
 45.     cap matrix bsc[`i',2] = _b[imp_post`2']
