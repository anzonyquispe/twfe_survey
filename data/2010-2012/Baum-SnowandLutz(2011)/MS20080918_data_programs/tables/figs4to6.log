  6. xtpoisson `1' imp_post`2' _Iyear_* [w=wgt] if dis2==1, fe iterate(25)
  7. matrix beta[1,2] = _b[imp_post`2']
  8. xtpoisson `1' imp_post`2' _Iyear_* [w=wgt] if dis3==1, fe iterate(25)
  9. matrix beta[1,3] = _b[imp_post`2']
