 51.     cap xtpoisson `1' imp_post`2' _Iyear_* [w=wgt] if dis4==1, fe iterate(
> 25)
 52.     if e(ic)==25 {
 53.       local x = 1 
 54.     }
 55.     cap matrix bsc[`i',4] = _b[imp_post`2']
 56.   }
 57.   use tempn2.dta, clear
 58.   local x = 1
 59.   while `x'==1 {
