  4.   xi: xtreg lnw`r' imp_post_south imp_post_nonsouth i.year*i.south              , fe i(leaid) cluster(leaid);
  5.   outreg2 imp_post_south imp_post_nonsouth using tableA2.out, bdec(2) se nor2 nocons append;
  6.   test imp_post_south = imp_post_nonsouth;
  7.   xi: xtreg lnb`r' impost_4                         i.year*i.south              , fe i(leaid) cluster(leaid);
  8.   outreg2 impost_4  using tableA2.out, bdec(2) se nor2 nocons append;
  9.   xi: xtreg lnb`r' impost_4_south impost_4_nonsouth i.year*i.south              , fe i(leaid) cluster(leaid);
 10.   outreg2 impost_4_south impost_4_nonsouth using tableA2.out, bdec(2) se nor2 nocons append;
 11.   test impost_4_south = impost_4_nonsouth;
 12.  };
