. 
. 
. *** Data Appendix Assertion about Tract Data Accuracy in 1960 **********
. clear

. use ../data/check/tracts60c.dta

. 
. gen ratelemb = xpublicelemb/publicelemb
(2984 missing values generated)

. *** Do this adjustment to omit partially tracted counties
. replace ratelemb = . if xpublicelemt~=publicelemt
(32 real changes made, 32 to missing)

. gen ratelemw = xpublicelemw/publicelemw
(2964 missing values generated)

. replace ratelemw = . if xpublicelemt~=publicelemt
(38 real changes made, 38 to missing)

. 
. gen rathsb = xpublichsb/publichsb
(2984 missing values generated)

. replace rathsb = . if xpublichst~=publichst
(32 real changes made, 32 to missing)

. gen rathsw = xpublichsw/publichsw
(2964 missing values generated)

. replace rathsw = . if xpublichst~=publichst
(38 real changes made, 38 to missing)

. 
. sum ratelemb rathsb

    Variable |       Obs        Mean    Std. Dev.       Min        Max
-------------+--------------------------------------------------------
    ratelemb |       116    .9396751    .0956913     .44032   1.145798
      rathsb |       116    1.007801    .1816627   .5481968   2.224889

. sum ratelemw rathsw

    Variable |       Obs        Mean    Std. Dev.       Min        Max
-------------+--------------------------------------------------------
    ratelemw |       130      1.0075    .0164597   .9346458   1.080603
      rathsw |       130    .9983555    .0254075   .8403205   1.072647

. 
. 
. /*** Data appendix - number of districts with tracts
> spanning district boundaries ***/
. 
. use ../data/dis70panx.dta, clear

. keep if major==1 & year==1990
(586 observations deleted)

. keep if cntydis==0
(31 observations deleted)

. gen stdis = sd70

. sort stdis

. save temp.dta, replace
(note: file temp.dta not found)
file temp.dta saved

. 
. use ../data/district70/tracts_unif70.dta

. sort stdis

. merge stdis using temp.dta
variable stdis does not uniquely identify observations in the master data

. tab _merge

     _merge |      Freq.     Percent        Cum.
------------+-----------------------------------
          1 |     24,727       78.09       78.09
          2 |          1        0.00       78.09
          3 |      6,937       21.91      100.00
------------+-----------------------------------
      Total |     31,665      100.00

. l mname if _merge==2

