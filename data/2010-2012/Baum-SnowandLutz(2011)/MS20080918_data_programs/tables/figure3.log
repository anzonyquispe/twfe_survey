 10. xi: xtreg lnpop`1'b impost_4 i.year if south==1, fe i(leaid) cluster(leaid)
 11. matrix blackss[`2',1] = _b[impost_4]
 12. matrix blackss[`2',2] = _se[impost_4]
 13. xi: xtreg lnpop`1'w imp_post i.year if south==0, fe i(leaid) cluster(leaid)
 14. matrix whitesn[`2',1] = _b[imp_post]
 15. matrix whitesn[`2',2] = _se[imp_post]
 16. xi: xtreg lnpop`1'b impost_4 i.year if south==0, fe i(leaid) cluster(leaid)
 17. matrix blacksn[`2',1] = _b[impost_4]
 18. matrix blacksn[`2',2] = _se[impost_4]
 19. 
. end

