  4. xi: xtreg lnpop`1'b impost_4 i.year*i.south, fe i(leaid) cluster(leaid)
  5. matrix blacks[`2',1] = _b[impost_4]
  6. matrix blacks[`2',2] = _se[impost_4]
  7. xi: xtreg lnpop`1'w imp_post i.year if south==1, fe i(leaid) cluster(leaid)
  8. matrix whitess[`2',1] = _b[imp_post]
