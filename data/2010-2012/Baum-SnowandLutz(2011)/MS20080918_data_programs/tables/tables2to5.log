>                                                    i.year*i.south               , fe i(leaid) cluster(leaid);
 35.  outreg2 imp_post_south impost_4_south imp_post_nonsouth impost_4_nonsouth
>                                           using table5.out, bdec(2) se nor2 nocons append;
 36.  test imp_post_south+impost_4_south=0;
 37.  test imp_post_nonsouth+impost_4_nonsouth=0;
 38.  test imp_post_south=imp_post_nonsouth;
 39.  test impost_4_south=impost_4_nonsouth;
 40.  test imp_post_south+impost_4_south=imp_post_nonsouth+impost_4_nonsouth=0;
 41.  xi: xtreg lnb`r' impost_4_south impost_4_nonsouth i.year*i.south , fe i(leaid) cluster(leaid);
 42.  outreg2 impost_4_south impost_4_nonsouth using table5.out, bdec(2) se nor2 nocons append;
 43.  test impost_4_south=impost_4_nonsouth;
