. foreach r in pu pr to {;
  2.  **************************;
.  * Black Outcomes, Table 4*;
.  **************************;
.  xi: xtreg lnb`r' imp_post            i.year*i.south            , fe i(leaid) cluster(leaid);
  3.  if "`r'"=="pu" {;
  4.   outreg2 imp_post using table4.out, bdec(2) se nor2 nocons replace;
  5.  };
  6.  else {;
  7.   outreg2 imp_post using table4.out, bdec(2) se nor2 nocons append;
  8.  };
  9.  xi: xtreg lnb`r' imp_post impost_4 i.year*i.south            , fe i(leaid) cluster(leaid);
 10.  outreg2 imp_post impost_4 using table4.out, bdec(2) se nor2 nocons append;
 11.  test imp_post+impost_4=0;
 12.  xi: xtreg lnb`r' impost_4            i.year*i.south , fe i(leaid) cluster(leaid);
 13.  outreg2 impost_4 using table4.out, bdec(2) se nor2 nocons append;
 14.  xi: xtreg lnb`r' impost_4            i.year*i.south i.leaid*year, fe i(leaid) cluster(leaid);
 15.  outreg2 impost_4 using table4.out, bdec(2) se nor2 nocons append;
 16.  xi: xtreg lnb`r' impost_4            i.year*i.south `base60'   , fe i(leaid) cluster(leaid);
 17.  outreg2 impost_4 using table4.out, bdec(2) se nor2 nocons append;
 18.  xi: xtreg lnb`r' impost_4 imp_pre23  i.year*i.south            , fe i(leaid) cluster(leaid);
 19.  outreg2 impost_4 imp_pre23  using table4.out, bdec(2) se nor2 nocons append;
 20.   **** These are to be used for black private only;
.  xi: xtreg lnb`r' imp_post            i.year*i.south i.leaid*year, fe i(leaid) cluster(leaid);
 21.  outreg2 imp_post using table4.out, bdec(2) se nor2 nocons append;
 22.  xi: xtreg lnb`r' imp_post            i.year*i.south `base60'   , fe i(leaid) cluster(leaid);
 23.  outreg2 imp_post using table4.out, bdec(2) se nor2 nocons append;
 24.  xi: xtreg lnb`r' imp_post imp_pre23  i.year*i.south            , fe i(leaid) cluster(leaid);
 25.  outreg2 imp_post imp_pre23  using table4.out, bdec(2) se nor2 nocons append;
 26.  **************************;
.  * Black Outcomes, Table 5*;
.  **************************;
.  xi: xtreg lnb`r' imp_post_south imp_post_nonsouth i.year*i.south               , fe i(leaid) cluster(leaid);
 27.  if "`r'" == "pu" {;
 28.   outreg2 imp_post_south imp_post_nonsouth using table5.out, bdec(2) se nor2 nocons replace;
 29.  };
 30.  else {;
 31.   outreg2 imp_post_south imp_post_nonsouth using table5.out, bdec(2) se nor2 nocons append;
 32.  };
 33.  test imp_post_south=imp_post_nonsouth;
