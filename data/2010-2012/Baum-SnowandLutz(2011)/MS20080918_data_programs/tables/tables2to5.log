. foreach r in pu pr to {;
  2.  **************************;
.  * White Outcomes, Table 2*;
.  **************************;
.  xi: xtreg lnw`r' imp_post            i.year*i.south            , fe i(leaid) cluster(leaid);
  3.  if "`r'"=="pu" {;
  4.   outreg2 imp_post using table2.out, bdec(2) se nor2 nocons replace;
