//Generating variables//period dummiesgen dyear1_1=(yr1<6)gen dyear1_2=(yr1>5)*(yr1<12)gen dyear1_3=(yr1>11)gen dyear2_1=(yr2<6)gen dyear2_2=(yr2>5)*(yr2<12)gen dyear2_3=(yr2>11)gen d32=dyear2_3*dyear1_2gen d31=dyear2_3*dyear1_1gen d21=dyear2_2*dyear1_1//interaction of period dummies and lotsizegen d32lotsize=d32*lotsizegen d31lotsize=d31*lotsizegen d21lotsize=d21*lotsize//interaction of period dummies and square footagegen d32sqft=d32*sqftgen d31sqft=d31*sqftgen d21sqft=d21*sqft//interaction of period dummies and # of bedroomsgen d32beds=d32*bedsgen d31beds=d31*bedsgen d21beds=d21*beds//interaction of period dummies and # of bathroomsgen d32baths=d32*bathsgen d31baths=d31*bathsgen d21baths=d21*baths//interaction of period dummies and # of roomsgen d32rooms=d32*roomsgen d31rooms=d31*roomsgen d21rooms=d21*rooms//interaction of period dummies and year of home builtgen d32yrblt=d32*yrbltgen d31yrblt=d31*yrbltgen d21yrblt=d21*yrblt//interaction of period dummies and county dummiesgen d32co2=d32*county2gen d31co2=d31*county2gen d21co2=d21*county2gen d32co3=d32*county3gen d31co3=d31*county3gen d21co3=d21*county3gen d32co4=d32*county4gen d31co4=d31*county4gen d21co4=d21*county4gen d32co5=d32*county5gen d31co5=d31*county5gen d21co5=d21*county5gen d32co6=d32*county6gen d31co6=d31*county6gen d21co6=d21*county6