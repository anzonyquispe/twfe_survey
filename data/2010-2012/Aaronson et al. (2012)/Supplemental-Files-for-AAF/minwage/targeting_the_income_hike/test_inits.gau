new;
cls;
#include "C:\Research\minwage\minwage_functions.gau";
loadPath = "C:\\Research\\minwage\\targeting_the_income_hike";

periods=188;
numsims=5000;
//periods=5;
//numsims=10;

// AVGmat matrix will contain the average income across individuals, at each time period
// for nohike, hike=16, hike=64, hike=128 ==>4 columns
AVGmat=zeros(periods,4);


for nn (1,4,1);
    rndseed 561;
 
    hikeswitch=1;
    if nn==1; hikeswitch=0; hikestart=0; wageincr=0; endif;

    if nn==2; hikeStart=16; endif;
    if nn==3; hikeStart=64; endif;
    if nn==4; hikeStart=128; endif;


//We'd like the average income increase due to the minimum wage hike to be $250 FOR EACH Age Group. We set the parameter wageIncr conditional on age, in order to get this.

    if nn==2; wageIncr= ln(1.0835); endif;
    if nn==3; wageIncr= ln(1.0517); endif;
    if nn==4; wageIncr= ln(1.0457); endif;

        initialPI = .44;          // Change this to target an average $4500
        rho=2;                    // CRRA  Gamma in Table 1

        beta= .93^(1/4);          // discount rate. ==4th root of .95   

        theta=.15;                // cobb-douglas exponent   (consumpt^(1-theta))*(stock^ theta) 
        PIgrowthR = 0.0108;       // Income Growth Rate (per quarter)
        downpaymentR = .4;        // downpayment rate
        delta= 0.034;             // depreciation rate of durables.
        R = 1.03^(1/4);           // 1+ rate of return.    
        fixedDurableCost = 0;     // multiplier on todays stock to determine fixed cost of buying a car/house (ie I>0)

    
        numPIstates = 7; 

        transitionM=0;
        PIstates=0;             // note: here, a PI state is an AR(1) shock - like a raise, not permanent income)
        c=0;

        sse = 0.005;       // Sigma squared e (VAR AR1)
        ssu = 0.05;          // Sigma squared u  (Trans comp)
        rho_paper = .995; // rho as defined in the paper

        adjustmentterm = (ssu + sse/(1-rho_paper^2))/2;

//CAREFUL HERE!   

        upper_lev=0.07;   //as these get appropriately low, grids will NEED to be expanded
        lower_lev=0.07;    
        // sse is sigma squared epsilon in table 7
        {transitionM,PIstates,c}=tauch(sse^(1/2), rho_paper, numPIstates, upper_lev, lower_lev);//units are  logged, additive.
        //if sse=0, uncomment next 2 lines;
        //PIstates=zeros(numPIstates,1);
        //transitionM=eye(numPIstates);
        //"No variability!";


        oddNumTSvals=7;   // I prefer to keep this number odd (hence the name) so as to have 0 be a TSval
        if ( round(oddNumTSvals/2) == oddNumTSvals/2);  print "oddNumTSvals isn't an odd number. it is " oddNumTSvals " Odd numbers allow exp(0)=1 to be an option. Comment this out if you want to keep your value. ending"; end; endif;
        // ssu is sigma squared u in table 7
        logSD_TS = ssu^(1/2); // .34928=.122^1/2


//! careful, .05 v .01!
        {TSprobabilities, TSvals, c} = tauch(logSD_TS, 0, oddNumTSvals, .05, .05); //units are NOT logged, additive.        
//!
        TSprobabilities = TSprobabilities[1,.]'; // all rows are identical, since the correlation coeff was set to zero
        TSvals = exp(TSvals);

Tsvals = 1;
TSprobabilities=1;

   

        timeAdjustment = PIgrowthR*(hikeStart-30);  // this program was written to always have hikes at time 30, when ;
                                                    // I change this, I start to distort the program this adjustment should correct it;



incomeLevelAtHike = exp(ln(3.6)-adjustmentterm ); //!!!!!!!!!!!!

//incomelevelathike is currently multiplied by 3.6/4.7, because setting 3.6 actually gives a value of 4.7.  so until i figure out how to get
//the value i want, im just using this hack.  !.

        
//wageincr at 1.07 when incomeLevel is 3.6*.76

//confused as to why this calculation doesnst sitll hold but apparently it gives $500. t=30 now.
//wageIncr= ln(1.065); // to get $300; .07629* 3.625 * 1.08 = 300;  1.08 is about the mean of exp(P*TS). 

        hikeLength = 10; //hikeLength is the number of (consecutive) time periods for which the hike is nonzero (e.g. the length of the wageHike vector)
        Cfloor = .1;
        PIgrowthChangeTime = 81; // Time (State var!) at which PIgrowthR changes.
        AfloorFnVersion = 0;    //0 is paper's model.  1 is analytical model, i.e. assets>=0 at death is only constraint.

//1/5, 1/9 not good enough [can loko at sims and see lots of cases where one goes down by max and hten goes down more next time].
//seem to be such that you can always get where you want to be after 2 periods, though.  
        Iguess = 1/7; //on at least semifine one run, going from 1/4, 1/8 to  1/12, 1/24 gave identical results
        Cguess = 1/11; // in general need way more cdecs than idecs.  and need a broader range of idecs than cdecs



Sstates = setGrid(.3|2|7|25|50|90|220, .3|.4|.4|1|6|10);

/*
        Tstates = seqa(1, 1, 200);     //T goes from 1 to periods/numTstates; functions require this 
                                       // A sim-person makes (periods-1) decisions in all, and has periods states. 
                                       // end of final period is certain death e.g. last dec should be "eat all"      
        Astates = setGrid(-180|-35|-10|10|30|150, 10|1.5|.7|3|10);  //COH states, actually! 
                                                                    //-31 was min for 4ksims for 1.27001_agrideror 
                                                                    //the states from 30 to 150 shoudl be very coarse, just for initial sims that are super high.
        Sstates = setGrid(.3|2|7|25|50|90|220, .3|.4|.6|2|6|10);  // 15 to 40 seems to be the range everyone is in around period 30; 
        Cdec = setGrid(Cfloor|2|4|18|27, .1|.1|.1|1);   //1.27 had max cons of 22, 4k sims.
        Idec = setGrid(0|2|4|7|14|20, .1|.1|.1|.8|1);   //top of igrid pretty rare


        numCdecs = rows(Cdec); 
        numIdecs = rows(Idec);
        CadjustmentLow = floor(Cguess*numCdecs);
        CadjustmentHigh = ceil(Cguess*numCdecs);
        IadjustmentLow = floor(Iguess*numIdecs);
        IadjustmentHigh = ceil(Iguess*numIdecs);//
*/
       gridScale=1000;
    
    if (hikeSwitch == 0);
        wageHike = zeros(hikeLength, 1);
    elseif (hikeSwitch == 1);
        wageHike = seqa(wageIncr, -wageIncr/hikeLength, hikeLength);
    endif;


// **********Save Data ************;

outpath = "C:\\Research\\minwage\\targeting_the_income_hike"; 
save path=^outpath beta, R, rho, theta, PIgrowthR, downpaymentR, delta, numPIstates, transitionM, 
        PIstates, hikeStart, wageHike,  PIgrowthChangeTime, gridScale
        AfloorFnVersion, fixedDurableCost, TSvals, TSprobabilities, incomeLevelAtHike, initialPI;
//probably soon add another parameter for which versioin of "setFixedDurCostFunction" is passed



//********************;
simOrd = periods|numsims; 
initSims = zeros(numsims,4);
TSmat = arrayinit(simOrd,0);
PIidxmat = arrayinit(simOrd,0); //PIidx is a state var. note the laast index is irrelevant of course.

Sfloor = Sstates[1];
numColsGuess=5; 
scf_ASPI_path = "C:\\Research\\minwage\\calculatingInitDistForSim\\scf_pi40.out";

    loadm a_s_pi[]=^scf_ASPI_path; 
    numRows = rows(a_s_pi)/numColsGuess;
    loadm a_s_pi[numRows, numColsGuess]=^scf_ASPI_path;
    a_s_pi = a_s_pi./gridScale;
    a_s_pi = a_s_pi[.,1:3]; //drop 2 excess columns for now
    a_s_pi = (seqa(1,1,numRows)./numRows)~seqa(1,1,numRows)~a_s_pi;
    aidx=5; sidx=4; incIdx=3;
    a_s_pi = a_s_pi~income2PI(a_s_pi[.,incIdx], hikeStart, PIstates, PIgrowthR, incomeLevelAtHike, 81, initialPI);
    piidx=6;
//print "a_s_pi" a_s_pi;

    simGenM=rndu(numsims,1);
    initFeasibilityViolated=-1;
    initSims = zeros(numsims,4);
    aidx_IS=3; sidx_IS=2; incIdx_IS=1; piIdx_IS=4; // "_IS" is "for initial sims array"
    for n (1, numsims, 1);
        tmp = selif(a_s_pi[.,3|4|5|6], simGenM[n].<a_s_pi[.,1]); //3,4,5,6 are: a,s,income, permincomeIdx
        initSims[n,.] = tmp[1,.];
        //check that feasibility is satisfied:
        afloor = getAfloor(initSims[n,2], downpaymentR, 1, periods, AfloorFnVersion);
        if (initSims[n,aidx_IS]<afloor); initSims[n,aidx_IS]=afloor; initFeasibilityViolated=initFeasibilityViolated|n; endif;
        if (initSims[n,sidx_IS]<sfloor); initSims[n,sidx_IS]=sfloor; endif;
    endfor;

tempy2 = arrayinit(simOrd,0);


if (numsims>1);
    setArray PIidxmat, 1, initSims[.,piIdx_IS]';
elseif (numsims==1); //GAUSS is stupid and can't figure out how to use setarray if numdims are nx1x1..x1 or something.
    PIidxmat[1,1] = initSims[1,piIdx_IS]';
else;
    print /flush "numsims<1; error, ending."; end;
endif;

for t (1, periods-1, 1);
  for sim (1, numsims, 1);
    y=getIncome(t, arraytomat(PIidxmat[t,sim]), PIstates, PIgrowthR, wageHike,  hikeStart, IncomeLevelAtHike, PIgrowthChangeTime, initialPI);
                rndnum = rndu(1,1);
                cumulProbs = cumsumc(TSprobabilities);
                probChooser = (rndnum .< cumulProbs);
                tmp = selif(TSvals, probChooser);
                TSmat[t,sim] = tmp[1];
                tempy2[t,sim] = y*TSmat[t,sim];
                /* shocks */      /* Let PI shocks hit at end of period, for next time */
                rndnum = rndu(1,1); // not sure if it is more time efficient to generate a buncha random #s at once, but it's not space efficient
                cumulProbs = cumsumc(transitionM[arraytomat(PIidxmat[t,sim]) ,.]');
                probChooser = (rndnum .< cumulProbs);
                tmp = selif(seqa(1,1,numPIstates), probChooser);
                PIidxmat[t+1,sim] = tmp[1];
endfor;
endfor;
 


AVG=amean(tempy2,1);
avg_16=(AVG[12]+AVG[13]+avg[14]+avg[15])/4;
avg_64=(AVG[60]+AVG[61]+avg[62]+avg[63])/4;
avg_128=(AVG[124]+AVG[125]+avg[126]+avg[127])/4;
print "mean income at age 21" avg_16;
print "mean income at age 33" avg_64;
print "mean income at age 49" avg_128;
//We want the following to be $4500
print "Avg Qtrly Income Over the 4 qtrs before HikeStart" (avg_16+avg_64+avg_128)/3;



avgmat[.,nn]=avg;

output on;
screen off;

if nn==1; dplogFilename = "income_nohike.txt"; endif;
if nn==2; dplogFilename = "income_hike16.txt"; endif;
if nn==3; dplogFilename = "income_hike64.txt"; endif;
if nn==4; dplogFilename = "income_hike128.txt"; endif;
pathTmp = loadPath $+ "\\" $+ dplogFilename;
output file = ^pathTmp reset;

for t (1, periods-1, 1);
  for sim (1, numsims, 1);
//    print t "," sim "," consM[t,sim] "," Ymat[t,sim] "," investM[t,sim];
    ti = tempy2[t,sim];
    print t "," ti;
  endfor;    
endfor;
output off;
screen on;

endfor;


proc(1) = setGrid(delimitersVec, incrVec);
    local theGrid, delimLength;

    delimLength = rows(delimitersVec)*cols(delimitersVec);
    //make sure two arguments are vectors and are the same length
    if (( rows(delimitersVec) != 1 and cols(delimitersVec) != 1 ) or
        ( rows(incrVec) != 1 and       cols(incrVec) != 1      ) or
         (delimLength != (rows(incrVec)*cols(incrVec) + 1))  );
        "error in arguments to setGrid. delimiters is " delimitersVec "and incrVec is " incrVec; end;
    endif;
    ///

   theGrid = seqa(delimitersVec[delimLength-1], incrVec[delimLength-1], (delimitersVec[delimLength]-delimitersVec[delimLength-1])/incrVec[delimLength-1] + 1);
    for i (delimLength-2, 1, , -1);
        theGrid = seqa(delimitersVec[i], incrVec[i], (delimitersVec[i+1]-delimitersVec[i])/incrVec[i])|theGrid;
    endfor;

    retp(theGrid);
endp;

