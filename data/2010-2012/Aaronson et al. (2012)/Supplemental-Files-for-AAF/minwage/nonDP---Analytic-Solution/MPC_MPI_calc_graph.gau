///////////////// function /////////////////////



//periods should be time LEFT to live, at moment of calculation, of course
proc(1) = getMPC(timeT, beta, R, periods, rho, theta);
    local discountTerm, MPC, MPCnought,rbr,numerator, denominator;

    rbr = (1/R)*((beta*R)^(1/rho));
    numerator = 1-rbr;
    denominator = 1 - rbr^periods;
    MPCnought = (1-theta)*numerator/denominator; // by MPCnought i mean MPCat 1 , nought from notes.
    discountTerm = (R*beta)^((timeT-1)/rho); // -1 cus start at 1 
    MPC = discountTerm * MPCnought;
    retp(MPC);
endp;

/*
Function calculating marginal propensity to Invest in durables relative to
an increase in permanent lifetime wealth (A0 + sum( (1/r^t)*Yt)).
See calculations elsewhere.
Time 1 is initial period (not 0).
//periods should be time LEFT to live, at moment of calculation, of course
*/

proc(1) = getMPI(timeT, beta, R, delta, periods, rho, theta);
    local MPI, MPInought, pricestock, rbr, numerator, denominator, discountTerm; //pricestock is price of one unit of stock

    pricestock = ((R-1)+delta)/R;
    rbr = (1/R)*((beta*R)^(1/rho));
    numerator = 1-rbr;
    denominator = 1 - rbr^periods;
    MPInought = (1/pricestock)*theta*numerator/denominator; //by "nought" i mean period 1 , e.g. period 0 in notes.
    if (timeT==1);
        MPI = MPInought;
    elseif (timeT>1);
        MPI = MPInought*( (beta*R)^(1/rho) + delta-1 );
        discountTerm = (R*beta)^((timeT-2)/rho); //-2 b/c start at 1; -1 if start at 0
        MPI = discountTerm*MPI; 
    endif; // T >=1.

    retp(MPI);
endp;




