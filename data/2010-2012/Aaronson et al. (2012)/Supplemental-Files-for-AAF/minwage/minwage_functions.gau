//fn: income2PI converts raw income data from the SCF to perm income indices as used in the simulation
//note that incomeData should ALREADY be converted to the same units that getIncome returns.
// ie if Y==1 means $1000, set simScaleFactor to 1000
/* The current method is to use getIncome_hikeStart to calculate the simulation level incomes at the time
of the hike (which is when the data come from) and see where these incomes fall. 
This is built to work with tauchen's method.  ie it takes two parameters, ltail and utail, which specify
how far in the distribution the upper and lower tails fall [and all other points are equispaced in tauch]
so that it can tell how to distribute the data to PI states.

PSD-- I'm hard coding this to look at time period zero and compare that to the SCF data instead of scaling time zero up
to the hikeStart.  This was at Eric's request.  IE getIncome(0,......)

*/
//proc(1) = income2PI(incomeData, hikeStart, PIstates, PIgrowthR, incomeLevelAtHike, PIgrowthRChangeTime, ltail, utail);
proc(1) = income2PI(incomeData, hikeStart, PIstates, PIgrowthR, incomeLevelAtHike, PIgrowthRChangeTime, initialPI);
    local PIindices, PIlevelsAtHike, PIcutpoints, numPIstates, numIncomePoints, somePIindices, index, piRangeTest;

    //initializatoins
    numPIstates = rows(PIstates)*cols(PIstates);
    numIncomePoints = rows(incomeData)*cols(incomeData);
    PIindices = -1*ones(numIncomePoints,1);
    //end inits

    if (numPIstates>1);
        PIlevelsAtHike = getIncome(0, seqa(1,1,numPIstates), PIstates, PIgrowthR, 0, hikeStart, incomeLevelAtHike, PIgrowthRChangeTime, initialPI);  
//        PIlevelsAtHike = getIncome(hikeStart, seqa(1,1,numPIstates), PIstates, PIgrowthR, 0, hikeStart, incomeLevelAtHike, PIgrowthRChangeTime, initialPI);  
        PIcutpoints = PIlevelsAtHike[2:rows(PIlevelsAtHike)]|0;
        PIcutpoints = (PIcutpoints+PIlevelsAtHike)/2; //PIlevelsAtHike+(PIcutpoints-PIlevelsAtHike)/2;
        PIcutpoints = PIcutpoints[1:(numPIstates-1)]; //Now PIcutpoints is  the halfway points between each PIlevels.  
        somePIindices = seqa(1,1, numPIstates-1); // all indices but the last
    else;
        PIcutpoints = -1/0; //dont set somePIindices;
        //PIcutpoints = 1/0; somePIindices = 1;
    endif;

    
    for n (1, numIncomePoints, 1);
        PIrangeTest = (incomeData[n].<=PIcutpoints);
        if (not (PIrangeTest == 0));
            index = selif(somePIindices, PIrangeTest);
            index = index[1];
        else; //income > all cutpoints so it goes to last index
            index = numPIstates;
        endif;
        PIindices[n]=index;
    endfor;

    retp(PIindices);
endp;






//should work with matrices? 
proc(1) = getAfloor(stockState, downpaymentR, theTime, periods, fnVersion);
    local indicator; //only used for 'no liquidity limits version'

    if (fnVersion == 0);     //standard version

        retp((downpaymentR-1).*stockState);

    elseif (fnVersion == 1);  // No liquidity limits version

        //stock time periods are all states.
        indicator = missrv(miss( (theTime .< (periods)), 1), -1/0);
        retp( indicator );

    endif;


endp;


