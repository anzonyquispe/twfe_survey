@-----------------------------------------------------------------------------@
/* tmp function for approximating normal distribution.  Produces
a uniform distribution as result.  Better than tauch in that, with
small numbers of states space, approximates distribution better.
*/

proc(2) = normal_approx(stddev, numStates, utail, ltail);
    local theStates, theProbabilities, prev, oldprev; //distMin, distMax, i,

    theProbabilities = seqa(1/numStates, 1/numStates, numStates); //start inc n
    theProbabilities[numStates] = 1-utail;
    prev = cdfni(ltail);
    theStates = cdfni(theProbabilities);

    for i (1, numStates, 1);
        oldprev = prev;
        prev = theStates[i];
        theStates[i] = oldprev + (theStates[i]-oldprev)/2;
    endfor;

    theStates = theStates * stddev;
    theProbabilities = ones(numStates,1)*(1/numStates);
    retp(theProbabilities, theStates);
endp;

/*
   Tauch:    Converts an AR(1) process into a Markov chain
             Follows Tauchen (Ec. Letters, 1986)
   Inputs:
       stdi:       Scalar, std. dev. of innovation (std. dev. of
epsilon in tauchen)
       rho:        Scalar, AR(1) correlation coefficient
       M:          Scalar indicating number of elements in the chain
       Tail:       Scalar indicating percentages left in each tail
   Output:
       pmtx:       MxM transition matrix
                   rows denote time t values, cols time t+1 values
       values:     Mx1 vector of values
*/

proc(3) = tauch(stdi,rho,m,utail,ltail);

   local v_min, v_max, stdy, pmtx, values, yold, ynew, i, j, w, fe,
intvals;

   stdy    = sqrt(stdi^2/(1-rho^2));

   v_min   = cdfni(ltail)*stdy;
   v_max   = cdfni(1-utail)*stdy;

//" v_min and v_max = " ;
//v_min; v_max;

   pmtx    = zeros(M,M);
   values  = zeros(M,1);
   values  = seqa(v_min,(v_max-v_min)/(m-1),m);
   intvals = seqa((values[2,1]+values[1,1])/2,(v_max-v_min)/(m-1),m-1);

   i=1; do until i>m;
       yold = values[i,1];
       ynew = values[1,1];
       w = (values[2,1] - values[1,1])/2; //" zz w/2 = " w; /* this is w/2 from the paper */
       fe = (ynew - rho*yold);
       pmtx[i,1] = cdfn((fe+w)/stdi); /* this is equation 3b */

       j=2; do until j>m-1;
           ynew = values[j,1];
           w = (ynew-values[j-1,1])/2; 
            //" w/2 = " w;
           fe = ynew - rho*yold;
           pmtx[i,j] = cdfn((fe+w)/stdi) - cdfn((fe-w)/stdi); /* this
is equation 3a */
       j=j+1;  endo;

       ynew =values[m,1];
       w = (values[m,1] - values[m-1,1])/2;
       fe = (ynew - rho*yold);
       pmtx[i,m] = 1 - cdfn((fe-w)/stdi); /* this is equation 3b */
   i=i+1; endo;



    retp(pmtx,values,intvals);
endp;


