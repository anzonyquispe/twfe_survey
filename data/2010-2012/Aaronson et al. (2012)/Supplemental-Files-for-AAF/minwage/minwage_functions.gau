/*requires: This version of  requires baseArray INCR and newArray DECR */
/* matchArray: Nx1 baseArray, Mx1 newArray.  Returns: 
1) Mx1 vector, indicesHigh. 1<=indicesHigh<=N. 
2) Mx1 vector, indicesLow. 1<=indicesLow<=N.
3) Mx1 vector, weightsHigh. 0<=weights<=1.
It will be true that baseArray[indicesLow[m]]<=newArray[m]<=baseArray[indicesHigh[m]]
for baseArray[1]<newArray[m]<baseArray[N].  Any values of newArray outside the range
of baseArray will have both indices values set to the max/min.
The third vector, weights, will have weights for linear interpolation such that
 (1- weightsHigh[m]) * baseArray[indicesLow[m]] + (weightsHigh[m]) * baseArray[indicesHigh[m]] == newArray[m]
as long as, again, newArray falls within the range of baseArray. Otherwise it will be "set" to the max/min 
of baseArray.
Big-O order of matchArray=M+N.
Requires both baseArray and newArray to be sorted (see above).
indicesHigh[m] might equal indicesLow[m]. (so careful of dividing by indicesHigh-IndicesLow. Rather,
use weightsHigh).  if there are multiple indices in baseArray with the same value, behavior
is not well-defined.
*/
proc(3) = matchArray(baseArray, newArray);
    /*Base case: all elts less than baseArray[1] */
    local N, M, i, j, indicesHigh, indicesLow, weightsHigh;
    N=rows(baseArray); M=rows(newArray);
    indicesHigh = zeros(M,1);
    indicesLow =  zeros(M,1);
    weightsHigh = zeros(M,1);

    i=M;// i>=1
    do while (newArray[i] <= baseArray[1]);
        indicesLow[i]=1;
        indicesHigh[i]=1;
        weightsHigh[i]=0;
        i=i-1;
        if i<1; break; endif; //no short-circuit eval
    endo;
    
    /*walk through newArray comparing to base, using fact that both arrays are monotonically ordered (asc, desc here)*/
    /*newArray[i] >= baseArray[j-1] always */
    let j=2;// j<=N
    do while (i>=1 and j<=N); //j<=N test here is necessary in case N==1.
        do while (newArray[i]>=baseArray[j]); // ">" moves through newArray quickest ; ">=" moves through baseArray quickest
            j=j+1;
            if (j>N); break; endif;
        endo;
        if (j>N); break; endif;  //"want" to iterate once more; can't; so go to final case loop.
        indicesLow[i] = j-1;
        indicesHigh[i] = j;
//        if (baseArray[j] == baseArray[j-1]); //This test is only useful if baseArray[1]==baseArray[2]. i believe that using ">=" above makes this test useless
//print "should never land here";
//            weightsHigh[i] = 0; 
//        else;
        weightsHigh[i] = (newArray[i] - baseArray[j-1]) / (baseArray[j] - baseArray[j-1]);
//        endif;
    i=i-1;
    endo;

    /* final cases */
    do while (i>=1);
        indicesLow[i]=N;
        indicesHigh[i]=N;
        weightsHigh[i]=1;
        i=i-1;
    endo;

    retp(indicesLow, indicesHigh, weightsHigh);
endp;


/*  Locates nearest point in an array
   (mostly) From Numerical Recipes in C, p. 117
Weight returned is for the higher index.
*/
proc(3) = binaryLocate( Xarray,  x);
   local j_L, j_U, j_M, ascend, dif, j_Star, DIM, wghtHigh;
   DIM = rows(Xarray);
   ascend = 1;
   if (Xarray[DIM]<Xarray[1]); ascend = 0; endif;

   j_L = 1;
   j_U = DIM;
   dif = j_U-j_L;

   if (ascend==1);
      do while (dif>1);
         j_M = floor((j_U+j_L)/2);
         if (x>Xarray[j_M]);
            j_L = j_M;
         else;
            j_U = j_M;
         endif;
         dif = j_U-j_L;
      endo;
     
      //j_Star = j_L;

   else;
      do while (dif>1);
         j_M = floor((j_U+j_L)/2);
         if (x<Xarray[j_M]) ;
            j_L = j_M;
         else; 
            j_U = j_M;
         endif;
         dif = j_U-j_L;
      endo;
      
      //j_Star = j_L;
   endif;
    
    if (Xarray[j_U] == Xarray[j_L]) or (Xarray[j_U] < x); //Can't guarantee Xarray[j_U] != Xarray[j_L] even if j_U>j_L always
        wghtHigh=1;
    elseif Xarray[j_L] > x;
        wghtHigh = 0;
    else;
        wghtHigh = (x - Xarray[j_L]) ./ (Xarray[j_U] - Xarray[j_L]);
    endif;
   retp(j_L, j_U, wghtHigh);
endp;

/*linear interp procedure for __2__ dimensional matrix. (e.g. not an array)  */
proc(1) = linearInterpolation(xMatrix, lowIndex1,highIndex1,lowIndex2,highIndex2, weightHigh1, weightHigh2);
    local avg;
    		avg = ((1-weightHigh1)*(1-weightHigh2)).*xMatrix[lowIndex1, lowIndex2] +  
                  ((1-weightHigh1)*(weightHigh2)).*xMatrix[lowIndex1, highIndex2]  +
                  ((weightHigh1)*(1-weightHigh2)).*xMatrix[highIndex1, lowIndex2]  +  
                  ((weightHigh1)*(weightHigh2)).*xMatrix[highIndex1, highIndex2];
retp(avg);
endp;



proc(1) = getResults_C(path, filename, numAstates, numSstates, numPIstates, periods);
    local tmpArray, order, x, fullPath;
    fullPath = path $+ filename;
    load x[] = ^fullPath;
    order = numAstates|numSstates|numPIstates|(periods-1);
    tmpArray = areshape(x,order);
retp(tmpArray);
endp;

proc(1) = getDP_C(path, filename, numAstates, numSstates, numPIstates, periods);
    local tmpArray, order, x, fullPath;
    fullPath = path $+ filename;
    load x[] = ^fullPath;
    order = numAstates|numSstates|numPIstates|(periods);
    tmpArray = areshape(x,order);
retp(tmpArray);
endp;





