/************************************* FUNCTIONS/PROCEDURES *****************************/



/*
output_paramsAndGrids():
Prints all the parameters.
*/
proc(0) = output_paramsAndGrids(settingsSwitch, hikeSwitch, Cdec, Idec, Astates, Sstates, PIstates, TSvals,
        transitionM, TSprobabilities, wageHike, hikeStart, R, fixedDurableCost, delta, downpaymentR, PIgrowthR, beta,
        rho, theta, CadjustmentLow, CadjustmentHigh, IadjustmentLow, IadjustmentHigh, numTstates,
        AfloorFnVersion, gridScale);
    local 	numCdecs, numIdecs, numAstates, numSstates, numPIstates, numTSvals,
		numops_total, numops_timeBoundary, numops_main, numops_Izero, numTimeBoundaryCases; //numops vars

    numCdecs=rows(Cdec); numIdecs=rows(Idec); 
    numAstates=rows(Astates)*cols(Astates); numSstates=rows(Sstates)*cols(Sstates); numPIstates=rows(PIstates)*cols(PIstates); numTSvals=rows(TSvals)*cols(TSvals);
    format /ldn 10,5; //set back to old format
    //Logging
    "SettingsSwitch is " settingsSwitch;
    "Grid Scale (ie gridScale is conversion multiplier from sim units to actual dollars; if c==1 in sim, c==Gridscale*1 in real dollars) " gridScale;
    "Hikeswitch is " hikeswitch;
    "Cdec (length: " rows(Cdec) "): " Cdec;
    "Idec: (length: " rows(Idec) "): " Idec;
    "Astates: (length: " rows(Astates) "): " Astates;
    "Sstates: (length: " rows(Sstates) "): " Sstates;
    "PIstates: (length: " rows(PIstates) "): " PIstates;
    "transitionM (rows denote time t values, cols time t+1 values): " transitionM;
    "TSvals: (length: " rows(TSvals) "): " TSvals;
    "TSprobabilities : " TSprobabilities;
    "wageHike " wageHike;
    "Hikestart " hikeStart;
    "R, fixedDurableCost, delta, downpaymentR: " R~fixedDurableCost~delta~downpaymentR;
    "PIgrowthR, beta, rho, theta " PIgrowthR~beta~rho~theta;
    //"Cfloor, Cinc, Iinc, Aincr, Sincr, Cguess, Iguess: " Cfloor~Cinc~Iinc~Aincr~Sincr~Cguess~Iguess;
    "C: low, high" CadjustmentLow CadjustmentHigh;
    "I: low, high" IadjustmentLow IadjustmentHigh;
    
    "dimensions: numTstates, numCdecs, numIdecs, numAstates, numSstates, numPIstates, numTSvals";//Iguess, cguess were here.
    numTstates~numCdecs~numIdecs~numAstates~numSstates~numPIstates~numTSvals; //Iguess, cguess were here.
    if (AfloorFnVersion == 0); "AfloorFnVersion: Standard."; else; "AfloorFnVersion: no liquidity constraints"; endif;
    
    format /len 6,2; //e-notation for the order of ops
    numTimeBoundaryCases = 1;
    //numops_Izero = (numTstates-numTimeBoundaryCases)*numAstates*numSstates*numPIstates*numPIstates*numTSvals*1*numCdecs;  //Izero with NO guessing for izero
    numops_Izero = (numTstates-numTimeBoundaryCases)*numAstates*numSstates*numPIstates*numPIstates*numTSvals*1*(CadjustmentHigh+CadjustmentLow+1); //Izero WITH guessing for Izero
    numops_main = (numTstates-numTimeBoundaryCases)*(numAstates*numSstates*numPIstates*numPIstates*numTSvals*(IadjustmentHigh+IadjustmentLow+1)*(CadjustmentHigh+CadjustmentLow+1));
    numops_timeBoundary = numTimeBoundaryCases*numAstates*numSstates*numPIstates*numPIstates*numTSvals*numIdecs*numCdecs;
    numops_total = numops_main+numops_Izero+numops_timeBoundary;
    "Num total operations [doesnt account for edge of guessing]: " numops_total;
    "Num operations for main cases: " numops_main;
    "num operations for I==0 case: " numops_Izero;
    "num operations for boundary time cases: " numops_timeBoundary;
    "Memory required: " numTstates*numAstates*numSstates*numPIstates*3; // 3 bc VM, CM, IM. // *8bytes per entry for GAUSS
    format /ldn 10,5; //set back to old format
    retp;
endp;


/*getFDC: (get Fixed Durable Cost)
--note, i started off using "FDC" as an abbreviation for fixed durable cost.
Since it's not a flat rate any more, i donno if  "fixed" is still appropriate. 
Maybe it is, since the amount paid has nothing to do with how much you buy.
--the function Takes a state and the DC multiplier, and returns the FDC,
ie what must be paid on top of the cost of the durable goods, if a sim decides to have I>0.
*/
proc(1) = getFDC(Sval, FDC_multiplier);
    retp(FDC_multiplier*Sval);
endp;



 /* getIncome should take the state variables as args and return a scalar */
/* getIncome uses global R and global PIgrowthR and PIstates vector and wageHike*/
/*right now, permIncome should be a non\negative integer, an index for PIstates */
//incomeLevelAtHike is what income will be at the time of the wagehike, given that the PI adjustment is 0.
/*note variable "time" is already taken*/
/*
    New intercept adjustment: ignoring randomness (pistates) and adjustment (wagehike), 
i.e. letting lnY = b + PIgrowthR*T          let b = fixedValue -PIgrowthR*timeBeforeStart
==> lnY(timeBeforeStart) = b + PIgrowthR*timeBeforeStart= fixedValue 
i.e. after timeBeforeStart periods, lnY is fixedvalue.  
*/
// at theTime==PIgrowthChangeTime, PIgrowth stops.  i.e. it is same as what it was previous period.
proc(1) = getIncome(theTime, permIncomeIdx, PIstates, PIgrowthR, wageHike, hikeStart, incomeLevelAtHike, PIgrowthChangeTime, initialPI);
    local income, logIncome, interest, adjustment, hikeLength, hikeIndex, 
            b, timeBeforeStart, fixedValue;

    //inits//
    timeBeforeStart = hikeStart; //1; // recall theTime state goes from 1 to periods (or periods-1)
    fixedValue = ln(incomeLevelAtHike);  
//    b = fixedValue - PIgrowthR*timeBeforeStart;
    b = initialPI;
    hikeLength = rows(wageHike)*cols(wageHike);
    hikeIndex = theTime - hikeStart; 
    //endinits//

    if (hikeLength < 199);
      //interest = (R-1).*assets; // note assets can be negative

      if ((0<=hikeIndex) and (hikeIndex < hikeLength)); //line up with C [also this is the more natural way to have hikeStart defined]
          adjustment = wageHike[hikeIndex+1]; //+1 for gauss' start at 1 indexing
      else;
          adjustment = 0;
      endif;

      /* end min wage hike calculation */

      if (theTime < PIgrowthChangeTime);
          logIncome = b + PIstates[permIncomeIdx] + PIgrowthR*theTime + adjustment;
      else;
          logIncome = b + PIstates[permIncomeIdx] + PIgrowthR*(PIgrowthChangeTime-1) + adjustment;
      endif;
    else;
      logincome = wageHike[theTime] + PIstates[permIncomeIdx];
    endif;
    //income = interest + exp(logIncome); /* uses global var R,  */
    income = exp(logIncome); 
    retp(income);
endp;


//print "getincome "  getIncome(5, 1, 0, .001, 0, 30, 3.6, 81 );
