Trade Liberalization, Exports and Technology Upgrading: Evidence on the Impact of MERCOSUR on Argentinean Firms
This stata .do file uses the dataset Firm_1.dta created by the accompanying .do file 
20081226_Create_Data to generate the results in the paper. The mapping of sections of the the code to the tables is   
indicated below.

This program produces the following Tables: 

1. Appendix Tables D.1 and D.2
2. Tables 2 to 6
3. Appendix Table E.1
4. Table 7
5. Table E.2
6. Table 8
7. Appendix Table E.3
8. Tables 9, 11 and 12

Note: Tables 1 and 10 are generated by an accompanying .do file named Tables_1_and_10.do

For variable definitions see accompanying stata .do file 20081226_Create_Data.do
*/


clear
set mem 80m
set more off
set matsize 150

# delimit ;

use Firm_1.dta;



/* Appendix Table D.1  summary statistics  */


/* All Firms */

reg m217a1 ;
for X in var  Lef1 m201c1 Ls1_Lef1 SIA1_Lef1 Sk1_Lef1 : reg X ;
reg SIA1_Lef1 if  SIA1_Lef1~=0;
reg Sk1_Lef1 if Sk1_Lef1~=0;
for X in var  pHpdpc pHpd pHpc : reg X; 

/* Non Exporters */

gen E1=X1;
reg m217a1  if X1==0;
for X in var  Lef1 m201c1 Ls1_Lef1 SIA1_Lef1 Sk1_Lef1  : 
reg X  if E1==0;
reg SIA1_Lef1 if  SIA1_Lef1~=0  & X1==0;
reg Sk1_Lef1 if  Sk1_Lef1~=0  & X1==0;
for X in var   pHpdpc pHpd pHpc : 
reg X if E1==0;

/* Exporters */


reg m217a1 if X1==1;

for X in var  Lef1 m201c1 Ls1_Lef1 SIA1_Lef1 Sk1_Lef1 : 
reg X if E1==1;
reg SIA1_Lef1 if SIA1_Lef1~=0  & X1==1;
reg Sk1_Lef1 if Sk1_Lef1~=0  & X1==1;
for X in var pHpdpc pHpd pHpc : 
reg X if E1==1;
reg m202e1_m201c1 if X1==1;
 

/* Appendix Table D.2 */

tabulate log_Lef1d4Q;
tabulate log_Lef1d4Q if pHpdpc~=.;
tabulate log_Lef1d4Q if log_SIA2_log_SIA1~=.;

/* TABLE 2  */

/* levels */ 

