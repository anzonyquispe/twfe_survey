treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Tercile 3 of spending") stats(N) stfmt(%3.0f)* close sample loop below}* close basic/supp loop below}* Cut by INCOMEuse erplanbyincome, cleardrop if income==.gen obs_income=.replace obs_income=X if plancode==2 & income==1replace obs_income=X if plancode==2 & income==2replace obs_income=X if plancode==2 & income==3replace obs_income=X if plancode==4 & income==1replace obs_income=X if plancode==4 & income==2replace obs_income=X if plancode==4 & income==3replace obs_income=X if plancode==6 & income==1replace obs_income=X if plancode==6 & income==2replace obs_income=X if plancode==6 & income==3replace obs_income=X if plancode==8 & income==1replace obs_income=X if plancode==8 & income==2replace obs_income=X if plancode==8 & income==3qui do drugs_createvars capture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obs_incomeegen totalusage=sum(usage), by(plancode timetrend income)gen paypp=imputed_totalpay/obs_incomeegen totpaypp=sum(paypp), by(plancode timetrend income)gen  inspp=imputed_inspay/obs_incomeegen totinspp=sum(inspp), by(plancode timetrend income)label var totalusage "Total usage"sort plancode year month incomecapture drop _mergemerge plancode year month income using copaybyincomerename copaybyincome         meancopayrename modalcopaybyincome    meancopay02rename modalcopay02retailbyincome meancopay02rettab _mergedrop if _merge!=3* above drops some obs with missing income drop if plancode==.* Pre-period means* Across all drug types and by income tercile : Row1=Copay per drug, Row2=Total Payments per Drug, Row3= Total use per person, Row4=Total Payments per person, Row5=Total Insurer Payments per persontable hmo            income  if basic==0  & $preperiodmeans [aw=obs_income], c(mean meancopay mean avgtot mean totalusage mean totpaypp mean totinspp)  format(%3.2f) row* Use by incoke tercile and type of drug table hmo importance income  if basic==0 &  $preperiodmeans [aw=obs_income], c(mean usage) format(%3.2f) rowforeach basic   in 0 {foreach sample in pooled 2001 2002 {forvalues income = 1/3 {* Estimate models for total usage: data is that the level of terciles and importance variable (1,2,3) so only use the first obs in each period for totalusagequi xtgls meancopay plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & income==`income' & importance==1           ${timesampleomit`sample'} [w=obs_income], $optionsestimates store copay`income'qui xtgls totalusage plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & income==`income' & importance==1             ${timesampleomit`sample'} [w=obs_income], $optionsestimates store total`income'qui xtgls totpaypp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & income==`income' & importance==1             ${timesampleomit`sample'} [w=obs_income], $optionsestimates store totpaypp`income'qui xtgls totinspp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & income==`income' & importance==1             ${timesampleomit`sample'} [w=obs_income], $optionsestimates store totinspp`income'forvalues importance = 1/3 {qui xtgls      usage plancodeD1-plancodeD8 ${treat`sample'}   timetrendD* if basic==`basic' & income==`income' & importance==`importance'  ${timesampleomit`sample'} [w=obs_income], $optionsestimates store DD`income'`importance'* close importance loop below}* close income loop below}di "DD Regs by Income Tercile for Basic Plans=`basic'"di "(Col2=Copay, Col2=Total Drug paymnts, col3=Insurer Drug Payments, col4=use across all drug types; col5=acute drugs, col6=chronic drugs, col7=lifestyle drugs)"estimates table copay1 totpaypp1 totinspp1 total1 DD11 DD12 DD13, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Tercile 1 of Income") stats(N) stfmt(%3.0f)estimates table copay2 totpaypp2 totinspp2 total2 DD21 DD22 DD23, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Tercile 2 of Income") stats(N) stfmt(%3.0f)estimates table copay3 totpaypp3 totinspp3 total3 DD31 DD32 DD33, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Tercile 3 of Income") stats(N) stfmt(%3.0f)* close sample loop below}* close basic/supp loop below}* Cut by CHARLSONuse erplanbycharlson, clear* code that create obs-charlson cannot be moved to drugs_createvars.do as "tercile" var is only defined in erplanbytercile dataset.gen obs_charlson=.replace obs_charlson=X if plancode==2 & charlson ==0replace obs_charlson=X if plancode==2 & charlson ==13replace obs_charlson=X if plancode==2 & charlson ==23replace obs_charlson=X if plancode==2 & charlson ==49replace obs_charlson=X if plancode==4 & charlson ==0replace obs_charlson=X if plancode==4 & charlson ==13replace obs_charlson=X if plancode==4 & charlson ==23replace obs_charlson=X if plancode==4 & charlson ==49replace obs_charlson=X if plancode==6 & charlson ==0replace obs_charlson=X if plancode==6 & charlson ==13replace obs_charlson=X if plancode==6 & charlson ==23replace obs_charlson=X if plancode==6 & charlson ==49replace obs_charlson=X if plancode==8 & charlson ==0replace obs_charlson=X if plancode==8 & charlson ==13replace obs_charlson=X if plancode==8 & charlson ==23replace obs_charlson=X if plancode==8 & charlson ==49qui do drugs_createvars capture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obs_charlsonegen totalusage=sum(usage), by(plancode timetrend charlson)label var totalusage "Total usage"sort plancode year month charlsoncapture drop _mergemerge plancode year month charlson using copaybycharlsonrename copaybycharlson         meancopayrename modalcopaybycharlson    meancopay02rename modalcopay02retailbycharlson meancopay02rettab _mergedrop if plancode==.gen paypp=imputed_totalpay/obs_charlsonegen totpaypp=sum(paypp), by(plancode timetrend charlson)gen  inspp=imputed_inspay/obs_charlsonegen totinspp=sum(inspp), by(plancode timetrend charlson)* Pre-period means* Across all drug types and by charlson : Row1=Copay per drug, Row2=Total Payments per Drug, Row3= Total use per person, Row4=Total Payments per person, Row5=Total Insurer Payments per persontable hmo            charlson  if basic==0  & $preperiodmeans [aw=obs_charlson], c(mean meancopay mean avgtot mean totalusage mean totpaypp mean totinspp)  format(%3.2f) row* Use by spending tercile and charlson table hmo importance charlson  if basic==0 &  $preperiodmeans [aw=obs_charlson], c(mean usage) format(%3.2f) rowforeach basic   in 0 {foreach sample in pooled 2001 2002 {foreach charlson in 0 13 49 {* Estimate models for total usage: data is that the level of terciles and importance variable (1,2,3) so only use the first obs in each period for totalusagequi xtgls meancopay plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & charlson==`charlson' & importance==1             ${timesampleomit`sample'} [w=obs_charlson], $optionsestimates store copay`charlson'qui xtgls totalusage plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & charlson==`charlson' & importance==1             ${timesampleomit`sample'} [w= obs_charlson], $optionsestimates store total`charlson'qui xtgls totpaypp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & charlson==`charlson' & importance==1             ${timesampleomit`sample'} [w= obs_charlson], $optionsestimates store totpaypp`charlson'qui xtgls totinspp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & charlson==`charlson' & importance==1             ${timesampleomit`sample'} [w= obs_charlson], $optionsestimates store totinspp`charlson'forvalues importance = 1/3 {qui xtgls      usage plancodeD1-plancodeD8 ${treat`sample'}   timetrendD* if basic==`basic' & charlson==`charlson' & importance==`importance'  ${timesampleomit`sample'} [w= obs_charlson], $optionsestimates store DD`charlson'`importance'* close importance loop below}* close tercile loop below}di "DD Regs by Charlson score for Basic Plans=`basic'"di "(Col2=Copay, Col2=Total Drug paymnts, col3=Insurer Drug Payments, col4=use across all drug types; col5=acute drugs, col6=chronic drugs, col7=lifestyle drugs)"estimates table  copay0 totpaypp0  totinspp0   total0   DD01   DD02   DD03,   keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Charlson score==0") stats(N) stfmt(%3.0f)estimates table  copay13 totpaypp13  totinspp13   total13   DD131   DD132   DD133,   keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Charlson score==1-3") stats(N) stfmt(%3.0f)estimates table  copay49 totpaypp49 totinspp49 total49 DD491 DD492 DD493, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Charlson score==4+") stats(N) stfmt(%3.0f)* close sample loop below}* close basic/supp loop below}* Cut by AGE-GROUPuse erplanbyagegroup, cleargen obs_age=.replace obs_age=X if plancode==2 & agegroup==18replace obs_age=X if plancode==2 & agegroup==1929replace obs_age=X if plancode==2 & agegroup==3039replace obs_age=X if plancode==2 & agegroup==4049replace obs_age=X if plancode==2 & agegroup==5064replace obs_age=X if plancode==2 & agegroup==6574replace obs_age=X if plancode==2 & agegroup==7584replace obs_age=X if plancode==2 & agegroup==8599replace obs_age=X if plancode==4 & agegroup==18replace obs_age=X if plancode==4 & agegroup==1929replace obs_age=X if plancode==4 & agegroup==3039replace obs_age=X if plancode==4 & agegroup==4049replace obs_age=X if plancode==4 & agegroup==5064replace obs_age=X if plancode==4 & agegroup==6574replace obs_age=X if plancode==4 & agegroup==7584replace obs_age=X if plancode==4 & agegroup==8599replace obs_age=X if plancode==6 & agegroup==18replace obs_age=X if plancode==6 & agegroup==1929replace obs_age=X if plancode==6 & agegroup==3039replace obs_age=X if plancode==6 & agegroup==4049replace obs_age=X if plancode==6 & agegroup==5064replace obs_age=X if plancode==6 & agegroup==6574replace obs_age=X if plancode==6 & agegroup==7584replace obs_age=X if plancode==6 & agegroup==8599replace obs_age=X if plancode==8 & agegroup==18replace obs_age=X if plancode==8 & agegroup==1929replace obs_age=X if plancode==8 & agegroup==3039replace obs_age=X if plancode==8 & agegroup==4049replace obs_age=X if plancode==8 & agegroup==5064replace obs_age=X if plancode==8 & agegroup==6574replace obs_age=X if plancode==8 & agegroup==7584replace obs_age=X if plancode==8 & agegroup==8599qui do drugs_createvarscapture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obs_ageegen totalusage=sum(usage), by(plancode timetrend agegroup)sort plancode year month agegroupcapture drop _mergemerge plancode year month agegroup using copaybyagegrouprename copaybyagegroup         meancopayrename modalcopaybyagegroup    meancopay02rename modalcopay02retailbyagegroup meancopay02rettab _mergedrop if plancode==.label var totalusage "Total usage"gen paypp=imputed_totalpay/obs_ageegen totpaypp=sum(paypp), by(plancode timetrend agegroup)gen  inspp=imputed_inspay/obs_ageegen totinspp=sum(inspp), by(plancode timetrend agegroup)* Pre-period means* Across all drug types and by age : Row1=Copay per drug, Row2=Total Payments per Drug, Row3= Total use per person, Row4=Total Payments per person, Row5=Total Insurer Payments per persontable hmo            agegroup  if basic==0  &  (agegroup== 6574| agegroup==7584| agegroup==8599) & $preperiodmeans [aw=obs_age], c(mean meancopay mean avgtot mean totalusage mean totpaypp mean totinspp)  format(%3.2f) row* Use by spending tercile and agetable hmo importance agegroup  if basic==0 &   (agegroup== 6574| agegroup==7584| agegroup==8599) & $preperiodmeans [aw=obs_age], c(mean usage) format(%3.2f) rowforeach basic in 0 {estimates drop _allforeach sample in pooled 2001 2002 {foreach agegroup  in 6574 7584 8599 {* Estimate models for total usage: data is that the level of terciles and importance variable (1,2,3) so only use the first obs in each period for totalusagequi xtgls meancopay plancodeD1-plancodeD8     ${treat`sample'}  timetrendD*  if basic==`basic' & agegroup==`agegroup' & importance==1             ${timesampleomit`sample'} [w= obs_age], $optionsestimates store copay`agegroup'qui xtgls totalusage plancodeD1-plancodeD8 ${treat`sample'} timetrendD* if basic==`basic' & agegroup==`agegroup' & importance==1            ${timesampleomit`sample'} [w= obs_age], $options estimates store total`agegroup'qui xtgls totpaypp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & agegroup==`agegroup' & importance==1             ${timesampleomit`sample'} [w= obs_age], $optionsestimates store totpaypp`agegroup'qui xtgls totinspp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & agegroup==`agegroup' & importance==1             ${timesampleomit`sample'} [w= obs_age], $optionsestimates store totinspp`agegroup'forvalues importance = 1/3 {qui xtgls      usage plancodeD1-plancodeD8 ${treat`sample'} timetrendD* if basic==`basic' & agegroup==`agegroup' & importance==`importance' ${timesampleomit`sample'} [w= obs_age], $options estimates store DD`agegroup'`importance'* close importance loop}* close agespecific loop}di "DD Regs by Tier for Basic Plans=`basic'"di "(Col1=Total Drug paymnts, col2=Insurer Drug Payments, col3=use across all drug types; col4=acute drugs, col5=chronic drugs, col6=lifestyle drugs)"estimates table  copay6574 totpaypp6574   totinspp6574  total6574 DD65741 DD65742 DD65743, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Age 65-74 years") stats(N) stfmt(%3.0f)estimates table  copay7584 totpaypp7584   totinspp7584  total7584 DD75841 DD75842 DD75843, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Age 75-84 years") stats(N) stfmt(%3.0f)estimates table  copay8599 totpaypp8599   totinspp8599  total8599 DD85991 DD85992 DD85993, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Age 85-99 years") stats(N) stfmt(%3.0f)* close sample loop}* close basic loop}* Cut by formulary tier/* copays for PPOs went from 5/10 to 5/15/30 (retail), and from 5 to 10/25/45 (mailorder)     Generics 	Formulary 	Brand2000 5			10			102001 5			15			30Mail order    Generics 	Formulary 	Brand2000 5			5			52001 10			25			45*/ 	use erplanbydrugtier, clearqui do drugs_createvarscapture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obsgen paypp=imputed_totalpay/obsgen  inspp=imputed_inspay/obssort plancode year month drugtiercapture drop _mergemerge plancode year month drugtier using copaybydrugtierrename copaybydrugtier         meancopayrename modalcopaybydrugtier    meancopay02rename modalcopay02retailbydrugtier meancopay02rettab _mergedrop if plancode==.drop if plancode==.estimates drop _allforvalues basic    = 0/1 {di "Pre-policy means by formulary tier"di "Row1=copay per drug, Row2=total payments per drug, Row3=usage per person, Row4=Total Payments per person, Row5=Insurer Payments per person"table  drugtier  if basic==`basic' & $preperiodmeans [aw=obs], c(mean meancopay mean avgtotpaypd mean usage mean paypp mean inspp) format(%3.2f)  by(hmo)foreach sample in pooled 2001 2002 {forvalues drugtier = 1/3 {qui xtgls      meancopay plancodeD1-plancodeD8 ${treat`sample'}  timetrendD* if basic==`basic'  & drugtier==`drugtier' ${timesampleomit`sample'} [w=obs], $options estimates store copay`drugtier'qui xtgls      usage plancodeD1-plancodeD8 ${treat`sample'}  timetrendD* if basic==`basic'  & drugtier==`drugtier' ${timesampleomit`sample'} [w=obs], $options estimates store DD`drugtier'* close drug tier loop}di "  "di "  "di "DD Regs by Tier for Basic Plans=`basic'"di "First 3 cols are copay changes (1=Generics, 2=Formulary, 3=Non-Formulary Retail). Next 3 cols are utilization changes"estimates table  copay1 copay2 copay3 DD1   DD2   DD3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f)   title("Policy Change=`sample': Copay Change and Drug Use by Formulary Tier")    stats(N) stfmt(%3.0f)* close 2001/2002 loop}* close basic/supp loop below}* Repeat Formulary regs using alternative way of defining control group-- pooled specification is not possible. * First do using PPO drug tieruse erplanbyppodrugtier, clearqui do drugs_createvarscapture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obsgen paypp=imputed_totalpay/obsgen inspp=imputed_inspay/obssort plancode year month ppodrugtiercapture drop _mergemerge plancode year month ppodrugtier using copaybyppodrugtierrename copaybyppodrugtier         meancopaytab _mergedrop if plancode==.estimates drop _alldi "Pre-policy means by formulary tier (control group in HMOs is defined using drugs in each formulary tier of PPO plans"di "Row1=copay per drug, Row2=total payments per drug, Row3=usage per person, Row4=Total Payments per person, Row5=Insurer Payments per person"forvalues basic    = 0/1 {table   ppodrugtier if ppo & basic==`basic' & $preperiodmeans [aw=obs], c(mean meancopay mean avgtotpaypd mean usage mean paypp mean inspp) format(%3.2f) forvalues ppodrugtier = 1/3 {qui xtgls      meancopay plancodeD1-plancodeD8 ${treat2001}  timetrendD* if basic==`basic'  & ppodrugtier==`ppodrugtier' ${timesampleomit2001} [w=obs], $options estimates store copay`ppodrugtier'qui xtgls      usage plancodeD1-plancodeD8 ${treat2001}  timetrendD* if basic==`basic'  & ppodrugtier==`ppodrugtier' ${timesampleomit2001} [w=obs], $options estimates store DD`ppodrugtier'* close drug tier loop}di "  "di "  "di "Control group defined by HMO usage of drugs in PPO formulary tier: DD Regs by Tier for Basic Plans=`basic'"di "First 3 cols are copay changes (1=Generics, 2=Formulary, 3=Non-Formulary Retail). Next 3 cols are utilization changes"estimates table  copay1 copay2 copay3 DD1   DD2   DD3 , keep (${treat2001}) b(%4.3f) se(%4.3f)   title("Policy Change=2001: Copay Change and Drug Use by Formulary Tier")    stats(N) stfmt(%3.0f)* close basic/supp loop below}* Now do with HMO drug tieruse erplanbyhmodrugtier, clearqui do drugs_createvarscapture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obsgen paypp=imputed_totalpay/obsgen inspp=imputed_inspay/obssort plancode year month hmodrugtiercapture drop _mergemerge plancode year month hmodrugtier using copaybyhmodrugtierrename copaybyhmodrugtier         meancopaytab _mergedrop if plancode==.estimates drop _all* Pre-policy means by formulary tier (control group in PPOs is defined using drugs in each formulary tier of HMO plansdi "Row1=copay per drug, Row2=total payments per drug, Row3=usage per person, Row4=Total Payments per person, Row5=Insurer Payments per person"forvalues basic    = 0/1 {di "Basic=`basic'"table   hmodrugtier if hmo & basic==`basic' & $preperiodmeans [aw=obs], c(mean meancopay mean avgtotpaypd mean usage mean paypp mean inspp) format(%3.2f) foreach sample in 2002 {* in loop below there are only two tiersforvalues hmodrugtier = 1/2 {qui xtgls      meancopay plancodeD1-plancodeD8 ${treat`sample'}  timetrendD* if basic==`basic'  & hmodrugtier==`hmodrugtier' ${timesampleomit`sample'} [w=obs], $options estimates store copay`hmodrugtier'qui xtgls      usage plancodeD1-plancodeD8 ${treat`sample'}  timetrendD* if basic==`basic'  & hmodrugtier==`hmodrugtier' ${timesampleomit`sample'} [w=obs], $options estimates store DD`hmodrugtier'* close drug tier loop}di "  "di "  "di "Control group defined by PPO usage of drugs in HMO formulary tier: DD Regs by Tier for Basic Plans=`basic'"di "First 2 cols are copay changes (1=Generics, 2=Formulary). Next 2 cols are utilization changes"estimates table  copay1 copay2  DD1   DD2   , keep (${treat`sample'}) b(%4.3f) se(%4.3f)   title("Policy Change=`sample': Copay Change and Drug Use by Formulary Tier")    stats(N) stfmt(%3.0f)* close 2001/2002 loop}* close basic/supp loop below}* look at use of drugs by those w/ chronic diseaseforeach basic  in 0 {foreach sample in pooled 2001 2002 {estimates drop _allforeach classification in   nochronic somechronic  depression hypertension hyperchol asthma gastritis  diabetes arthritis {use erplanby`classification' , clearqui drop if plancode==.qui do drugs_createvarsqui gen usage=onequi replace usage=(usage)/obs_`classification'qui gen usage_specific=specificdrug/obs_`classification'gen totpaypp=imputed_totalpay/obs_`classification'gen totinspp=imputed_inspay/obs_`classification'capture drop _mergequi merge plancode year month  using erplanby`classification'rename copayby`classification'         meancopayrename modalcopayby`classification'    meancopay02rename modalcopay02retailby`classification' meancopay02retqui tab _mergedi "Pre-policy means for `classification' and Basic=`basic'. * Col1 copay per drug, Col2= total payment per drug, third is insurer payment, fourth is avg payment per drug" table  hmo if basic==`basic' &  $preperiodmeans [aw=obs_`classification'], c(mean meancopay mean avgtotpaypd)  format(%3.2f) row * Col1 is total use per person, Col2 is condition specific use per person, Col3 is total paymnt per person, Col4 is total insurer paymnt per persontable  hmo if basic==`basic' &  $preperiodmeans [aw=obs_`classification'], c(mean usage  mean usage_specific mean totpaypp mean totinspp) format(%3.2f) row di "_____________________________________"qui xtgls             meancopay    plancodeD1-plancodeD8 ${treat`sample'}  timetrendD* if basic==`basic' ${timesampleomit`sample'} [w=obs_`classification'], $options estimates store `classification'copayqui xtgls             totpaypp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD* if basic==`basic' ${timesampleomit`sample'} [w=obs_`classification'], $options estimates store `classification'totpayppqui xtgls             totinspp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD* if basic==`basic' ${timesampleomit`sample'} [w=obs_`classification'], $options estimates store `classification'totinsppqui xtgls                usage plancodeD1-plancodeD8 ${treat`sample'}  timetrendD* if basic==`basic' ${timesampleomit`sample'} [w=obs_`classification'], $options estimates store `classification'allqui xtgls      usage_specific  plancodeD1-plancodeD8 ${treat`sample'}  timetrendD* if basic==`basic' ${timesampleomit`sample'} [w=obs_`classification'], $options estimates store `classification'spec* close classification of chronic condition below}di " "di " "di "DD Regs by Chronic Disease condition, for Basic Plans=`basic', and policy-change=`sample'"estimates table   nochroniccopay  somechroniccopay    depressioncopay  hypertensioncopay   hypercholcopay   asthmacopay    gastritiscopay     diabetescopay  arthritiscopay , keep (${treat`sample'})  b(%4.3f) se(%4.3f)   title("Policy Change=`sample': Copays for patients with chronic disease")        stats(N) stfmt(%3.0f)estimates table   nochronictotpaypp  somechronictotpaypp    depressiontotpaypp    hypertensiontotpaypp    hypercholtotpaypp   asthmatotpaypp    gastritistotpaypp     diabetestotpaypp  arthritistotpaypp , keep (${treat`sample'})  b(%4.3f) se(%4.3f)   title("Policy Change=`sample': Total Drug Payments for patients with chronic disease")        stats(N) stfmt(%3.0f)estimates table   nochronictotinspp  somechronictotinspp    depressiontotinspp    hypertensiontotinspp    hypercholtotinspp   asthmatotinspp    gastritistotinspp     diabetestotinspp  arthritistotinspp , keep (${treat`sample'})  b(%4.3f) se(%4.3f)   title("Policy Change=`sample': Insurer Drug Payments for patients with chronic disease")        stats(N) stfmt(%3.0f)estimates table   nochronicall   somechronicall    depressionall    hypertensionall    hypercholall    asthmaall    gastritisall     diabetesall   arthritisall , keep (${treat`sample'})  b(%4.3f) se(%4.3f)   title("Policy Change=`sample': Drug use (all drugs) by patients with chronic disease")        stats(N) stfmt(%3.0f)estimates table   nochronicspec  somechronicspec  depressionspec   hypertensionspec   hypercholspec   asthmaspec   gastritisspec    diabetesspec  arthritisspec, keep (${treat`sample'})  b(%4.3f) se(%4.3f)   title("Policy Change=`sample': Drug use (disease specific) by patients with chronic disease") stats(N) stfmt(%3.0f)* close sample loop}* close basic/supp loop below}* Regs for revisionclearuse erdrugsforswitchinggen datawithage=0gen databysomechronicage=0gen databysomechronicage2=0gen databynochronicage=0gen databynochronicage2=0qui do drugs_createvarsdrop if timetrend>45capture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obsfor var rx_none rx_both rx_form rx_generic  : replace X=X/obsdrop if (plancode==3|plancode==4) & (timetrend<=12)* Pre-period means* Across all drug types: Row1=Copay per drug, Row2=Total Payments per Drug, Row3= Total use per person, Row4=Total Payments per person, Row5=Total Insurer Payments per persontable hmo    if basic==0  & $preperiodmeans [aw=obs], c(mean usage mean rx_none mean rx_both mean rx_form  mean rx_generic)  format(%3.2f) rowforeach basic   in 0 {foreach sample in 2001 2002 {foreach outcome in usage  rx_none rx_both rx_form rx_generic {qui reg `outcome' plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic'    ${timesampleomit`sample'} [w= obs], restimates store `outcome'}di "DD Regs for `outcome' for Basic Plans=`basic'"di "(Col1= Any use, Col2=No Rx, Col3=Both Form and Generics, Col4 Only Formulary Rx, Col 5=Only Generic)"di "look at ppo results for 2001 change, and hmo results for 2002 change"estimates table  usage  rx_none rx_both rx_form rx_generic ,   keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample'") stats(N) stfmt(%3.0f)* close sample loop below}* close basic/supp loop below}for var hmorx_none hmorx_both hmorx_form hmorx_generic  : replace X=X/obs* Pre-period means using alt defn of drug tiers* Across all drug types: Row1=Copay per drug, Row2=Total Payments per Drug, Row3= Total use per person, Row4=Total Payments per person, Row5=Total Insurer Payments per persontable hmo    if basic==0  & $preperiodmeans [aw=obs], c(mean usage mean hmorx_none mean hmorx_both mean hmorx_form  mean hmorx_generic)  format(%3.2f) rowforeach basic   in 0 {foreach sample in 2001 2002 {foreach outcome in usage  hmorx_none hmorx_both hmorx_form hmorx_generic {qui reg `outcome' plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic'    ${timesampleomit`sample'} [w= obs], restimates store `outcome'}di "DD Regs for `outcome' for Basic Plans=`basic'"di "(Col1= Any use, Col2=No Rx, Col3=Both Form and Generics, Col4 Only Formulary Rx, Col 5=Only Generic)"di "look at ppo results for 2001 change, and hmo results for 2002 change"estimates table  usage  hmorx_none hmorx_both hmorx_form hmorx_generic ,   keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample'") stats(N) stfmt(%3.0f)* close sample loop below}* close basic/supp loop below}* Cut by DONUT2000 * Donut2000 indicates whether the person had drug spending below the hole (1), in the hole (2), or above the hole (3) in 2000. use erplanbydonut2000, clear* code that create obs-donut cannot be moved to drugs_createvars as "donut" var isn't in every erplanbyXXX dataset.gen obs_donut2000=.replace obs_donut2000=X if donut2000==1 & plancode==2replace obs_donut2000=X if donut2000==2 & plancode==2replace obs_donut2000=X if donut2000==3 & plancode==2replace obs_donut2000=X if donut2000==1 & plancode==6replace obs_donut2000=X if donut2000==2 & plancode==6replace obs_donut2000=X if donut2000==3 & plancode==6replace obs_donut2000=X if donut2000==1 & plancode==8replace obs_donut2000=X if donut2000==2 & plancode==8replace obs_donut2000=X if donut2000==3 & plancode==8qui do drugs_createvars capture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obs_donut2000egen totalusage=sum(usage), by(plancode timetrend donut2000)label var totalusage "Total usage"gen  paypp=imputed_totalpay/obs_donut2000egen totpaypp=sum(paypp), by(plancode timetrend donut2000)gen  inspp=imputed_inspay/obs_donut2000egen totinspp=sum(inspp), by(plancode timetrend donut2000)sort plancode year month donut2000capture drop _mergemerge plancode year month donut2000 using copaybydonut2000rename copaybydonut2000           meancopayrename modalcopaybydonut2000    meancopay02rename modalcopay02retailbydonut2000 meancopay02rettab _mergedrop if plancode==.* We drop HMO=4 from this analysis as we don't have 2000 data for this HMOdrop if plancode==4* Pre-period means* Across all drug types and by location in donuthole in 2000 : Row1=Copay per drug, Row2=Total Payments per Drug, Row3= Total use per person, Row4=Total Payments per person, Row5=Total Insurer Payments per persontable hmo            donut2000  if basic==0  & $preperiodmeans [aw=obs_donut2000], c(mean meancopay mean avgtot mean totalusage mean totpaypp mean totinspp)  format(%3.2f) row colforeach basic   in 0 {foreach sample in pooled 2001 2002 {forvalues donut2000 = 1/3 {* Estimate models for total usagequi xtgls meancopay plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & donut2000 ==`donut2000'   ${timesampleomit`sample'} [w=obs], $optionsestimates store copay`donut2000'qui xtgls totalusage plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & donut2000 ==`donut2000'  ${timesampleomit`sample'} [w=obs], $optionsestimates store total`donut2000'qui xtgls totpaypp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & donut2000 ==`donut2000'    ${timesampleomit`sample'} [w=obs], $optionsestimates store totpaypp`donut2000'qui xtgls totinspp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & donut2000 ==`donut2000'    ${timesampleomit`sample'} [w=obs], $optionsestimates store totinspp`donut2000'* close donut2000 loop below}di "DD Regs by Below/Within/Above Donut Hole in 2000 for Basic Plans=`basic'"di "(col1=Copay Change, col2=Total paymnts, col3=Insurer Drug Payments, col4=use across all drug types)"estimates table copay1 totpaypp1 totinspp1 total1, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Below  donut in 2000") stats(N) stfmt(%3.0f)estimates table copay2 totpaypp2 totinspp2 total2, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Inside donut in 2000") stats(N) stfmt(%3.0f)estimates table copay3 totpaypp3 totinspp3 total3, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Above  donut in 2000") stats(N) stfmt(%3.0f)* close sample loop below}* close basic/supp loop below}* Cut by EverinDonut * Everindonut (0/1) indicates whether the person ever fell into the donutuse erplanbyeverindonut, clear* code that create obs-donut cannot be moved to drugs_createvars as "donut" var isn't in every erplanbyXXX dataset.gen obs_everindonut=.replace obs_everindonut=X if everindonut ==0 & plancode==2replace obs_everindonut=X if everindonut ==1 & plancode==2replace obs_everindonut=X if everindonut ==0 & plancode==6replace obs_everindonut=X if everindonut ==1 & plancode==6replace obs_everindonut=X if everindonut ==0 & plancode==8replace obs_everindonut=X if everindonut ==1 & plancode==8qui do drugs_createvars capture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obs_everindonutegen totalusage=sum(usage), by(plancode timetrend everindonut)label var totalusage "Total usage"gen  paypp=imputed_totalpay/obs_everindonutegen totpaypp=sum(paypp), by(plancode timetrend everindonut)gen  inspp=imputed_inspay/obs_everindonutegen totinspp=sum(inspp), by(plancode timetrend everindonut)sort plancode year month everindonutcapture drop _mergemerge plancode year month everindonut using copaybyeverindonutrename copaybyeverindonut           meancopayrename modalcopaybyeverindonut    meancopay02rename modalcopay02retailbyeverindonut meancopay02rettab _mergedrop if plancode==.* We drop HMO=4 from this analysis as we don't have 2000 data for this HMOdrop if plancode==4* Pre-period means* Across all drug types and by ever in donut (in any of the 4 yrs) : Row1=Copay per drug, Row2=Total Payments per Drug, Row3= Total use per person, Row4=Total Payments per person, Row5=Total Insurer Payments per persontable hmo            everindonut  if basic==0  & $preperiodmeans [aw=obs_everindonut], c(mean meancopay mean avgtot mean totalusage mean totpaypp mean totinspp)  format(%3.2f) row colforeach basic   in 0 {foreach sample in pooled 2001 2002 {forvalues everindonut = 0/1 {* Estimate models for total usagequi xtgls meancopay plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & everindonut ==`everindonut'   ${timesampleomit`sample'} [w=obs], $optionsestimates store copay`everindonut'qui xtgls totalusage plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & everindonut ==`everindonut'  ${timesampleomit`sample'} [w=obs], $optionsestimates store total`everindonut'qui xtgls totpaypp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & everindonut ==`everindonut'    ${timesampleomit`sample'} [w=obs], $optionsestimates store totpaypp`everindonut'qui xtgls totinspp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & everindonut ==`everindonut'    ${timesampleomit`sample'} [w=obs], $optionsestimates store totinspp`everindonut'* close everindonut loop below}di "DD Regs by whether one was ever inside Donut Hole in 2000-03 for Basic Plans=`basic'"di "(col1=Copay Change, col2=Total paymnts, col3=Insurer Drug Payments, col4=use across all drug types)"estimates table copay0 totpaypp0 totinspp0 total0, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample':         Never in donut in 2000-03") stats(N) stfmt(%3.0f)estimates table copay1 totpaypp1 totinspp1 total1, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': At least once in donut in 2000-03") stats(N) stfmt(%3.0f)* close sample loop below}* close basic/supp loop below}* Cut by countdonut * countdonut indicates the number of times a person fell into the donu holeuse erplanbycountdonut, clear* code that create obs-donut cannot be moved to drugs_createvars as "donut" var isn't in every erplanbyXXX dataset.*/gen obs_countdonut=.replace obs_countdonut=X if countdonut ==0 & plancode==2replace obs_countdonut=X if countdonut ==1 & plancode==2replace obs_countdonut=X if countdonut ==2 & plancode==2replace obs_countdonut=X if countdonut ==3 & plancode==2replace obs_countdonut=X if countdonut ==4 & plancode==2replace obs_countdonut=X if countdonut ==0 & plancode==6replace obs_countdonut=X if countdonut ==1 & plancode==6replace obs_countdonut=X if countdonut ==2 & plancode==6replace obs_countdonut=X if countdonut ==3 & plancode==6replace obs_countdonut=X if countdonut ==4 & plancode==6replace obs_countdonut=X if countdonut ==0 & plancode==8replace obs_countdonut=X if countdonut ==1 & plancode==8replace obs_countdonut=X if countdonut ==2 & plancode==8replace obs_countdonut=X if countdonut ==3 & plancode==8replace obs_countdonut=X if countdonut ==4 & plancode==8qui do drugs_createvars capture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obs_countdonutegen totalusage=sum(usage), by(plancode timetrend countdonut)label var totalusage "Total usage"gen  paypp=imputed_totalpay/obs_countdonutegen totpaypp=sum(paypp), by(plancode timetrend countdonut)gen  inspp=imputed_inspay/obs_countdonutegen totinspp=sum(inspp), by(plancode timetrend countdonut)sort plancode year month countdonutcapture drop _mergemerge plancode year month countdonut using copaybycountdonutrename copaybycountdonut          meancopayrename modalcopaybycountdonut    meancopay02rename modalcopay02retailbycountdonut meancopay02rettab _mergedrop if plancode==.* We drop HMO=4 from this analysis as we don't have 2000 data for this HMOdrop if plancode==4* Pre-period means* Across all drug types and by location in donuthole in 2000 : Row1=Copay per drug, Row2=Total Payments per Drug, Row3= Total use per person, Row4=Total Payments per person, Row5=Total Insurer Payments per persontable hmo            countdonut  if basic==0  & $preperiodmeans [aw=obs_countdonut], c(mean meancopay mean avgtot mean totalusage mean totpaypp mean totinspp)  format(%3.2f) row colforeach basic   in 0 {foreach sample in pooled 2001 2002 {forvalues countdonut = 0/4 {* Estimate models for total usagequi xtgls meancopay plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & countdonut ==`countdonut'   ${timesampleomit`sample'} [w=obs], $optionsestimates store copay`countdonut'qui xtgls totalusage plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & countdonut ==`countdonut'  ${timesampleomit`sample'} [w=obs], $optionsestimates store total`countdonut'qui xtgls totpaypp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & countdonut ==`countdonut'    ${timesampleomit`sample'} [w=obs], $optionsestimates store totpaypp`countdonut'qui xtgls totinspp plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & countdonut ==`countdonut'    ${timesampleomit`sample'} [w=obs], $optionsestimates store totinspp`countdonut'* close countdonut loop below}di "DD Regs by Below/Within/Above Donut Hole in 2000 for Basic Plans=`basic'"di "(col1=Copay Change, col2=Total paymnts, col3=Insurer Drug Payments, col4=use across all drug types)"estimates table copay0 totpaypp0 totinspp0 total0, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Never in donut") stats(N) stfmt(%3.0f)estimates table copay1 totpaypp1 totinspp1 total1, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Once in donut") stats(N) stfmt(%3.0f)estimates table copay2 totpaypp2 totinspp2 total2, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Twice in donut") stats(N) stfmt(%3.0f)estimates table copay3 totpaypp3 totinspp3 total3, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Thrice in donut") stats(N) stfmt(%3.0f)estimates table copay4 totpaypp4 totinspp4 total4, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Four+ times in donut") stats(N) stfmt(%3.0f)* close sample loop below}* close basic/supp loop below}log closeexitS ***************************clearset mem 1gset more offcapture log closelog using drugregs.log, replace* Read in drug x plan (in planbydrug.dta and planbyclass.dta) data and merge to "rank" data.* foreach classification in class drug {foreach classification in class  {use erplanby`classification', clear* Merge in rank of drug/class of drug in 2003sort basic `classification'merge basic `classification' using ercountof`classification'nametab _mergegen ppo=plancode>=5gen hmo=!ppogen obs=.replace obs=X if plancode==1replace obs=X if plancode==2replace obs=X if plancode==3replace obs=X if plancode==4replace obs=X if plancode==5replace obs=X if plancode==6replace obs=X if plancode==7replace obs=X if plancode==8egen timetrend=group (year month)egen planmonth=group(plan month)tab timetrend, gen(timetrendD)tab plancode,  gen(plancodeD)tab month,     gen(monthD)gen pmo=plancode*100+monthtab pmo, gen(planmonthD)gen post=(ppo==1 & timetrend>13) | (ppo==0 & timetrend>24)gen postppo=timetrend>13gen posthmo=timetrend>24gen treat=(plancode<5 & timetrend>24) | (plancode>=5 & timetrend>13)gen treathmo=treat*hmogen plancodeD1tt=plancodeD1*timetrendgen plancodeD2tt=plancodeD2*timetrendgen plancodeD3tt=plancodeD3*timetrendgen plancodeD4tt=plancodeD4*timetrendgen plancodeD5tt=plancodeD5*timetrendgen plancodeD6tt=plancodeD6*timetrendgen plancodeD7tt=plancodeD7*timetrendgen plancodeD8tt=plancodeD8*timetrend* foreach drugrank in   rank_count rank_persons { foreach drugrank in   rank_count {capture drop usage tmp  touse tousetotal totalusagegen usage=one* recode drugs with rank>10 to a rank of 11 and collapse data to create one obs for such datareplace `drugrank'=11 if `drugrank' >=11egen tmp=sum(one) , by(plancode year month `drugrank') egen totalusage=sum(one) , by(plancode year month) bysort plancode year month `drugrank': replace usage=tmp if one!=tmpbysort plancode year month `drugrank': gen touse=_n==1bysort plancode year month           : gen tousetotal=_n==1replace usage=(usage)/obsreplace totalusage=totalusage/obsglobal regmodel1 "reg"global regmodel2 "xtgls"global optionmodel1 "r cluster(plancode)"global optionmodel2 "i(plancode) t(timetrend) panels(het) corr(psar1)"* Note: doing only ", robust" is the same as doing "cluster (plantimetrend) in the micro dataforvalues basic   = 0/1   {di "Type of Plan (Basic/Supp): Basic==`basic'"* First check model specificationsforeach specification in model1 model2 {qui ${reg`specification'} totalusage plancodeD1-plancodeD8 treat              timetrendD*   				if basic==`basic' & tousetotal==1  [w=obs], ${option`specification'}estimates store DD1`specification'qui ${reg`specification'} totalusage plancodeD1-plancodeD8 treat treathmo     timetrendD*                     		if basic==`basic' & tousetotal==1  [w=obs], ${option`specification'}estimates store DD2`specification'qui ${reg`specification'} totalusage plancodeD1-plancodeD8 treat treathmo     timetrendD*                planmonthD*  	if basic==`basic' & tousetotal==1  [w=obs], ${option`specification'}estimates store DD3`specification'* qui ${reg`specification'} totalusage plancodeD1-plancodeD8 treat treathmo     timetrendD*  plancodeD*tt  		if basic==`basic' & tousetotal==1  [w=obs], ${option`specification'}* estimates store DD4`specification'* qui ${reg`specification'} totalusage plancodeD1-plancodeD8 treat treathmo     timetrendD*  plancodeD*tt  planmonthD*  if basic==`basic' & tousetotal==1  [w=obs], ${option`specification'}* estimates store DD5`specification'}di "First 3 regs cluster at plancode level, next 3 use XTGLS with i(plancode) t(timetrend) panels(het) corr(psar1)"estimates table  DD1model1 DD2model1 DD3model1  DD1model2 DD2model2 DD3model2, keep (treat treathmo) b(%5.4f) se(%5.4f) title("`label' regs by `classification', Sample=Full Sample") stats(N) stfmt(%3.0f)estimates drop _all}