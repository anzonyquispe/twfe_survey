* The program below estimates all the Rx regressions, including those in the working paper and those referenced in the AER footnotes. For the program do run successfully* you need to sure that (1) you've executed makedrugdata.do and retained all the resulting datasets (2) include the .do files that are disease specific (chronic.do, gastritic.do, * alzheimers.do, diabetes.do...) in the same directory as this program and (3) have the .do file drugs_createvars in the same directory.* execute makedrugdata.do<- this program takes in claims data at the person x claim data makes a number of datasets for the Rx analysisdo makedrugdata  *********************** CODE BELOW ESTIMATES REGS BY TYPE OF DRUG (IE: ACUTE/CHRONIC/LIFESTYLE) *****************************cap log closeset more offlog using drugsbyimportance.log, replace* Regressions below produce results by importance of drug.use erplanbyimportance, clearqui do drugs_createvarscapture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obsegen totalusage=sum(usage), by(plancode timetrend)gen  paypp=imputed_totalpay/obsegen totpaypp=sum(paypp), by(plancode timetrend )gen  inspp=imputed_inspay/obsegen totinspp=sum(inspp), by(plancode timetrend )sort plancode year monthmerge plancode year month using copayrename copay           meancopayrename modalcopay02    meancopay02rename modalcopay02ret meancopay02rettab _mergedrop if plancode==.* merge in drug specific copaysdrop _mergesort plancode year month importancemerge plancode year month importance using copaybyimportancerename copaybyimp               meancopaybyimprename modalcopaybyimp          meancopay02byimprename modalcopay02retailbyimp meancopay02retbyimptab _mergedrop if plancode==.* Preperiod means (2000 (through October) for PPOs, and 2001 (through September) for HMOs)* Across all drug types: Col 1 is avg. copay per drug, Col2 is avg. payment per drugtable hmo              if basic==0  & $preperiodmeans [aw=obs], c(mean meancopay  mean totavgtotpaypd) format(%3.2f) row* Across all drug types: Col 1 is total use per person, Col2 is total payment per person, Col 3 is total insurer paymnt per persontable hmo              if basic==0  & $preperiodmeans [aw=obs], c(mean totalusage mean totpaypp mean totinspp) format(%3.2f) row* By Drug Type:  Col 1 is avg. copay per drug, Col2 is avg. payment per drugtable hmo  importance  if basic==0  & $preperiodmeans [aw=obs], c(mean meancopaybyimp mean avgtotpaypd) format(%3.2f) row* By Drug Type:  Col 1 is total use per person, Col2 is total payment per person, Col 3 is total insurer paymnt per persontable hmo  importance  if basic==0  & $preperiodmeans [aw=obs], c(mean usage mean paypp mean inspp) format(%3.2f) row  * Run regressions by importance of drug but don't add dynamics, and don't separate ppo/hmo policy changesestimates drop _allforvalues basic   = 0/1   {* Estimate models for COPAY: data is that the level of plancode and importance (1,2,3) so only use the first obs in each period for totalusagequi xtgls meancopay02 plancodeD1-plancodeD8 treat              timetrendD*   			  		if basic==`basic' & importance==1  [w=obs], $optionsestimates store DD1meancopaybasic`basic'qui xtgls meancopay02 plancodeD1-plancodeD8 treat              timetrendD*             planmonthD*    if basic==`basic' & importance==1  [w=obs], $optionsestimates store DD2meancopaybasic`basic'qui xtgls meancopay02 plancodeD1-plancodeD8 treat treathmo     timetrendD*             planmonthD*    if basic==`basic' & importance==1  [w=obs], $optionsestimates store DD3meancopaybasic`basic'di "Regs for Copays (including dynamic-substitution-effects) "di "First reg force HMO and PPO effects to be the same, next include plan-specific month dummmies, last adds treat*hmo"estimates table  DD1meancopaybasic`basic' DD2meancopaybasic`basic' DD3meancopaybasic`basic', keep (treat treathmo) b(%4.1f) se(%4.1f) title("Copay Regressions, Basic= `basic'") stats(N) stfmt(%3.0f)table basic treat    if importance==1, c(mean meancopay mean meancopay02 mean meancopay02ret) format(%4.2f)}* Table for dynamic vs. static copay changestable hmo post [aw=obs] if basic==0 & importance==1, c(mean meancopay mean meancopaypost)* THESE REGS ESTIMATE SEPARATE MODELS BY 2001/2002 POLICY CHANGE: dynamic models here are monthly dynamics-- later we switch to quarterly dynamics.forvalues basic   = 0/1    {di "Type of Plan (Basic/Supp): Basic==`basic'"		* Separate analysis for 2001 and 2002 policy changes.	foreach sample in "2001" "2002" {	* Do regs for COPAYS: data is at plancode x timetred level, so only use first obs of totalusage in each period.		qui xtgls meancopay plancodeD1-plancodeD8 ${dynamics`sample'}   timetrendD*   if basic==`basic' & importance==1 &  ${timesample`sample'}  [w=obs], $options		estimates store DDXTGLSmeancopay				qui xtgls meancopay plancodeD1-plancodeD8 ${dynamicsQUAT`sample'}   timetrendD*   if basic==`basic' & importance==1 &  ${timesample`sample'}  [w=obs], $options		estimates store DDXTGLSQUATmeancopay		di "Regs for Copays"		di "First reg is simple DD, second is with monthly level dynamics, third is with quarterly dynamics"		estimates table  DDXTGLSsimplemeancopay   DDXTGLSmeancopay  DDXTGLSQUATmeancopay  , keep (${simple`sample'} ${dynamics`sample'} ${dynamicsQUAT`sample'}) b(%4.3f) se(%4.3f) title("Basic=`basic', Policy Change=`sample'") stats(N) stfmt(%3.0f) label			* Do regs for total charges and usage: data is at plancode x timetred level, so only use first obs of totalusage in each period.		qui xtgls totinspp plancodeD1-plancodeD8 ${simple`sample'}     timetrendD*   if basic==`basic' & importance==1 &  ${timesample`sample'}  [w=obs], $options		estimates store DDXTGLSsimpletotinspp				qui xtgls totalusage plancodeD1-plancodeD8 ${simple`sample'}     timetrendD*   if basic==`basic' & importance==1 &  ${timesample`sample'}  [w=obs], $options		estimates store DDXTGLSsimpletotalusage				qui xtgls totalusage plancodeD1-plancodeD8 ${dynamics`sample'}   timetrendD*   if basic==`basic' & importance==1 &  ${timesample`sample'} [w=obs], $options		estimates store DDXTGLStotalusage					qui xtgls totalusage plancodeD1-plancodeD8 ${dynamicsQUAT`sample'}   timetrendD*   if basic==`basic' & importance==1 &  ${timesample`sample'}  [w=obs], $options		estimates store DDXTGLSQUATtotalusage		di "Regs for total usage"		di "First reg is simple DD, second is with monthly level dynamics, third is with quarterly dynamics"		estimates table  DDXTGLSsimpletotalusage   DDXTGLStotalusage   DDXTGLSQUATtotalusage  , keep (${simple`sample'} ${dynamics`sample'} ${dynamicsQUAT`sample'}) b(%4.3f) se(%4.3f) title("Basic=`basic', Policy Change=`sample'") stats(N) stfmt(%3.0f) label			* Do regs by type of drug			forvalues importance = 1/3 {		qui xtgls charge plancodeD1-plancodeD8 ${dynamics`sample'}   timetrendD*   if basic==`basic' & importance==`importance' &  ${timesample`sample'} [w=obs], $options		estimates store DDXTGLScharge`importance'				qui xtgls usage plancodeD1-plancodeD8 ${dynamics`sample'}   timetrendD*   if basic==`basic' & importance==`importance' &  ${timesample`sample'} [w=obs], $options		estimates store DDXTGLS`importance'				qui xtgls usage plancodeD1-plancodeD8 ${dynamicsQUAT`sample'}   timetrendD*   if basic==`basic' & importance==`importance' &  ${timesample`sample'}   [w=obs], $options		estimates store DDXTGLSQUAT`importance'					* close drug type (importance) loop below}*	di "Regs are reported in groups of 3 (one for each type of drug)"*	di "E.g.: Models DDXTGLS1 DDXTGLS2 DDXTGLS3 refer to drugs for acute conditions (DD*1), for chronic conditions (DD*2), and lifestyle (DD*3)"*	di "      Next 3 models use OLS instead of XTGLS"*	estimates table  DDXTGLSsimple1 DDXTGLSsimple2 DDXTGLSsimple3 DDXTGLS1 DDXTGLS2 DDXTGLS3 DDXTGLSQUAT1 DDXTGLSQUAT2 DDXTGLSQUAT3, keep (${simple`sample'} ${dynamics`sample'} ${dynamicsQUAT`sample'}) b(%4.3f) se(%4.3f) title("Basic=`basic', Policy Change=`sample'") stats(N) stfmt(%3.0f) labeldi "First col is total use, next 3 are by type of drug (col2=acute care, col3=chronic, col4=lifestyle)"estimates table DDXTGLSsimplemeancopay DDXTGLSsimpletotalusage DDXTGLSsimple1 DDXTGLSsimple2 DDXTGLSsimple3, keep (${simple`sample'}) b(%4.3f) se(%4.3f) title("Basic=`basic', Policy Change=`sample'") stats(N) stfmt(%3.0f) labeldi Results for Charges"estimates table DDXTGLStotinspp DDXTGLScharge1 DDXTGLScharge2 DDXTGLScharge3, keep (${simple`sample'}) b(%4.3f) se(%4.3f) title("Basic=`basic', Policy Change=`sample'") stats(N) stfmt(%3.0f) label	* Make graphs using GLS estimates	foreach model in DDXTGLS1 DDXTGLS2  DDXTGLS3 {	capture drop beta*	estimates restore `model'		if `sample'==2001 {		for num 2/23: gen betaX=_b[treatppoX] 	}	else {		for num 5/25: gen betaX=_b[treathmoX] 	}	if `sample'==2001 {	gr bar  beta2-beta23, ascat title("Policy Change=2001, Basic=0") /*	*/ yvaropt(relabel (1 "t-12" 2 "t-11" 3 "t-10"  4 "t-9" 5 "t-8" 6 "t-7" 7 "t-6" 8 "t-5" 9 "t-4" 10 "t-3" 11 "t-2" 12 "t-1" 13 "Treat" 14 "t+1" 15 "t+2" 16 "t+3" 17 "t+4" 18 "t+5" 19 "t+6" 20 "t+7" 21 "t+8" 22 "t+9" 23 "t+10") /*	*/ label(angle(vertical)))  title("Policy Change=`sample', Basic=`basic'") ylabel(#5) saving(`model'`sample'`basic', replace)	}	else {	gr bar  beta5-beta25, ascat title("Policy Change=2001, Basic=0") /*	*/ yvaropt(relabel (1 "t-9" 2 "t-8" 3 "t-7" 4 "t-6" 5 "t-5" 6 "t-4" 7 "t-3" 8 "t-2" 9 "t-1" 10 "Treat" 11 "t+1" 12 "t+2" 13 "t+3" 14 "t+4" 15 "t+5" 16 "t+6" 17 "t+7" 18 "t+8" 19 "t+9" 20 "t+10" 21 "t>=11") /*	*/ label(angle(vertical)))  title("Policy Change=`sample', Basic=`basic'") ylabel(#5) saving(`model'`sample'`basic', replace)	}	* close  model loop below	drop beta*}	gr combine DDXTGLS1`sample'`basic'.gph DDXTGLS2`sample'`basic'.gph  DDXTGLS3`sample'`basic'.gph, saving(combined`sample'`basic', replace)	estimates drop _all		*close 2001/2002 loop below}* close basic/supp loop below}*** REGS BY IMPORTANCE (regs by essential / non-essential follow this Segment) ****************************************************use erplanbyimportance, clearqui do drugs_createvarscapture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obsegen totalusage=sum(usage), by(plancode timetrend)gen  paypp=imputed_totalpay/obsegen totpaypp=sum(paypp), by(plancode timetrend )gen  inspp=imputed_inspay/obsegen totinspp=sum(inspp), by(plancode timetrend )sort plancode year monthmerge plancode year month using copayrename copay           meancopayrename modalcopay02    meancopay02rename modalcopay02ret meancopay02rettab _mergedrop if plancode==.* merge in drug specific copaysdrop _mergesort plancode year month importancemerge plancode year month importance using copaybyimportancerename copaybyimp               meancopaybyimprename modalcopaybyimp          meancopay02byimprename modalcopay02retailbyimp meancopay02retbyimptab _mergedrop if plancode==.table  hmo year [aw=obs] if basic==0 & importance==1, c(mean meancopay mean totalusage)* Preperiod means (2000 (through October) for PPOs, and 2001 (through September) for HMOs)* Across all drug types: Col 1 is avg. copay per drug, Col2 is avg. payment per drug" table hmo              if basic==0  & $preperiodmeans [aw=obs], c(mean meancopay  mean totavgtotpaypd) format(%3.2f) row* Across all drug types: Col 1 is total use per person, Col2 is total payment per person, Col 3 is total insurer paymnt per persontable hmo              if basic==0  & $preperiodmeans [aw=obs], c(mean totalusage mean totpaypp mean totinspp) format(%3.2f) row* By Drug Type:  Row 1 is avg. copay per drug, Row2 is avg. payment per drugtable hmo  importance  if basic==0  & $preperiodmeans [aw=obs], c(mean meancopaybyimp mean avgtotpaypd) format(%3.2f) row* By Drug Type:  Row 1 is total use per person, Row2 is total payment per person, Col 3 is total insurer paymnt per persontable hmo  importance  if basic==0  & $preperiodmeans [aw=obs], c(mean usage mean paypp mean inspp) format(%3.2f) row* Look at Static copayssave tmp, replaceforeach basic   in 0    {* Don't know how to do this for the Pooled policy Changeuse tmp, clear* 2001 PPO policy Change* Across all drugsuse tmp, clearqui table hmo postppo [aw=obs] if basic==0 & importance==1 & timetrend<24, c(mean meancopay mean meancopaypost) replacequi reshape wide table* ,i(hmo) j(postppo)gen copaydd=table20-table10-(table21[_n+1]-table20[_n+1])di "Static copays for PPO policy change"list hmo copaydd if _n==1* By type of druguse tmp, clearqui table hmo postppo importance [aw=obs] if basic==0 & timetrend<24, c(mean meancopaybyimp mean meancopaypostbyimp) replacequi reshape wide table1 table2 , i(importance postppo) j(hmo)qui reshape wide table* , i(importance ) j(postppo)gen copaydd=table200-table100-(table211-table210)list importance copaydd* 2002 HMO policy change* Across all drugsuse tmp, clearqui table hmo posthmo [aw=obs] if basic==0 & importance==1 & timetrend>14, c(mean meancopay mean meancopaypost) replacequi reshape wide table* ,i(hmo) j(posthmo)qui gen copaydd=table20-table10-(table21[_n-1]-table20[_n-1])di "Static copays for HMO policy change"list hmo copaydd if _n==2use tmp, clearqui table hmo posthmo importance [aw=obs] if basic==0 & timetrend>14, c(mean meancopaybyimp mean meancopaypostbyimp) replacequi reshape wide table1 table2 , i(importance posthmo) j(hmo)qui reshape wide table* , i(importance ) j(posthmo)gen copaydd=table210-table110-(table201-table200)list importance copaydd}use erplanbyimportance, clearqui do drugs_createvarscapture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obsegen totalusage=sum(usage), by(plancode timetrend)gen  paypp=imputed_totalpay/obsegen totpaypp=sum(paypp), by(plancode timetrend )gen  inspp=imputed_inspay/obsegen totinspp=sum(inspp), by(plancode timetrend )sort plancode year monthmerge plancode year month using copayrename copay           meancopayrename modalcopay02    meancopay02rename modalcopay02ret meancopay02rettab _mergedrop if plancode==.* merge in drug specific copaysdrop _mergesort plancode year month importancemerge plancode year month importance using copaybyimportancerename copaybyimp               meancopaybyimprename modalcopaybyimp          meancopay02byimprename modalcopay02retailbyimp meancopay02retbyimptab _mergedrop if plancode==.* Regression without dynamics* Some specchecks for SElabel var totalusage "Total usage"global command "xtgls reg "global xtgls1 "i(plancode) t(timetrend) panels(het) corr(psar1) force"global xtgls2 "i(plancode) t(timetrend) panels(het) corr(ar1) force"global reg1   "cluster(plancode) r"global reg2   "cluster(planbymonth) r"estimates drop _allforeach basic   in 0    {foreach sample in  2001 2002 {foreach command of global command {foreach option in 1 2 {di "`command'"noi di "${`command'`option'}"		qui `command' meancopay      plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==1   			 ${timesample`sample'}  [w=obs], ${`command'`option'}		estimates store meancopay				qui `command' totalusage     plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==1   			 ${timesample`sample'}  [w=obs], ${`command'`option'}		estimates store totalusageforvalues importance = 1/3 {		qui `command' usage          plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'   ${timesample`sample'}  [w=obs], ${`command'`option'}		estimates store usage`importance'		qui `command' meancopaybyimp  plancodeD1-plancodeD8 ${treat`sample'}    timetrendD*   if basic==`basic' & importance==`importance'   ${timesample`sample'}  [w=obs], ${`command'`option'}		estimates store meancopayimp`importance'* close importance loop}* close sample loop* Col1 is copaychange, col2 is total use, col3 is acutecare drugs, col4 is chronic care drugs, col5 is lifestyle drugsestimates table            totalusage  usage1 usage2 usage3 ,        keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Command= `command', Option=${`command'`option'}, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table            meancopay meancopayimp1 meancopayimp2 meancopayimp3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f) title(" ") stats(N) stfmt(%3.0f)}}}}estimates drop _allforeach basic   in 0    {foreach sample in pooled 2001 2002 {		qui xtgls meancopay      plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==1   			 ${timesample`sample'}  [w=obs], $options		estimates store meancopay				qui xtgls totalusage     plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==1   			 ${timesample`sample'}  [w=obs], $options		estimates store totalusage		qui xtgls totpaypp     plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==1   			 ${timesample`sample'}  [w=obs], $options		estimates store totpaypp		qui xtgls totinspp     plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==1   			 ${timesample`sample'}  [w=obs], $options		estimates store totinsppforvalues importance = 1/3 {		qui xtgls usage          plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'   ${timesample`sample'}  [w=obs], $options		estimates store usage`importance'		qui xtgls meancopaybyimp  plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'   ${timesample`sample'}  [w=obs], $options		estimates store meancopayimp`importance'		qui xtgls paypp       plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'   ${timesample`sample'}  [w=obs], $options		estimates store paypp`importance'		qui xtgls inspp       plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'   ${timesample`sample'}  [w=obs], $options		estimates store inspp`importance'		* close importance loop}* close sample loop* Col1 is copaychange, col2 is total use, col3 is acutecare drugs, col4 is chronic care drugs, col5 is lifestyle drugsestimates table            totalusage  usage1 usage2 usage3 ,        keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Usage Regs, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table            meancopay meancopayimp1 meancopayimp2 meancopayimp3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Copay Changes, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table            totpaypp  paypp1 paypp2 paypp3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Total Payment Regs, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table            totinspp  inspp1 inspp2 inspp3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Insurer Payment Regs, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)}* close basic loop}* Do same regs as above, but omit Q+1 quarter and Q-1 Quarters from the regressionestimates drop _allforeach basic   in 0    {foreach sample in pooled 2001 2002 {		qui xtgls meancopay      plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==1  	 ${timesampleomit`sample'}  [w=obs], $options 		estimates store meancopay				qui xtgls totalusage     plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==1   	 ${timesampleomit`sample'}  [w=obs], $options 		estimates store totalusage		qui xtgls totpaypp     plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==1   	 ${timesampleomit`sample'}  [w=obs], $options 		estimates store totpaypp		qui xtgls totinspp     plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==1   	 ${timesampleomit`sample'}  [w=obs], $options 		estimates store totinsppforvalues importance = 1/3 {		qui xtgls usage          plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'   ${timesampleomit`sample'}  [w=obs], $options 		estimates store usage`importance'		qui xtgls meancopaybyimp  plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'  ${timesampleomit`sample'}  [w=obs], $options 		estimates store meancopayimp`importance'		qui xtgls paypp       plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'   ${timesampleomit`sample'}  [w=obs], $options 		estimates store paypp`importance'		qui xtgls inspp       plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'   ${timesampleomit`sample'}  [w=obs], $options 		estimates store inspp`importance'		* close importance loop}* close sample loop* Col1 is copaychange, col2 is total use, col3 is acutecare drugs, col4 is chronic care drugs, col5 is lifestyle drugsestimates table            totalusage  usage1 usage2 usage3 ,        keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Usage Regs omitting quarters t-1 and t=0, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table            meancopay meancopayimp1 meancopayimp2 meancopayimp3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Copay Changes omitting quarters t-1 and t=0, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table            totpaypp  paypp1 paypp2 paypp3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Total Payment Regs omitting quarters t-1 and t=0, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table            totinspp  inspp1 inspp2 inspp3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Insurer Payment Regs omitting quarters t-1 and t=0, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)}* close basic loop}* Regression with dynamics (pooled, and separately for 2001/2001)foreach basic  in 0   {foreach sample in pooled 2001 2002 {		qui xtgls meancopay      plancodeD1-plancodeD8 ${Dtreat`sample'}     timetrendD*   if basic==`basic' & importance==1   			 ${Dtimesample`sample'}  [w=obs], $options		estimates store meancopay`sample'			qui xtgls totalusage     plancodeD1-plancodeD8 ${Dtreat`sample'}     timetrendD*   if basic==`basic' & importance==1   			 ${Dtimesample`sample'}  [w=obs], $options		estimates store totalusage`sample'forvalues importance = 1/3 {		qui xtgls usage          plancodeD1-plancodeD8 ${Dtreat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'  ${Dtimesample`sample'}  [w=obs], $options		estimates store usage`importance'`sample'* close importance loop}di "Col1 is copaychange, col2 is total drug use, col3 is acutecare drugs, col4 is chronic care drugs and col5 is lifestyle drugs"estimates table  meancopay`sample' totalusage`sample'  usage1`sample' usage2`sample' usage3`sample' , keep (${Dtreat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f) label* close sample loop}* Pooled graphsforeach model in totalusagepooled  usage1pooled usage2pooled usage3pooled {	capture drop beta*	estimates restore `model'	for num 1 2 4 5 6 7 8: gen betaX=_b[treatQX] 	gen beta3=0	aorder beta*	gr bar  beta1-beta8, ascat /*	*/ yvaropt(relabel (1 "t-4" 2 "t-3" 3 "t-2" 4 "t-1" 5 "t=0" 6 "t+1" 7 "t+2" 8 "t+3") label(angle(horizontal)))  title(${`model'}) ylabel(#5, angle(horizontal)) saving(`model', replace)	* close  model loop below}gr combine totalusagepooled.gph usage1pooled.gph usage2pooled.gph usage3pooled.gph, title("Basic=`basic', HMO and PPO Effects Combined") saving(combined`basic'pooled, replace)* 2001 Policy Change graphsforeach model in totalusage2001  usage12001 usage22001 usage32001 {	capture drop beta*	estimates restore `model'	for num 1 2 3 5 6 7 8 9: gen betaX=_b[treatppoQX] 	gen beta4=0	aorder beta*	gr bar  beta1-beta9, ascat /*	*/ yvaropt(relabel (1 "t-5" 2 "t-4" 3 "t-3" 4 "t-2" 5 "t-1" 6 "t=0" 7 "t+1" 8 "t+2" 9 "t+3") label(angle(horizontal)))  title(${`model'}) ylabel(#5, angle(horizontal)) saving(`model', replace)	* close  model loop below}gr combine totalusage2001.gph usage12001.gph usage22001.gph usage32001.gph, title("Basic=`basic', 2001 Policy Change") saving(combined`basic'2001, replace)* 2002 Policy change graphsforeach model in totalusage2002  usage12002 usage22002 usage32002 {	capture drop beta*	estimates restore `model'	for num 1 2 4 5 6 7 8 10 11: gen betaX=_b[treathmoQX] 	gen beta3=0	aorder beta*	gr bar  beta1-beta11, ascat /*	*/ yvaropt(relabel (1 "t-4" 2 "t-3" 3 "t-2" 4 "t-1" 5 "t=0" 6 "t+1" 7 "t+2" 8 "t+3" 9 "t+4" 10 "t+5" 11 "t+6") label(angle(horizontal)))  title(${`model'}) ylabel(#5, angle(horizontal)) saving(`model', replace)	* close  model loop below}gr combine totalusage2002.gph usage12002.gph usage22002.gph usage32002.gph, title("Basic=`basic', 2002 Policy Change") saving(combined`basic'2002, replace)* close basic loop}*** END OF REGS BY IMPORTANCE (regs by essential / non-essential) follow this Segment *******************************************************  REGS BY ESSENTIAL/NON-ESSENTIAL follow this Segment ****************************************************use erplanbyessential, clearqui do drugs_createvarscapture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obsegen totalusage=sum(usage), by(plancode timetrend)gen  paypp=imputed_totalpay/obsegen totpaypp=sum(paypp), by(plancode timetrend )gen  inspp=imputed_inspay/obsegen totinspp=sum(inspp), by(plancode timetrend )sort plancode year monthmerge plancode year month using copayrename copay           meancopayrename modalcopay02    meancopay02rename modalcopay02ret meancopay02rettab _mergedrop if plancode==.* merge in drug specific copaysdrop _mergesort plancode year month essentialmerge plancode year month essential using copaybyessentialrename copaybyess           meancopaybyessrename modalcopaybyess    meancopay02byessrename modalcopay02retailbyess meancopay02retbyesstab _mergedrop if plancode==.* Preperiod means (2000 (through October) for PPOs, and 2001 (through September) for HMOs)* Across all drug types: Col 1 is avg. copay per drug, Col2 is avg. payment per drugtable hmo              if basic==0  & $preperiodmeans [aw=obs], c(mean meancopay  mean totavgtotpaypd) format(%3.2f) row* Across all drug types: Col 1 is total use per person, Col2 is total payment per person, Col 3 is total insurer paymnt per persontable hmo              if basic==0  & $preperiodmeans [aw=obs], c(mean totalusage mean totpaypp mean totinspp) format(%3.2f) row* By Drug Type:  Col 1 is avg. copay per drug, Col2 is avg. payment per drug"table hmo  essential  if basic==0  & $preperiodmeans [aw=obs], c(mean meancopaybyess mean avgtotpaypd) format(%3.2f) row* By Drug Type:  Col 1 is total use per person, Col2 is total payment per person, Col 3 is total insurer paymnt per persontable hmo  essential  if basic==0  & $preperiodmeans [aw=obs], c(mean usage mean paypp mean inspp) format(%3.2f) row* Look at Static copayssave tmp, replaceforeach basic   in 0    {* Don't know how to do this for the Pooled policy Changeuse tmp, clear* 2001 PPO policy Change* Across all drugsuse tmp, clearqui table hmo postppo [aw=obs] if basic==0 & essential==1 & timetrend<24, c(mean meancopay mean meancopaypost) replacequi reshape wide table* ,i(hmo) j(postppo)gen copaydd=table20-table10-(table21[_n+1]-table20[_n+1])di "Static copays for PPO policy change"list hmo copaydd if _n==1* By type of druguse tmp, clearqui table hmo postppo essential [aw=obs] if basic==0 & timetrend<24, c(mean meancopaybyess mean meancopaypostbyess) replacequi reshape wide table1 table2 , i(essential postppo) j(hmo)qui reshape wide table* , i(essential ) j(postppo)gen copaydd=table200-table100-(table211-table210)list essential copaydd* 2002 HMO policy change* Across all drugsuse tmp, clearqui table hmo posthmo [aw=obs] if basic==0 & essential==1 & timetrend>14, c(mean meancopay mean meancopaypost) replacequi reshape wide table* ,i(hmo) j(posthmo)qui gen copaydd=table20-table10-(table21[_n-1]-table20[_n-1])di "Static copays for HMO policy change"list hmo copaydd if _n==2use tmp, clearqui table hmo posthmo essential [aw=obs] if basic==0 & timetrend>14, c(mean meancopaybyess mean meancopaypostbyess) replacequi reshape wide table1 table2 , i(essential posthmo) j(hmo)qui reshape wide table* , i(essential) j(posthmo)gen copaydd=table210-table110-(table201-table200)list essential copaydd}use tmp, clear* Regression without dynamicslabel var totalusage "Total usage"foreach basic   in 0    {foreach sample in pooled 2001 2002 {		qui xtgls meancopay      plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & essential==1   		 ${timesampleomit`sample'}  [w=obs], $options		estimates store meancopay			qui xtgls totalusage     plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & essential==1   		${timesampleomit`sample'}   [w=obs], $options		estimates store totalusage		qui xtgls totinspp     plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & essential==1   			${timesampleomit`sample'}   [w=obs], $options		estimates store totinspp		qui xtgls totpaypp     plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & essential==1   			${timesampleomit`sample'}   [w=obs], $options		estimates store totpayppforvalues essential = 1/3 {		qui xtgls usage          plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & essential==`essential'  ${timesampleomit`sample'}   [w=obs], $options		estimates store usage`essential'		qui xtgls meancopaybyess  plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & essential==`essential'   ${timesampleomit`sample'}   [w=obs], $options		estimates store meancopayess`essential'		qui xtgls inspp       plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & essential==`essential'      ${timesampleomit`sample'}   [w=obs], $options		estimates store inspp`essential'		qui xtgls paypp       plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & essential==`essential'   ${timesampleomit`sample'}  [w=obs], $options		estimates store paypp`essential'* close essential loop}* close sample loop* Col1 is copaychange, col2 is total use, col3 is essential drugs, col4 is less-essential drugs, col5 are unclassified drugsestimates table            totalusage  usage1 usage2 usage3 ,        keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table            meancopay meancopayess1 meancopayess2 meancopayess3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table            totpaypp  paypp1 paypp2 paypp3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Total Payment Regs, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table            totinspp  inspp1 inspp2 inspp3 , keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Total Insurer Regs, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)}* close basic loop}* Regression with dynamics (pooled, and separately for 2001/2001)foreach basic   in 0   {foreach sample in pooled 2001 2002 {		qui xtgls meancopay      plancodeD1-plancodeD8 ${Dtreat`sample'}     timetrendD*   if basic==`basic' & essential==1   			 ${Dtimesample`sample'}  [w=obs], $options		estimates store meancopay`sample'ess			qui xtgls totalusage     plancodeD1-plancodeD8 ${Dtreat`sample'}     timetrendD*   if basic==`basic' & essential==1   			 ${Dtimesample`sample'}  [w=obs], $options		estimates store totalusage`sample'essforvalues essential = 1/3 {		qui xtgls usage          plancodeD1-plancodeD8 ${Dtreat`sample'}     timetrendD*   if basic==`basic' & essential==`essential'  ${Dtimesample`sample'}  [w=obs], $options		estimates store usage`essential'`sample'ess* close essential loop}di "Col1 is copaychange, col2 is total drug use, col3 is essential drugs, col4 is less essential care drugs and col5 are unclassified drugs"estimates table  meancopay`sample'ess totalusage`sample'ess  usage1`sample'ess usage2`sample'ess usage3`sample'ess , keep (${Dtreat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f) label* close sample loop}* Pooled graphsforeach model in totalusagepooledess  usage1pooledess usage2pooledess usage3pooledess {	capture drop beta*	estimates restore `model'	for num 1 2 4 5 6 7 8: gen betaX=_b[treatQX] 	gen beta3=0	aorder beta*	gr bar  beta1-beta8, ascat /*	*/ yvaropt(relabel (1 "t-4" 2 "t-3" 3 "t-2" 4 "t-1" 5 "t=0" 6 "t+1" 7 "t+2" 8 "t+3") label(angle(horizontal)))  title(${`model'}) ylabel(#5, angle(horizontal)) saving(`model', replace)	* close  model loop below}gr combine totalusagepooledess.gph usage1pooledess.gph usage2pooledess.gph usage3pooledess.gph, title("Basic=`basic', HMO and PPO Effects Combined") saving(combined`basic'pooledess, replace)* 2001 Policy Change graphsforeach model in totalusage2001ess  usage12001ess usage22001ess usage32001ess {	capture drop beta*	estimates restore `model'	for num 1 2 3 5 6 7 8 9: gen betaX=_b[treatppoQX] 	gen beta4=0	aorder beta*	gr bar  beta1-beta9, ascat /*	*/ yvaropt(relabel (1 "t-5" 2 "t-4" 3 "t-3" 4 "t-2" 5 "t-1" 6 "t=0" 7 "t+1" 8 "t+2" 9 "t+3") label(angle(horizontal)))  title(${`model'}) ylabel(#5, angle(horizontal)) saving(`model', replace)	* close  model loop below}gr combine totalusage2001ess.gph usage12001ess.gph usage22001ess.gph usage32001ess.gph, title("Basic=`basic', 2001 Policy Change") saving(combined`basic'2001ess, replace)* 2002 Policy change graphsforeach model in totalusage2002ess  usage12002ess usage22002ess usage32002ess {	capture drop beta*	estimates restore `model'	for num 1 2 4 5 6 7 8 10 11: gen betaX=_b[treathmoQX] 	gen beta3=0	aorder beta*	gr bar  beta1-beta11, ascat /*	*/ yvaropt(relabel (1 "t-4" 2 "t-3" 3 "t-2" 4 "t-1" 5 "t=0" 6 "t+1" 7 "t+2" 8 "t+3" 9 "t+4" 10 "t+5" 11 "t+6") label(angle(horizontal)))  title(${`model'}) ylabel(#5, angle(horizontal)) saving(`model', replace)	* close  model loop below}gr combine totalusage2002ess.gph usage12002ess.gph usage22002ess.gph usage32002ess.gph, title("Basic=`basic', 2002 Policy Change") saving(combined`basic'2002ess, replace)* close basic loop}* Regs by NEW/REFILLuse erplanbyimportance, clearqui do drugs_createvarscapture drop usage tmp  touse tousetotal totalusagefor var new refill newclass refillclass: gen Xpp=X/obsfor var newpp refillpp newclasspp refillclasspp: egen totalX=sum(X), by(plancode timetrend)* drop data for first 6 monthsdrop if timetrend<=6* drop plancode 3/4 completely as we don't have "pre" data for themdrop if plancode==3|plancode==4* Across all drug types: Col 1 is  new Rx per person, Col 2 is refills per persontable hmo              if basic==0  & $preperiodmeans [aw=obs], c(mean totalnewpp mean totalrefillpp) format(%3.2f) row* By type of drug:       Row 1 is  new Rx per person, Row 2 is refills per persontable hmo  importance  if basic==0  & $preperiodmeans [aw=obs], c(mean newpp mean refillpp)  format(%3.2f) row* Regression without dynamicsforeach basic in 0    {foreach sample in pooled 2001 2002 {		qui xtgls totalnewpp      plancodeD1-plancodeD8 ${treat`sample'}   timetrendD*   if basic==`basic' & importance==1   ${timesampleomit`sample'}   [w=obs], $options		estimates store totalnewpp			qui xtgls totalrefillpp     plancodeD1-plancodeD8 ${treat`sample'} timetrendD*   if basic==`basic' & importance==1    ${timesampleomit`sample'}   [w=obs], $options		estimates store totalrefillppforvalues importance = 1/3 {		qui xtgls newpp          plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'   ${timesampleomit`sample'}   [w=obs], $options		estimates store newpp`importance'		qui xtgls refillpp          plancodeD1-plancodeD8 ${treat`sample'}     timetrendD*   if basic==`basic' & importance==`importance'   ${timesampleomit`sample'}   [w=obs], $options		estimates store refillpp`importance'* close importance loop}* close sample loop* Col1 is copaychange, col2 is total use, col3 is acutecare drugs, col4 is chronic care drugs, col5 is lifestyle drugsestimates table  totalnewpp       newpp1    newpp2    newpp3, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("New Prescriptions, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)estimates table  totalrefillpp refillpp1 refillpp2 refillpp3, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Refill Prescriptions, Policy Change=`sample': Basic= `basic'") stats(N) stfmt(%3.0f)}* close basic loop}* Run regs for intensive and extensive utilizationuse erplanbyimportance, clearqui do drugs_createvarscapture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obsegen totalusage=sum(usage), by(plancode timetrend)drop if plancode==.* merge in data for intensive / extensive margin regressions.sort plancode year month importance merge   plancode year month importance using erdrugsforintensivedrop if plancode==0tab _merge* merge in data for #persons using all drugs (across all categories) for extensive margin regressions.* note: you cannot calculate this number by summing across the "importance" categories, as you'll double count individualsdrop _mergesort plancode year month  merge   plancode year month  using erdrugsforextensivedrop if plancode==0tab _merge* create LHS for regsgen  extensive=npersons/obsgen totalext =npersons_all/obsgen  intensive=(usage*obs)/npersonsegen totalint   =sum(usage*obs), by(plancode year month)replace totalint=totalint/npersons_all* Pre-period means on usage at extensive and intensive margins* Intensive and Extensive drug use across all Drug-types (will not vary by drugtype) (Row1=total intensive, Row2=total extensive margin, Row3=total use)table hmo  importance            [aw=obs] if basic==0 & $preperiodmeans, c(mean totalint  mean totalext   mean totalusage)   format(%3.2f) row* Intensive and Extensive drug  by  Drug-types (Row1=intensive use, Row2= extensive use, Row3= usage)table hmo importance              [aw=obs] if basic==0 & $preperiodmeans , c(mean intensive mean extensive  mean usage)   format(%3.2f) rowforeach basic   in 0   {foreach sample in pooled 2001 2002 {* Estimate models for total usuage: data is that the level of plancode and importance (1,2,3) so only use the first obs in each period for totalusagequi xtgls totalint    plancodeD1-plancodeD8 ${treat`sample'}  timetrendD*  if basic==`basic' & importance==1             ${timesampleomit`sample'} [w=obs], $optionsestimates store DD1totintqui xtgls totalext    plancodeD1-plancodeD8 ${treat`sample'} timetrendD*  if basic==`basic' & importance==1             ${timesampleomit`sample'} [w=obs], $optionsestimates store DD1totextforvalues importance = 1/3 {qui xtgls intensive plancodeD1-plancodeD8   ${treat`sample'}  timetrendD*  if basic==`basic' & importance==`importance'  ${timesampleomit`sample'} [w=obs], $optionsestimates store DD1int`importance'qui xtgls extensive   plancodeD1-plancodeD8 ${treat`sample'} timetrendD*   if basic==`basic' & importance==`importance' ${timesampleomit`sample'}  [w=obs], $optionsestimates store DD1ext`importance'* close drug type (importance) loop below}di "Usage at the Extensive and Intensive Margin Margin, Basic==`basic'"di "Col1 is across all drug types, col2 is for acute care drugs, col3 is for chronic care drugs, col4 is for lifestyle drugs"estimates table  DD1totint  DD1int1 DD1int2 DD1int3, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Intensive Margin") stats(N) stfmt(%3.0f)estimates table  DD1totext  DD1ext1 DD1ext2 DD1ext3, keep (${treat`sample'}) b(%4.3f) se(%4.3f) title("Policy Change=`sample': Extensive Margin") stats(N) stfmt(%3.0f)* close sample loop below}*close basic/supp loop below}* Cut by TERCILEuse erplanbytercile, clear* code that create obs-tercile cannot be moved to erplanbytercile.do as "tercile" var isn't in only define in erplanbytercile dataset.
* observation values have been recoded as X here (and below), to preserve the confidentiality of the data
gen obs_tercile=.replace obs_tercile=X if plancode==2 & tercile==1replace obs_tercile=X if plancode==2 & tercile==2replace obs_tercile=X if plancode==2 & tercile==3replace obs_tercile=X if plancode==4 & tercile==1replace obs_tercile=X if plancode==4 & tercile==2replace obs_tercile=X if plancode==4 & tercile==3replace obs_tercile=X if plancode==6 & tercile==1replace obs_tercile=X if plancode==6 & tercile==2replace obs_tercile=X if plancode==6 & tercile==3replace obs_tercile=X if plancode==8 & tercile==1replace obs_tercile=X if plancode==8 & tercile==2replace obs_tercile=X if plancode==8 & tercile==3qui do drugs_createvars capture drop usage tmp  touse tousetotal totalusagegen usage=onereplace usage=(usage)/obs_tercileegen totalusage=sum(usage), by(plancode timetrend tercile)label var totalusage "Total usage"gen  paypp=imputed_totalpay/obs_tercileegen totpaypp=sum(paypp), by(plancode timetrend tercile)gen  inspp=imputed_inspay/obs_tercileegen totinspp=sum(inspp), by(plancode timetrend tercile)sort plancode year month tercilecapture drop _mergemerge plancode year month tercile using copaybytercilerename copaybytercile           meancopayrename modalcopaybytercile    meancopay02rename modalcopay02retailbytercile meancopay02rettab _mergedrop if plancode==.drop if plancode==.* Pre-period means* Across all drug types and by tercile of spending : Row1=Copay per drug, Row2=Total Payments per Drug, Row3= Total use per person, Row4=Total Payments per person, Row5=Total Insurer Payments per persontable hmo            tercile  if basic==0  & $preperiodmeans [aw=obs_tercile], c(mean meancopay mean avgtot mean totalusage mean totpaypp mean totinspp)  format(%3.2f) row* Use by spending tercile and type of drug table hmo importance tercile  if basic==0 &  $preperiodmeans [aw=obs_tercile], c(mean usage) format(%3.2f) rowforeach basic   in 0 {foreach sample in pooled 2001 2002 {forvalues tercile = 1/3 {* Estimate models for total usage: