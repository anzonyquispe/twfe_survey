<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#the PredRes matrix has in its 1st column the predicted migrations and in the 2nd column the actual migrations to facilitate calculation of the loss function:</Text-field>
</Input>
</Group>
<Group view="code" labelreference="L542" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PredRes:=Matrix(1..tot,1..2);
PredRes[1..tot,2]:=data[1..tot,5]:

#Lambdas. actual lambda in the second column
PredLambda := Matrix(1..tot, 1..3);
PredLambda[1..tot,2]:=data[1..tot,10]:
for k from 1 to castes do:
PredLambda[N*k,1]:=1;
end do:
</Text-field>
</Input>
