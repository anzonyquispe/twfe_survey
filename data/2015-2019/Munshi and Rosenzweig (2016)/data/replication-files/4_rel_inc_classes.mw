<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Introduce vectors of starting nus, also the starting guess for beta and the (original) attempt limit:
#This specification uses a single nu, which is calibrated to 23.620298. 
starta:=[23.620298];
startc:=[1.5];
attemptlimit:=80;</Text-field>
