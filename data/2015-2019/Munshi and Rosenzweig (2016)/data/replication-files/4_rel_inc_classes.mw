<Group view="code" labelreference="L540" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#procedure to find beta from fixed nu(s) to match the first moment;
getbeta:= proc(a) option trace; global starta, tbad, endc;
starta:=a;
match:= Minimize((c)-&gt;mx2(starta,[c]),{},initialpoint=startc,method=nonlinearsimplex,evaluationlimit=1000);
endc:=match[2];
tbad;
endc;
