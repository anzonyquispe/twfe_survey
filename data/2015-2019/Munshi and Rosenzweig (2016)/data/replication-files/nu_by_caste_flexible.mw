<Group view="code" labelreference="L485" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#note that this is a modified version of the mx2 procedure.
#mx2 generates a value for the loss function, which is defined below.
#A grid search is then used to determine the combination of alpha (c) and gamma (d) that minimizes this value:</Text-field>
</Input>
</Group>
<Group view="code" labelreference="L454" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">mx2:=proc(a,c,d) options notrace; global tbad,ik,badarray,badstot,enda,PredRes,avpredmig,PredLams,avglams;
p:=0; tbad:=0;

for k from 1 to castes do;
stk:=(k-1)*N+1;
enk:=stk+N-1;

sa:=mxj(a,c,d,stk,enk);
#showx7(sa);


#Fill PredRes matrix with predicted migrations:
for i from 1 to N do;
PredRes[stk+i-1,1]:=op(i,sa[1]);
end do;

#Fill predicted lambdas matrix;
for i from 1 to (N-1) do;
PredLams[k,i]:=op(2,op(i,op(2,sa[2])));
end do;

tbad:=tbad+sa[3];
badarray[k]:=sa[4];

for i from 1 to N do;
badstot[N*(k-1)+i]:=sa[3];
end do;

end do;

#Get average predicted lambdas:
for i from 1 to (N-1) do:
avglams[i]:=add(PredLams[k,i],k=1..castes)/castes;
end do;

#Get average predicted migration, by relative income-classes:
for i from 1 to N do:
avgpred[i]:=add(PredRes[N*(j-1)+i,1],j=1..castes)/castes;
end do:

#Get average predicted migration:
averagepred:=add(PredRes[i,1],i=1..tot)/tot;

#Loss function : For this flexible specification, we match 1st relative income-class' actual and predicted migration, as well as 5th relative income-class' actual/predicted migration.
p:=(avgpred[1]-migbyclass[1])^2+(avgpred[N]-migbyclass[N])^2;

ik:=ik+1;

if trunc(ik/20)=ik/20 then 
 show(p,a,c,d);
end if;
p;
end proc;</Text-field>
</Input>
<Output>
<Text-field style="HyperlinkWarning" layout="HyperlinkWarning"><Hyperlink linktarget="http://www.maplesoft.com/support/help/errors/view.aspx?path=Warning,%20%60p%60%20is%20implicitly%20declared%20local%20to%20procedure%20%60mx2%60" hyperlink="true"><Font style="HyperlinkWarning">Warning, `p` is implicitly declared local to procedure `mx2`</Font></Hyperlink></Text-field>
</Output>
<Output>
<Text-field style="HyperlinkWarning" layout="HyperlinkWarning"><Hyperlink linktarget="http://www.maplesoft.com/support/help/errors/view.aspx?path=Warning,%20%60k%60%20is%20implicitly%20declared%20local%20to%20procedure%20%60mx2%60" hyperlink="true"><Font style="HyperlinkWarning">Warning, `k` is implicitly declared local to procedure `mx2`</Font></Hyperlink></Text-field>
</Output>
<Output>
