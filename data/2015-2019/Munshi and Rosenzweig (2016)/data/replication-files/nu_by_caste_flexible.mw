<Group view="code" labelreference="L338" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#note: this procedure is modified to allow for a separate nu for each caste and to have alpha and gamma vary based on absolute income class, which will be used in the counterfactual simulations for Figures 7 and 8:
mxj:=proc(a,c,d,j,jm) option notrace;

attempts:=0;
doMax:=true;
while doMax do:
attempts:=attempts+1:

# ma is mean income, va is variance of income, p is population, and f is migration.
# a different nu is assigned for each caste
# beta is determined as below: alpha + gamma * (relative income-class' mean income)
</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">mm:=['ma[i-j+1]=data[i,3]'$'i'=j..jm];
vv:=['va[i-j+1]=data[i,4]'$'i'=j..jm];
nut:=['nu[i-j+1]=a[trunc((i-1)/N)+1]'$'i'=j..jm];
nutbet:=['beta[i-j+1]=c[trunc(data[i,11]+1)]+(data[i,3]*d[trunc(data[i,11]+1)])'$'i'=j..jm];
pp:=['p[i-j+1]=data[i,1]'$'i'=j..jm];</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" alignment="left" firstindent="0" spacebelow="0" leftmargin="0" linespacing="0.0" initial="0" linebreak="space" rightmargin="0" bulletsuffix="" spaceabove="0" bullet="none" pagebreak-before="false">mf:=['f[i-j+1]=data[i,5]'$'i'=j..jm];
nomig:=['nm[i-j+1]=data[i,9]'$'i'=j..jm];
</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" alignment="left" firstindent="0" spacebelow="0" leftmargin="0" linespacing="0.0" initial="0" linebreak="space" rightmargin="0" bulletsuffix="" spaceabove="0" bullet="none" pagebreak-before="false">parms:=op(mm),op(vv),op(pp),op(nut),op(nutbet);

#x4c is actual number of migrants, x4c1, x4d are default values if interior solution cannot be found, x4e, x4f, and x4f1 are constraints. x4d and x4g are used as starting points.</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">x4c:='n[i]=(1-f[i])*p[i]'$'i'=1..N;
x4c1:='n[i]=p[i]'$'i'=1..N;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">x4d:=subs(parms,{'lambda[i]=ma[i]/ma[N]*1'$'i'=1..(N-1)});
x4e:=subs(parms,{'n[i]&lt;=p[i]'$'i'=1..N});
x4f:={'lambda[i]&lt;=1'$'i'=1..(N-1)};
x4f1:=subs(mm,{'lambda[i]&gt;=ma[i]/ma[N]'$'i'=1..(N-1)});
x4h:=subs(parms,mf,{x4d});
x4g:=subs(nomig,{'n[i]=nm[i]'$'i'=1..N});
x4g1:=subs(parms,mf,{x4c1});


#x5 is the surplus function and x6 is the fixed point condition with the data for this caste.
x5:=subs(parms,subs(x1a,x2a,x4));
x6:=subs(parms,subs(x1a,x2a,x3e)):
bad:=0;

start:={op(x4g),op(x4d)};
#showx7(start);

#estimate lambdas and n's to maximize surplus function
try
</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#note, removed op(x4e) as a constraint (should not make a difference)
x7:=Maximize(x5,{op(x6), op(x4f), op(x4f1)},assume=nonnegative,initialpoint=start,iterationlimit=500);

catch &quot;no improved point could be found&quot; : bad:=1;nb:=1;
catch &quot;no feasible point found for the nonlinear constraints&quot; : bad:=1;nb:=2;
catch &quot;complex value encountered&quot; : bad:=1; nb:=3;
catch &quot;could not store&quot; : bad:=1; nb:=4;
catch &quot;number expected for float[8] parameter&quot; : bad:=1; nb:=5; castes:=tot/N;
end try;
#attemptlimit specifies how many times to try to rerun the procedure for a particular caste in case of a bad:
if bad=1 and attempts&lt;attemptlimit then 
doMax:=true; 

else
doMax:=false: 
if bad = 1 then:

#if a bad remains after rerunning procedure, attempt to estimate migration assuming lambdas in autarky and solving the fixed point condition:
tosolve:=subs(op(x4d),subs(parms,['x3e[i]'$'i'=1..N])):
badns:=fsolve({op(tosolve)});
if op(0,badns)= fsolve then badns:=evalf(subs(op(pp),['n[i]=p[i]*subs(op(start),op(2,x6[i]))'$'i'=1..N])); end if;
badns:=[op(badns)];
for i from 1 to N do:
if op(2,badns[i]) &gt; op(2,pp[i]) then: badns[i]:=subs(op(pp),n[i]=p[i]);end if:
if op(2,badns[i]) &lt; 0 then:badns[i]:=n[i]=0;end if:
end do:
x7:=[0,[op(op(x4h)),op(badns)]];
end if:

end if:
end do:

#x8a is actual participation, x8b is predicted participation.
x8a:=subs(parms,mf,{x4c});
x8b:=subs(op(2,x7),{'ne[i]=n[i]'$'i'=1..N});

#SSE(with some complication - x8c is added for diagnostic purpose to check that mean error is close to zero.)
x8c:=evalf(subs(x8a,x8b,op(pp),['n[i]/p[i]-ne[i]/p[i]'$'i'=1..N]));
</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#x8 is a vector of the difference for each relative income class between the actual and predicted migration. x9 was the squared sum of these, no longer used. predmig is a vector of predicted migration by relative income class. x9new is the output of the procedure, referenced in mx2 as 'sa':
x8:=subs(subs(op(2,x7),{'ne[i]=n[i]'$'i'=1..N}),op(x8a),op(pp),['n[i]/p[i]-ne[i]/p[i]'$'i'=1..N]);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#x9:=[sum('x8[i]^2','i'=1..N),x7,bad,nb,x8c];
predmig:=subs(op(2,x7),op(pp),['(p[i]-n[i])/p[i]'$'i'=1..N]);
#NOTE removed risk ratio:
#riskrat:=['(vi[i]*ma[i]^2)/(va[i]*mi[i]^2)'$'i'=1..N];
#risk2:=subs(parms,op(2,x7),subs(x1a,x2a,riskrat));
risk2:=1;
x9new:=[predmig,x7,bad,nb,x8c,risk2];</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">end proc;</Text-field>
</Input>
<Output>
<Text-field style="HyperlinkWarning" layout="HyperlinkWarning"><Hyperlink linktarget="http://www.maplesoft.com/support/help/errors/view.aspx?path=Warning,%20%60attempts%60%20is%20implicitly%20declared%20local%20to%20procedure%20%60mxj%60" hyperlink="true"><Font style="HyperlinkWarning">Warning, `attempts` is implicitly declared local to procedure `mxj`</Font></Hyperlink></Text-field>
</Output>
