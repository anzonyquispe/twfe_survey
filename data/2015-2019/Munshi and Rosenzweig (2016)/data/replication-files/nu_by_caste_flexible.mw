<Group view="code" labelreference="L580" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># using grid search to find where the loss function is minimzed, given alpha and gamma value. Alpha and gamma is used to determine the beta for each caste. (Gamma multiplied to the mean income of the relative income-classes, alpha added to this number) Alpha range is from 0 to 0.05, and gamma ranges from 3.80 to 4.50. Step sizes or ranges could be changed using the for loops right below.

</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">Loss_Func := Matrix(1..390,1..4);
k :=0:
#note: have to enter parameters as a vector of 5: one for each absolute income class
#this is necessary for some of the later counterfactuals
for i from 0.00 by 0.002 to 0.05 do:
    for j from 3.80 by 0.05 to 4.50 do:
       k:=k+1;
       Loss_Func[k,1]:=k;
       Loss_Func[k,2]:=i;
       Loss_Func[k,3]:=j;
       Loss_Func[k,4]:=mx2(starta,[i,i,i,i,i],[j,j,j,j,j]);
end do:
end do:
Export(Loss_Func, &quot;Loss_Func_Grid.xlsx&quot;);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" alignment="left" firstindent="0" spacebelow="0" leftmargin="0" linespacing="0.0" initial="0" linebreak="space" rightmargin="0" bulletsuffix="" spaceabove="0" bullet="none" pagebreak-before="false">i:='i': j:= 'j': k:='k':</Text-field>
</Input>
<Input>
