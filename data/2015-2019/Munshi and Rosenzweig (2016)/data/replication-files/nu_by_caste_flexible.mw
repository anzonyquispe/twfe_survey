<Group view="code" labelreference="L540" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># procedure to find beta from fixed nu(s) to match the first moment;
# we do not use getbeta procedure in this specification but left it here for reference. 
getbeta:= proc(a) option trace; global starta, tbad, endc, endd;
starta:=a;

match:= Minimize((c,d)-&gt;mx2(starta,[c],[d]),{},initialpoint=[startc,startd],method=nonlinearsimplex,evaluationlimit=1000);
endc:=op(2,op(1,op(2,match[2]))); 
endd:=op(2,op(2,op(2,match[2])));
tbad;
end proc;</Text-field>
</Input>
<Output>
<Text-field style="HyperlinkWarning" layout="HyperlinkWarning"><Hyperlink linktarget="http://www.maplesoft.com/support/help/errors/view.aspx?path=Warning,%20%60match%60%20is%20implicitly%20declared%20local%20to%20procedure%20%60getbeta%60" hyperlink="true"><Font style="HyperlinkWarning">Warning, `match` is implicitly declared local to procedure `getbeta`</Font></Hyperlink></Text-field>
</Output>
<Output>
<Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
