. do estimate_cost_generators2.do 

. /*
> 
> Program to Estimate Cost of Generators
> 
> Allan Collard-Wexler
> 
> October 1 2014
> 
> */
. 
. cd ~/Dropbox/India_Power_Shortages/matlab/
/Users/ac418/Dropbox/India_Power_Shortages/matlab

. clear all

. set more off

. set mem 500m
set memory ignored.
    Memory no longer needs to be set in modern Statas; memory adjustments are
    performed on the fly automatically.

. set linesize 200

. 
. 
. // (assuming a ten year life)
. global gen_lifespan=10

. 
. // Price of Self-Generated Power
. // Source: World Bank Survey
. global p_e_s=7

. // Price of Grid Power
. global p_e_g=4.5

. 
. // Hours of production: 6 hours a day
. global hours_prod=6*365

. 
. 
. global graphit=1

. 
. cd simulation_asi_inputs_dec2014
/Users/ac418/Dropbox/India_Power_Shortages/matlab/simulation_asi_inputs_dec2014

. 
. // Generator 
. 
. global graphit=1

. global p_e_s=7

. global elasticity=-10

. global filename="ASI_Prediction2005_7.csv"

. 
. 
. clear

. insheet using $filename
(45 vars, 33871 obs)

. 
. // Keep plants that are not in exogenous generation industries
. keep if exog_gen_industry==0
(4614 observations deleted)

. 
. g kshare_Y=fcapclose/grsale_defl

.                * trim outliers
.                replace kshare_Y = . if kshare_Y>20 //
(59 real changes made, 59 to missing)

. 
. cap drop if $droplist

. //noisily des
. foreach x of varlist year-y_no_generator {
  2. destring `x', replace force
  3. } 
year already numeric; no replace
delta_psp already numeric; no replace
delta_pdpm already numeric; no replace
k already numeric; no replace
alpha_m already numeric; no replace
alpha_l already numeric; no replace
alpha_k already numeric; no replace
alpha_e already numeric; no replace
omega already numeric; no replace
zero_generation_flag already numeric; no replace
p already numeric; no replace
p_m already numeric; no replace
p_l already numeric; no replace
y_shortage already numeric; no replace
y_no_shortage already numeric; no replace
m_shortage already numeric; no replace
m_no_shortage already numeric; no replace
l_shortage already numeric; no replace
l_no_shortage already numeric; no replace
e_self_shortage already numeric; no replace
e_self_no_shortage already numeric; no replace
e_grid_shortage already numeric; no replace
e_grid_no_shortage already numeric; no replace
pctshortage already numeric; no replace
messedupcompute already numeric; no replace
y_shortage_prime already numeric; no replace
y_no_shortage_prime already numeric; no replace
profit_generator already numeric; no replace
profit_no_generator already numeric; no replace
profit_no_shortages already numeric; no replace
snic_hc already numeric; no replace
exog_gen_industry already numeric; no replace
panelgroup already numeric; no replace
scheme_dummy already numeric; no replace
grsale_defl already numeric; no replace
totpersons already numeric; no replace
qeleccons already numeric; no replace
fcapclose already numeric; no replace
matls_defl already numeric; no replace
y_no_generator already numeric; no replace

. 
. //---------------------------------------------------------------------------------------
. // 0) Prep Work
. //---------------------------------------------------------------------------------------
. 
. cap destring e_grid_no_generator, replace force

. cap destring e_grid_generator, replace force

. 
. 
. sum delta_psp, meanonly

. scalar shortage=r(mean)

. 
. drop if messedupcompute==-2
(0 observations deleted)

. 
. //---------------------------------------------------------------------------------------
. // 1) Dollar Per Megawatt to make indifference between generator and no-generator
. //---------------------------------------------------------------------------------------
. replace e_self_shortage=e_self_shortage/$p_e_s
(15758 real changes made)

. replace e_self_no_shortage=e_self_no_shortage/$p_e_s
(0 real changes made)

. 
. replace e_grid_shortage=e_grid_shortage/$p_e_g
(29256 real changes made)

. replace e_grid_no_shortage=e_grid_no_shortage/$p_e_g
(29256 real changes made)

. 
. gen total_power=e_self_shortage + e_grid_shortage

. 
. // Size of Required Generator
. gen gen_size= total_power/($hours_prod)
(6 missing values generated)

. 
. 
. //---------------------------------------------------------------------------------------
. // 1.5) Profits of a Generator, Cost of These
. //---------------------------------------------------------------------------------------
. gen profit_no_shortage=y_no_shortage-p_m * m_no_shortage -p_l *  l_no_shortage-$p_e_g* e_grid_no_shortage-$p_e_s* e_self_no_shortage

. gen profit_shortage=y_shortage-p_m* m_shortage-p_l* l_shortage-$p_e_g* e_grid_shortage-$p_e_s* e_self_shortage

. 
. gen has_gen=(zero_generation_flag==1)

. 
. 
. gen log_gen_size=log(gen_size)
(7 missing values generated)

. reg zero_generation_flag log_gen_size 

      Source |       SS       df       MS              Number of obs =   29250
