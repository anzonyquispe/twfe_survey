. // Program 
. cap program drop gen_cost_estimator

. program gen_cost_estimator, eclass
  1. 
. capture drop if $dropglobal
  2. 
. * Load Data
. mata: LOG_K=st_data(.,("log_k"))
  3. mata: LOG_G=st_data(.,("log_gen_size"))
  4. mata: GENERATOR=st_data(.,("has_gen"))
  5. mata: PROFIT_GEN=st_data(.,("profit_generator"))
  6. mata: PROFIT_NO_GEN=st_data(.,("profit_no_generator"))
  7. mata: GEN_SIZE=st_data(.,("gen_size"))
  8. 
. * Setup Optimizer
. mata: S3=optimize_init()
  9. mata: optimize_init_evaluator(S3, &GMM_CRIT2())
 10. mata: optimize_init_evaluatortype(S3,"d0")
 11. mata: optimize_init_technique(S3, "nm")
 12. mata: optimize_init_nmsimplexdeltas(S3, 1)
 13. mata: optimize_init_which(S3,"min")
 14. 
. * These starting values come from Regressions on Generators Costs
. mata: optimize_init_params(S3,(12,0.8))
 15. mata: optimize_init_argument(S3, 1, GENERATOR)
 16. mata: optimize_init_argument(S3, 2, PROFIT_GEN)
 17. mata: optimize_init_argument(S3, 3, PROFIT_NO_GEN)
 18. mata: optimize_init_argument(S3, 4, GEN_SIZE)
 19. mata: optimize_init_argument(S3, 5, LOG_K)
 20. mata: optimize_init_argument(S3, 6, LOG_G)
 21. 
. * Minimize Criterion
. 
. mata: p3=optimize(S3)
 22. mata: p3
 23. 
. forval i=1/4 {
 24. mata: optimize_init_params(S3,p3)
 25. mata: p3=optimize(S3)
 26. mata: p3
 27. 
. mata: GEN_COSTS=exp(p3[1,1]):*(GEN_SIZE):^p3[1,2]
 28. mata: PREDICTED_GEN=PROFIT_GEN:>(PROFIT_NO_GEN+GEN_COSTS)
 29. mata: cov_hat_k=variance((PREDICTED_GEN,LOG_K))
 30. mata: cov_data_k=variance((GENERATOR,LOG_K))
 31. 
. mata: cov_hat_g=variance((PREDICTED_GEN,LOG_G))
 32. mata: cov_data_g=variance((GENERATOR,LOG_G))
 33. 
. mata: genpredvec=(mean(PREDICTED_GEN),mean(GENERATOR))
 34. 
. mata: genpredvec
 35. mata: cov_hat_g[2,1],cov_data_g[2,1]
 36. mata: cov_hat_k[2,1],cov_data_k[2,1]
 37. }
 38. 
. 
. mata: st_matrix("sigmas2",p3)
 39. 
. 
. 
. mat colnames sigmas2 = sigma_0, sigma_1
 40. ereturn post sigmas2
 41. end

. 
