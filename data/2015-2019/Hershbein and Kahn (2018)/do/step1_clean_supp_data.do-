*}}}
assert age>=16
gen employed = (empstat==10 | empstat==12)

gen dropout = (educ99<=9)
gen hs = (educ99==10)
gen sc = (educ99>=11 & educ99<=14)
gen ba_plus = (educ99>=15 & educ99<999)
assert dropout + hs + sc + ba_plus==1


keep if year<2016


gen metarea_collapse = floor(metarea/10)
drop metarea
ren metarea_collapse metarea

**merge in Bartiks created above -- some don't match to the shock vars
merge m:1 metarea using "$data_output/Bartiks_metarea"
keep if _merge==3
ren metarea msa

gen epop_low = employed if dropout==1 | hs==1
gen epop_high = employed if sc==1 | ba_plus==1

collapse epop_low epop_high lf2006 ACS* M_ACS shock9010  [aw=wtfinl], by(msa year)

gen weight = lf2006


save "$public/workingCPS", replace
save "$data_output/workingCPS", replace
*}}}

***clean layoffs dataset made by brad
*{{{
use "$CPS_data/CPS_layoff_regready_part1", clear
append using "$CPS_data/CPS_layoff_regready_part2"

**soc codes are slightly different in this sample so use that categorization to get quantiles
preserve
collapse AA_r_cog AA_r_man [aw=pwgt], by(soc4)
foreach var of varlist AA_r_cog AA_r_man {
	foreach q in 4 {
		xtile V`var'`q'_unwt = `var', nq(`q')
	}
}
tempfile CPSoccs
save `CPSoccs', replace
restore

keep if year<2016

collapse invsep lf2006 shock9010 ACS* M_ACS (rawsum) pwgt [aw=pwgt], by(msa soc4 year)
merge m:1 soc4 using `CPSoccs'
assert _merge==3
drop _merge

foreach year of numlist 2000/2015 {
	gen shock9010`year' = shock9010*(year==`year')
}

bysort msa year: egen tot = sum(pwgt)
gen weight = lf2006*pwgt/tot

gen temp = invsep if year==2007
bysort msa soc: egen mtemp = mean(temp)
bysort msa: egen helper = nvals(year)
**there are some non-matches even among MSAs present every year
tab helper if mtemp==.
gen chinvsep = invsep - mtemp
gen Mvar = (chinvsep==.)
tab Mvar
tab Mvar [aw=weight]
drop helper temp mtemp

foreach year of numlist 2000/2006 2008/2015 {
	gen cog`year' = shock9010*(year==`year')*(VAA_r_cog4_unwt==4)
	gen man`year' = shock9010*(year==`year')*(VAA_r_man4_unwt==4)
}

bysort msa: egen Nyears = nvals(year)
gen has16 = (Nyears==16)
tab has16
tab has16 [aw=weight]
tab has16 if chinvsep!=.
tab has16 if chinvsep!=. [aw=weight]

sum invsep chinvsep [aw=weight]
sum invsep chinvsep [aw=weight] if VAA_r_cog4_unwt==4
sum invsep chinvsep [aw=weight] if VAA_r_man4_unwt==4

save "$public/workingCPS_layoffs", replace
save "$data_output/workingCPS_layoffs", replace

*}}}

*}}}

