***get ave chars in 2005 and 2006
assert year==2005 | year==2006


ren met2013 msa

**recode MSAs to NECTAs to match BG (and BLS etc)
*{{{
				foreach var in msa  {
					qui replace `var' = 	70600	if `var'==	12300	//Augusta-Waterville, ME
					qui replace `var' = 	70750	if `var'==	12620	//Bangor, ME
					qui replace `var' = 	70900	if `var'==	12700	//Barnstable Town, MA
					qui replace `var' = 	71050	if `var'==	12740	//Barre, VT
					qui replace `var' = 	71350	if `var'==	13540	//Bennington, VT
					qui replace `var' = 	71500	if `var'==	13620	//Berlin, NH-VT
					qui replace `var' = 	71500	if `var'==	13620	//Berlin, NH-VT
					qui replace `var' = 	71650	if `var'==	14460	//Boston-Cambridge-Quincy, MA-NH
					qui replace `var' = 	71950	if `var'==	14860	//Bridgeport-Stamford-Norwalk, CT
					qui replace `var' = 	72400	if `var'==	15540	//Burlington-South Burlington, VT
					qui replace `var' = 	72500	if `var'==	17200	//Claremont, NH
					qui replace `var' = 	72700	if `var'==	18180	//Concord, NH
					qui replace `var' = 	73450	if `var'==	25540	//Hartford-West Hartford-East Hartford, CT
					qui replace `var' = 	73750	if `var'==	28300	//Keene, NH
					qui replace `var' = 	73900	if `var'==	29060	//Laconia, NH
					qui replace `var' = 	74350	if `var'==	30100	//Lebanon, NH-VT
					qui replace `var' = 	74650	if `var'==	30340	//Lewiston-Auburn, ME
					qui replace `var' = 	74950	if `var'==	31700	//Manchester-Nashua, NH
					qui replace `var' = 	75700	if `var'==	35300	//New Haven-Milford, CT
					qui replace `var' = 	76450	if `var'==	35980	//Norwich-New London, CT
					qui replace `var' = 	76600	if `var'==	38340	//Pittsfield, MA
					qui replace `var' = 	76750	if `var'==	38860	//Portland-South Portland-Biddeford, ME
					qui replace `var' = 	77200	if `var'==	39300	//Providence-New Bedford-Fall River, RI-MA
					qui replace `var' = 	77500	if `var'==	40500	//Rockland, ME
					qui replace `var' = 	77650	if `var'==	40860	//Rutland, VT
					qui replace `var' = 	78100	if `var'==	44140	//Springfield, MA
					qui replace `var' = 	78400	if `var'==	45860	//Torrington, CT
					qui replace `var' = 	79300	if `var'==	48740	//Willimantic, CT
					qui replace `var' = 	79600	if `var'==	49340	//Worcester, MA
				}
*}}}

****make variables
gen ACS_female = (sex==2)
gen ACS_hispanic = (hispan>=1 & hispan<=4)
gen ACS_black = (ACS_hispanic==0 & race==2)
gen ACS_asian = (ACS_hispanic==0 & race>=4 & race<=6)
gen ACS_married = (marst==1)
gen ACS_migrated = (migrate1>1 & migrate1<=4) 
gen ACS_dropout = (educ<=5)
gen ACS_hs = (educ==6)
gen ACS_sc = (educ>=7 & educ<=9)
gen ACS_ba = (educ==10)
gen ACS_enrolled = (school==2)

gen ACS_18 = (age<=18)
gen ACS_19_29 = (age>=19 & age<=29)
gen ACS_30_39 = (age>=30 & age<=39)
gen ACS_40_49 = (age>=40 & age<=49)
gen ACS_50_64 = (age>=50 & age<=64)

gen ACS_epop = (empstat==1)
replace ACS_epop = . if age>64 | age<16

foreach var in incwage wkswork uhrswor {
	replace `var' = . if q`var'!=0
}

gen weekly_wage = incwage/wkswork1 if wkswork1>=48 & wkswork1!=. & uhrswork>=35 & uhrswork!=.
ren weekly_wage ACS_wage

***MSA collapse
**use person weights within year and unweighted across year
collapse ACS* [aw=perwt], by(msa year)
collapse ACS*, by(msa)

save "$data_output/ACSvars0506_msa", replace
save "$public/ACSvars0506_msa", replace

*}}}


/****************************************************************************
** 	2. Annual labor force from BLS LAUS			   	   **
****************************************************************************/
*{{{
clear
import delim using "$raw_MSA/msa_LF_2006_all.txt"
ren v1 msacode
ren v2 lf2006

gen statemsa = substr(msacode,6,2)
destring statemsa, replace
assert statemsa!=.
tab statemsa
gen msa = substr(msacode,8,5)
destring msa, replace
assert msa!=.

keep msa lf2006
save "$data_output/msa_LF_2006", replace
save "$public/msa_LF_2006", replace
*}}}



/****************************************************************************
** 3. Make Bartiks 					**
****************************************************************************/
*{{{
**clean raw data
*{{{
local max = 666
foreach set in 0405 {
	foreach geo in msa {
		foreach suffix in sa {
			use "$data_output/cbp_3dig_`set'_`geo'.dta", clear
	
			if "`set'"=="0405" {
				gen year = 200405
			}
			if "`set'"=="9899" {
				gen year = 199899
			}
	
			* Keep only the ln_emp_change
			merge m:1 naics using "$data_output/ces_emp_growth_naics3_98_15_`suffix'.dta", ///
			keepusing(emp_`suffix'* ln_emp_change*)
	
			* Unmatched is AG (11), which CES doesn't track --> drop
			* Unmatched also is rail transport (482), which CBP doesn't track --> drop
			drop if (naics>=110 & naics<=119) | naics==482
			drop _merge
	
			sort `geo' year naics

			/*LBK: get emp levels*/
			forv t = 468/`max' {
				gen lnemp`t' = (log(emp_`suffix'`t'))*wt
				gen emp`t' = emp_`suffix'`t'*wt
				foreach var of varlist lnemp`t' emp`t' {
					by `geo' year: egen tot_`var' = total(`var')
				}
				drop lnemp`t' emp`t'
				forv tau = 1/11 {
					local tmin`tau' = `t' - `tau'
				}
				gen ln_emp_ch_1mo`t' = ln_emp_change`t'*wt
				gen ln_emp_ch_2mo`t' = ln_emp_ch_1mo`t' + ln_emp_change`tmin1'*wt
				gen ln_emp_ch_3mo`t' = ln_emp_ch_2mo`t' + ln_emp_change`tmin2'*wt
				gen ln_emp_ch_6mo`t' = ln_emp_ch_3mo`t' + ///
				(ln_emp_change`tmin3'+ln_emp_change`tmin4'+ln_emp_change`tmin5')*wt
				gen ln_emp_ch_12mo`t' = ln_emp_ch_6mo`t' + ///
				(ln_emp_change`tmin6'+ln_emp_change`tmin7'+ln_emp_change`tmin8'+ ///
				ln_emp_change`tmin9'+ln_emp_change`tmin10'+ln_emp_change`tmin11')*wt
	
				foreach var of varlist ln_emp_ch_1mo`t'-ln_emp_ch_12mo`t'  {
					by `geo' year: egen tot_`var' = total(`var')
				}
				drop ln_emp_ch_1mo`t'-ln_emp_ch_12mo`t'
		
			}
	
			bysort `geo' year: gen helper = _n		/* Collapse to geo-year-level */
			keep if helper==1
	
			if "`geo'"=="msa" {
				keep tot_* `geo' MetroMicro
				reshape long tot_emp tot_lnemp tot_ln_emp_ch_1mo tot_ln_emp_ch_2mo tot_ln_emp_ch_3mo tot_ln_emp_ch_6mo tot_ln_emp_ch_12mo, i(`geo' MetroMicro) j(date)
			}
			else if "`geo'"=="state" | "`geo'"=="division" {
				keep tot_* `geo'
				reshape long tot_emp tot_lnemp tot_ln_emp_ch_1mo tot_ln_emp_ch_2mo tot_ln_emp_ch_3mo tot_ln_emp_ch_6mo tot_ln_emp_ch_12mo, i(`geo') j(date)
			}
	
	format %tm date
	saveold "$data_output/bartik_3d_`set'_`geo'_`suffix'_G.dta", replace
	
	}
	}
}
*}}}

**make bartiks
*{{{
foreach geo in msa  {
	foreach season in sa {
		use "$data_output/bartik_3d_0405_`geo'_`season'_G", clear
		**keep only metro areas for dist
		keep if MetroMicro==1

		gen year = 1999 + floor((date - 468)/12)
		merge m:1 `geo' using "$data_output/`geo'_LF_2006"
		drop if _merge==2
		drop _merge
		ren tot_ln_emp_ch_12mo bartik12
		ren tot_lnemp level
		foreach month in 1 2 3 6 {
			ren tot_ln_emp_ch_`month'mo bartik`month'
		}
		keep if year>=2005
		foreach var in bartik12 bartik1 bartik2 bartik3 bartik6 level {
			**find year of best emp
			bysort `geo': egen best = max(`var') if year<=2007
			gen this = year if best==`var'
			bysort `geo': egen Fyear = min(this)
			display "year of best `var' economy"
			tab Fyear [aw=lf2006]
			egen Fmain = mode(Fyear) 
			tab Fmain
			bysort `geo': egen best_`var' = max(`var') if year<=2007
			bysort `geo': egen mean_pre_`var' = mean(`var') if year==Fmain
			bysort `geo': egen mean_pre2007_`var' = mean(`var') if year==2007
			drop best this Fyear Fmain

			bysort `geo': egen worst = min(`var') if year>=2008
			gen this = year if worst==`var'
			bysort `geo': egen Lyear = max(this)
			display "year of worst `var' economy"
			tab Lyear [aw=lf2006]
			egen Lmain = mode(Lyear)
			tab Lmain
			bysort `geo': egen worst_`var' = min(`var') if year>=2008
			bysort `geo': egen mean_post_`var' = mean(`var') if year==Lmain
			bysort `geo': egen mean_post2010_`var' = mean(`var') if year==2010
			drop worst this Lyear Lmain
		}
		collapse best_* worst_* mean_pre_* mean_post_* mean_pre2007_* mean_post2010_* lf2006, by(`geo')
		foreach var in bartik12 bartik1 bartik2 bartik3 bartik6 level {
			gen shock_`season'_`var' = worst_`var'-best_`var'
			gen shock_mean_`season'_`var' = mean_post_`var' - mean_pre_`var'
			gen shock_0710_`season'_`var' = mean_post2010_`var' - mean_pre2007_`var'
		}
		keep shock_`season'_* shock_mean_`season'_* shock_0710_`season'_* `geo'
		ren shock_`season'_bartik12 shock_`season'_bartik
		ren shock_mean_`season'_bartik12 shock_mean_`season'_bartik
		ren shock_0710_`season'_bartik12 shock_0710_`season'_bartik 
		tempfile shock_`season'_`geo'
		save `shock_`season'_`geo'', replace
	}
}	

***note shock_0710_`season'_level and shock_mean_`season'_level are identical because 2007 and 2010 are best and worst years
***note shock_0710_`season'_bartik and shock_mean_`season'_bartik are uncorrelated, lots of recovery by 2010
*}}}

***make 90-10 differentials
*{{{
use `shock_sa_msa', clear

**get -1*90-10 diff'l
foreach var of varlist shock* {
	sum `var', d
	gen `var'9010 = `var'/(r(p10) - r(p90))
}


keep shock_mean_sa_bartik9010 shock_sa_bartik9010 shock_mean_sa_level9010 shock_mean_sa_bartik19010  msa

count
local Nmsas = r(N)
assert `Nmsas'==381

save "$data_output/bartiks", replace
save "$public/bartiks", replace

*}}}

*}}}

/****************************************************************************
** 	4. MSA Unemployment rates from BLS LAUS			   	   **
****************************************************************************/
*{{{
clear
import delim using "$raw_MSA/msa_unemps1998_2016_NSA.txt"
foreach varnum of numlist 2/219 {
	local actual = `varnum'-1
	ren v`varnum' unemp_msa_nsa`actual'
}
ren v1 msacode
gen statemsa = substr(msacode,6,2)
destring statemsa, replace
assert statemsa!=.
gen msa = substr(msacode,8,5)
destring msa, replace
assert msa!=.
reshape long unemp_msa_nsa, i(msa) j(date)
gen year = 1998 + floor((date-1)/12)
tab year
gen month = date - (year-1998)*12
tab month

keep year month msa statemsa unemp_msa_nsa
keep if year>=2000 & year<=2015
save "$data_output/msa_unemps2000_2015", replace
save "$public/msa_unemps2000_2015", replace
*}}}

/****************************************************************************
** 5. Make MSA Employment Levels from BLS CEs 		 					     	
****************************************************************************/
*{{{
clear
import delim using "$raw_MSA/msa_emps1998_2016_NSA.txt"
ren v1 msacode
foreach varnum of numlist 2/219 {
	local actual = `varnum'-1
	ren v`varnum' emp_private`actual'_
}
gen statemsa = substr(msacode,4,2)
destring statemsa, replace
assert statemsa!=.
gen msa = substr(msacode,6,5)
destring msa, replace
assert msa!=.
gen classcode = substr(msacode,12,1)
destring classcode, replace
assert classcode==5 | classcode==0
drop msacode 
reshape wide emp_private*_, i(msa) j(classcode)
ren emp_private*_0 emp_total*
ren emp_private*_5 emp_private*

reshape long emp_private emp_total, i(msa) j(date)
gen year = 1998 + floor((date-1)/12)
tab year
gen month = date - (year-1998)*12
drop date
gen date = ym(year, month)

keep year month date msa statemsa emp_private emp_total

keep if year>=1999 & year<=2015
save "$data_output/msa_emps1999_2015", replace
save "$public/msa_emps1999_2015", replace
*}}}

/******************************************************************************
** 6. Make OES datset							
**		uses brad's routine measures
**		uses brad's soc 2000 to soc 2010 crosswalk
**		uses MSA crosswalk created next
*******************************************************************************/
*{{{
/****************************************************************************
** get MSA crosswalk from census -- different categorizations					**
**--OMB 2013 categorization available in 2000 and 2005-present
**--first few years of OES and historically in CPS use earlier categorization that is available in 2000 and 2005-2011
** get a crosswalk from IPUMS for years when both are available
****************************************************************************/
*{{{
* NOTE: You need to set the Stata working directory to the path
* where the data file is located.

set more off

clear
quietly infix              ///
  int     year      1-4    ///
  byte    datanum   5-6    ///
  double  serial    7-14   ///
  float   hhwt      15-24  ///
  int     metarea   25-27  ///
  int     metaread  28-31  ///
  long    met2013   32-36  ///
  byte    gq        37-37  ///
  int     pernum    38-41  ///
  float   perwt     42-51  ///
  using "$raw_MSA/usa_00052.dat"

replace hhwt     = hhwt     / 100
replace perwt    = perwt    / 100

format serial   %8.0f
format hhwt     %10.2f
format perwt    %10.2f

label var year     `"Census year"'
label var datanum  `"Data set number"'
label var serial   `"Household serial number"'
label var hhwt     `"Household weight"'
label var metarea  `"Metropolitan area [general version]"'
label var metaread `"Metropolitan area [detailed version]"'
label var met2013  `"Metropolitan area, 2013 OMB delineations"'
label var gq       `"Group quarters status"'
label var pernum   `"Person number in sample unit"'
label var perwt    `"Person weight"'

