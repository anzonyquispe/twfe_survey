ren met2013 msa


**recode MSAs to NECTAs to match BG (and BLS etc)
*{{{
				foreach var in msa  {
					qui replace `var' = 	70600	if `var'==	12300	//Augusta-Waterville, ME
					qui replace `var' = 	70750	if `var'==	12620	//Bangor, ME
					qui replace `var' = 	70900	if `var'==	12700	//Barnstable Town, MA
					qui replace `var' = 	71050	if `var'==	12740	//Barre, VT
					qui replace `var' = 	71350	if `var'==	13540	//Bennington, VT
					qui replace `var' = 	71500	if `var'==	13620	//Berlin, NH-VT
					qui replace `var' = 	71500	if `var'==	13620	//Berlin, NH-VT
					qui replace `var' = 	71650	if `var'==	14460	//Boston-Cambridge-Quincy, MA-NH
					qui replace `var' = 	71950	if `var'==	14860	//Bridgeport-Stamford-Norwalk, CT
					qui replace `var' = 	72400	if `var'==	15540	//Burlington-South Burlington, VT
					qui replace `var' = 	72500	if `var'==	17200	//Claremont, NH
					qui replace `var' = 	72700	if `var'==	18180	//Concord, NH
					qui replace `var' = 	73450	if `var'==	25540	//Hartford-West Hartford-East Hartford, CT
					qui replace `var' = 	73750	if `var'==	28300	//Keene, NH
					qui replace `var' = 	73900	if `var'==	29060	//Laconia, NH
					qui replace `var' = 	74350	if `var'==	30100	//Lebanon, NH-VT
					qui replace `var' = 	74650	if `var'==	30340	//Lewiston-Auburn, ME
					qui replace `var' = 	74950	if `var'==	31700	//Manchester-Nashua, NH
					qui replace `var' = 	75700	if `var'==	35300	//New Haven-Milford, CT
					qui replace `var' = 	76450	if `var'==	35980	//Norwich-New London, CT
					qui replace `var' = 	76600	if `var'==	38340	//Pittsfield, MA
					qui replace `var' = 	76750	if `var'==	38860	//Portland-South Portland-Biddeford, ME
					qui replace `var' = 	77200	if `var'==	39300	//Providence-New Bedford-Fall River, RI-MA
					qui replace `var' = 	77500	if `var'==	40500	//Rockland, ME
					qui replace `var' = 	77650	if `var'==	40860	//Rutland, VT
					qui replace `var' = 	78100	if `var'==	44140	//Springfield, MA
					qui replace `var' = 	78400	if `var'==	45860	//Torrington, CT
					qui replace `var' = 	79300	if `var'==	48740	//Willimantic, CT
					qui replace `var' = 	79600	if `var'==	49340	//Worcester, MA
				}
*}}}


drop if metaread==0
drop if msa==0

**get crosswalk be msa and metaread weighting to break ties
**if weighting using person weights then 2000 Census will swamp all other years
**instead give equal weight across survey years and weight by perwt within survey years to break ties
bysort year: egen tot = sum(perwt)
gen weight = perwt/tot
drop tot
bysort year: egen wtsum=sum(weight)
display "should be equal to 1"
assert wtsum>=.99 & wtsum<=1.01

collapse (sum) weight, by(metaread msa)
gsort metaread -weight
by metaread: gen counter = _n
tab counter
*only a few metareas that do not uniquely match to msa
reshape wide weight msa, i(metaread) j(counter)
assert weight1>weight2 if weight2!=.
assert weight1>weight3 if weight3!=.
keep msa1 metaread
ren msa1 msa
ren metaread msa_old
saveold "$data_output/msa_crosswalk", replace
*}}}

*****************************************************************
**read in Brad's routineness measures, get quantiles
*****************************************************************
*{{{
*routineness measures made by brad
use "$data_output/onet_routine_harmonized_4d", clear
ren soc4 soc
keep soc AA_r_cog AA_r_man
foreach var of varlist AA_r_cog AA_r_man {
	foreach q in 4 {
		xtile V`var'`q'_unwt = `var', nq(`q')
	}
}
tempfile occs
save `occs', replace
*}}}

****************************************************************************
**Read in text file for each year (code from DemingKahn is helpful)
****************************************************************************
*{{{
foreach year of numlist 2000/2015 {
	local counter = 1
	if `year'==2000 | `year'==2002 | `year'==2003 {
		local rawlist = "1 2"
	}
	if `year'==2001 | `year'==2004 {
		local rawlist = "1 2 3"
	}
	if `year'>=2005 & `year'<=2013 {
		local rawlist = "a 1 2 3"
	}
	if `year'>=2014 {
		local rawlist = "a 1"
	}
	foreach rawfile in `rawlist' {
		clear
		
		display "year = `year', rawfile = `rawfile'"

		import delim using "$raw_OES/MSA_`year'_dl_`rawfile'.txt"

		/*
		**make sure the data are collected in this year
		**but year not available later
		assert year==`year'
		*/
		
		gen soc = substr(occ_code,1,2)+substr(occ_code,4,4)
		***use Brad code to adjust 6-digit occupations from 2000 to 2010
		if `year'<=2011 {
			*{{{
			* This file adjusts SOC 2000 codes to SOC 2010 codes using logical edits and stochastic imputation

***********************************************  Adjustments  ****************************************************************************************
*** Adjust SOCs to 2010; random reassignment based on empirical shares from ACS over 2010-2012
set seed 54321
gen rand = runiform()
replace soc = "113111" if rand<=.039 & soc=="113040" 			/* HR managers get split */
replace soc = "113121" if rand>.039 & rand<=0.876 & soc=="113040" 	/* HR managers get split */
replace soc = "113131" if rand>0.876 & soc=="113040"			/* HR managers get split */
replace soc = "119013" if soc=="119011" | soc=="119012"		/* Farmers and ranchers */
replace soc = "119061" if soc=="119061" | soc=="1191XX"		/* Funeral directors */

replace soc = "131141" if soc=="131070" & rand>0.779 & rand<0.853	/* Split human resources specialists */
replace soc = "131151" if soc=="131070" & rand>0.853
replace soc = "131121" if soc=="1311XX" & rand<=0.184			/* Split other business operations specialists */
replace soc = "131161" if soc=="1311XX" & rand>0.184 & rand<=0.610
replace soc = "131199" if soc=="1311XX" & rand>0.610	

replace soc = "151131" if soc=="151021"					/* Computer programmers */
replace soc = "15113X" if soc=="151030"					/* Software engineers */
replace soc = "151150" if soc=="151041"					/* Computer support specialists */
replace soc = "151141" if soc=="151061"					/* Database administrators */
replace soc = "151142" if soc=="151071"					/* Network and system admins */
replace soc = "151122" if soc=="151081" & rand<=0.047			/* Split network system data analysts */
replace soc = "151134" if soc=="151081" & rand>0.047 & rand<=0.208	
replace soc = "151150" if soc=="151081" & rand>0.208 & rand<=0.709		
replace soc = "151142" if soc=="151081" & rand>0.709 & rand<=0.915		
replace soc = "151143" if soc=="151081" & rand>0.915	
replace soc = "151111" if soc=="1510XX" & rand<=0.018			/* Split computer scientists and systems analysts */
replace soc = "151121" if soc=="1510XX" & rand>0.018 & rand<=0.529
replace soc = "151143" if soc=="1510XX" & rand>0.529 & rand<=0.629		
replace soc = "151199" if soc=="1510XX" & rand>0.629		

replace soc = "1910XX" if soc=="191040"					/* Medical scientists */
replace soc = "131161" if soc=="193020"					/* Market and survey researchers */
replace soc = "1940YY" if soc=="194041" | soc=="1940XX"		/* Misc technicians */

replace soc = "211092" if soc=="211090" & rand<=0.255			/* Split misc community workers */
replace soc = "211093" if soc=="211090" & rand>0.255 & rand<=0.694
replace soc = "21109X" if soc=="211090" & rand>0.694

replace soc = "2310XX" if soc=="231011" | soc=="231020"			/* Combine lawyers, judges, and law clerks */

replace soc = "252050" if soc=="252040"					/* Spec ed teachers */

replace soc = "291141" if soc=="291111"					/* Registered nurses */
replace soc = "291181" if soc=="291121"					/* Audiologists */
replace soc = "29112X" if soc=="291129"					/* Other therapists */

replace soc = "319092" if soc=="31909X" & rand<=0.516		/* Split misc health care support workers */
replace soc = "319094" if soc=="31909X" & rand>0.516 & rand<=0.593
replace soc = "319095" if soc=="31909X" & rand>0.593 & rand<=0.646
replace soc = "319096" if soc=="31909X" & rand>0.646 & rand<=0.701
replace soc = "319097" if soc=="31909X" & rand>0.701 & rand<=0.818

replace soc = "3940XX" if soc=="394000"					/* Funeral workers */
replace soc = "397010" if soc=="396020"					/* Travel/tour guides */
replace soc = "532031" if soc=="396030" & rand<=0.741			/* Split travel attendants */
replace soc = "536061" if soc=="396030" & rand>0.741

replace soc = "451011" if soc=="451010"					/* Supervisors of agriculture workers */

replace soc = "472020" if soc=="472XXX"					/* Misc construction workers */
replace soc = "472141" if soc=="472140" & rand<=0.99			/* Split painters */
replace soc = "472142" if soc=="472140" & rand>0.99
replace soc = "472141" if soc=="472XXX" & rand<=0.99
replace soc = "472142" if soc=="472XXX" & rand>0.99

replace soc = "499071" if soc=="499042"					/* Maintenance/repair workers */
replace soc = "499095" if soc=="4990XX" & rand<=0.032			/* Misc installation workers */
replace soc = "49909X" if soc=="4990XX" & rand>0.032

replace soc = "514031" if soc=="514030" & rand<=0.583			/* Split machine operators */
replace soc = "514032" if soc=="514030" & rand>0.583 & rand<=0.616
replace soc = "514033" if soc=="514030" & rand>0.616 & rand<=0.925
replace soc = "514034" if soc=="514030" & rand>0.925
replace soc = "514060" if soc=="5140XX" & rand<=0.14			/* Split mold/model makers */
replace soc = "514070" if soc=="5140XX" & rand>0.14
replace soc = "515113" if soc=="515010"					/* Bookbinders */
replace soc = "515112" if soc=="515021" & rand<=0.876			/* Split printers */
replace soc = "515113" if soc=="515021" & rand>0.876
replace soc = "515111" if soc=="515022"					/* Prepress techs */
replace soc = "515112" if soc=="515023"					/* Printing mach operators */
replace soc = "516041" if soc=="516040" & rand<=0.65			/* Split shoe machinists */
replace soc = "516042" if soc=="516040" & rand>0.65
replace soc = "519151" if soc=="519130"					/* Photo processors */
*}}}
		}
		
		**make 4-digit SOC
		replace soc = substr(soc,1,4)
		assert soc!="" 
		destring soc, replace
		assert soc!=.
		
		***clean up a few soc's that don't merge with our variables
		drop if soc==0
		**replace missing occupations with nearby occupations
		replace soc = 1511 if soc==1510
		replace soc = 5151 if soc==5150

		**group = "major" are the super categories, we only want sub
		**this also drops "total" which is all occupations
		if `year'>=2012 {
			ren occ_group group
			replace group="" if group=="detailed"
		}
		drop if group!=""
		drop group occ_code 
		
		**ren from old naming conventions
		if `year'<=2002 {
			foreach stem in h a {
				foreach ptile in 10 25 75 90 {
					ren `stem'_wpct`ptile' `stem'_pct`ptile'
				}
			}
		}
		
		**get rid of commas in wage variables
		foreach var of varlist h_* a_* tot_emp {
			replace `var' = subinstr(`var', ",", "",.)
		}

		**tot_emp only non-numeric if ="**", i.e., estimate not available
		replace tot_emp = "" if tot_emp=="**"
		destring tot_emp, replace
		
		
		**wage variables are topcoded
		**follow top-coding convention by multiplying by 1.5
		if `year'<=2007 {
			local acode = 145600
			local hcode = 70
		}
		if `year'>=2008 & `year'<=2010 {
			local acode = 166400
			local hcode = 80
		}
		if `year'>=2011 {
			local acode = 187200
			local hcode = 90
		}
		foreach var of varlist h_* {
			replace `var' = "" if `var'=="*" | `var'=="***"
			local helper = `hcode'*1.5
			replace `var' = "`helper'" if `var'=="#"
			destring `var', replace
		}
		foreach var of varlist a_* {
			replace `var' = "" if `var'=="*" | `var'=="***"
			local helper = `acode'*1.5
			replace `var' = "`helper'" if `var'=="#"
			destring `var', replace
		}
		
		***start with hourly data
		**combine variables -- make hrly by dividing by FT hours
		gen wmean = a_mean/2000 if annual=="true" | annual=="TRUE"
		gen w10 = a_pct10/2000 if annual=="true" | annual=="TRUE"
		gen w25 = a_pct25/2000 if annual=="true" | annual=="TRUE"
		gen wmedian = a_median/2000 if annual=="true" | annual=="TRUE"
		gen w75 = a_pct75/2000 if annual=="true" | annual=="TRUE"
		gen w90 = a_pct90/2000 if annual=="true" | annual=="TRUE"
		
		replace wmean = h_mean if wmean==.
		replace w10 = h_pct10 if w10==.
		replace w25 = h_pct25 if w25==.
		replace wmedian = h_median if wmedian==.
		replace w75 = h_pct75 if w75==.
		replace w90 = h_pct90 if w90==.
		
		
		****get aligned MSAs -- ONLY KEEPING EARLIER MSAs THAT MATCH FORWARD
		if `year'<=2004 {
			ren area msa_old
			merge m:1 msa_old using "$data_output/msa_crosswalk"
			**most of the ones that don't match don't have an identifiable OMB2013 MSA def
			keep if _merge==3
			drop _merge
		}
		**for recent categorization, make sure in NECTAs 
		if `year'>=2005 {
			ren area msa
			
			**recode MSAs to NECTAs to match BG (and BLS etc)
			*{{{
				foreach var in msa  {
					qui replace `var' = 	70600	if `var'==	12300	//Augusta-Waterville, ME
					qui replace `var' = 	70750	if `var'==	12620	//Bangor, ME
					qui replace `var' = 	70900	if `var'==	12700	//Barnstable Town, MA
					qui replace `var' = 	71050	if `var'==	12740	//Barre, VT
					qui replace `var' = 	71350	if `var'==	13540	//Bennington, VT
					qui replace `var' = 	71500	if `var'==	13620	//Berlin, NH-VT
					qui replace `var' = 	71500	if `var'==	13620	//Berlin, NH-VT
					qui replace `var' = 	71650	if `var'==	14460	//Boston-Cambridge-Quincy, MA-NH
					qui replace `var' = 	71950	if `var'==	14860	//Bridgeport-Stamford-Norwalk, CT
					qui replace `var' = 	72400	if `var'==	15540	//Burlington-South Burlington, VT
					qui replace `var' = 	72500	if `var'==	17200	//Claremont, NH
					qui replace `var' = 	72700	if `var'==	18180	//Concord, NH
					qui replace `var' = 	73450	if `var'==	25540	//Hartford-West Hartford-East Hartford, CT
					qui replace `var' = 	73750	if `var'==	28300	//Keene, NH
					qui replace `var' = 	73900	if `var'==	29060	//Laconia, NH
					qui replace `var' = 	74350	if `var'==	30100	//Lebanon, NH-VT
					qui replace `var' = 	74650	if `var'==	30340	//Lewiston-Auburn, ME
					qui replace `var' = 	74950	if `var'==	31700	//Manchester-Nashua, NH
					qui replace `var' = 	75700	if `var'==	35300	//New Haven-Milford, CT
					qui replace `var' = 	76450	if `var'==	35980	//Norwich-New London, CT
					qui replace `var' = 	76600	if `var'==	38340	//Pittsfield, MA
					qui replace `var' = 	76750	if `var'==	38860	//Portland-South Portland-Biddeford, ME
					qui replace `var' = 	77200	if `var'==	39300	//Providence-New Bedford-Fall River, RI-MA
					qui replace `var' = 	77500	if `var'==	40500	//Rockland, ME
					qui replace `var' = 	77650	if `var'==	40860	//Rutland, VT
					qui replace `var' = 	78100	if `var'==	44140	//Springfield, MA
					qui replace `var' = 	78400	if `var'==	45860	//Torrington, CT
					qui replace `var' = 	79300	if `var'==	48740	//Willimantic, CT
					qui replace `var' = 	79600	if `var'==	49340	//Worcester, MA
				}
			*}}}
		}

		collapse wmean w10 w25 wmedian w75 w90 (rawsum) tot_emp [aw=tot_emp], by(msa soc)
		gen year = `year'
		tempfile raw`rawfile'
		save `raw`rawfile'', replace
	}
	use `raw1', clear
		
	if `year'>=2000 & `year'<=2013 {
		append using `raw2'
	}

	if `year'==2001 | (`year'>=2004 & `year'<=2013){
		append using `raw3'
	}
	if `year'>=2005 {
		append using `rawa'
	}
		
	***MSA crosswalk results in repeat MSAs across files, collapse again
	if `year'<=2004 {
		collapse year wmean w10 w25 wmedian w75 w90 (rawsum) tot_emp [aw=tot_emp], by(msa soc)
	}
	
	bysort msa soc: assert _n==_N
	
	tempfile raw`year'
	save `raw`year'', replace
}
use `raw2000', clear
foreach year of numlist 2001/2015 {
	append using `raw`year''
}

merge m:1 soc using `occs'
**temporary occupations used in 2010 and 11 won't merge
assert year==2010 | year==2011 if _merge==1
keep if _merge==3
drop _merge

bysort msa: egen Nyears = nvals(year)
tab Nyears
bysort Nyears: tab year

***there are some non-matching msas
merge m:1 msa using "$data_output/msa_LF_2006"
tab msa if _merge==1
keep if _merge==3
drop _merge

merge m:1 msa using "$data_output/bartiks", keepusing(shock_mean_sa_bartik9010)
keep if _merge==3
drop _merge

ren shock_mean_sa_bartik9010 shock9010

merge m:1 msa using "$data_output/ACSvars0506_msa"
	drop if _merge==2
	gen M_ACS = (_merge==1)
	foreach var of varlist ACS* {
		replace `var' = 0 if M_ACS==1
	}
	capture drop miss_ACS
	drop _merge

   
save "$public/workingOES", replace
save "$data_output/workingOES", replace
*}}}

*}}}

/*****************************************************************************
** 7a. Make CPS for figure 1 -- from IPUMS
**	CPS analysis is at metarea level (instead of msa OMB 2013 level)
**	need crosswalk from ACS/census for metarea<->msa
** 7b. Make CPS layoffs dataset for figure 7 and figure A5
******************************************************************************/
*{{{
**get MSA variables at metareag level
*{{{

set more off

clear
quietly infix              ///
  int     year      1-4    ///
  byte    datanum   5-6    ///
  double  serial    7-14   ///
  float   hhwt      15-24  ///
  int     metarea   25-27  ///
  int     metaread  28-31  ///
  long    met2013   32-36  ///
  byte    gq        37-37  ///
  int     pernum    38-41  ///
  float   perwt     42-51  ///
  using "$raw_MSA/usa_00052.dat"

replace hhwt     = hhwt     / 100
replace perwt    = perwt    / 100

format serial   %8.0f
format hhwt     %10.2f
format perwt    %10.2f

label var year     `"Census year"'
label var datanum  `"Data set number"'
label var serial   `"Household serial number"'
label var hhwt     `"Household weight"'
label var metarea  `"Metropolitan area [general version]"'
label var metaread `"Metropolitan area [detailed version]"'
label var met2013  `"Metropolitan area, 2013 OMB delineations"'
label var gq       `"Group quarters status"'
label var pernum   `"Person number in sample unit"'
label var perwt    `"Person weight"'

***label vars
