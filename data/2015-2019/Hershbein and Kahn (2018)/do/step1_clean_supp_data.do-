label define gq_lbl 4 `"Other group quarters"', add
label define gq_lbl 5 `"Additional households under 2000 definition"', add
label define gq_lbl 6 `"Fragment"', add
label values gq gq_lbl


*}}}

ren met2013 msa


**recode MSAs to NECTAs to match BG (and BLS etc)
*{{{
				foreach var in msa  {
					qui replace `var' = 	70600	if `var'==	12300	//Augusta-Waterville, ME
					qui replace `var' = 	70750	if `var'==	12620	//Bangor, ME
					qui replace `var' = 	70900	if `var'==	12700	//Barnstable Town, MA
					qui replace `var' = 	71050	if `var'==	12740	//Barre, VT
					qui replace `var' = 	71350	if `var'==	13540	//Bennington, VT
					qui replace `var' = 	71500	if `var'==	13620	//Berlin, NH-VT
					qui replace `var' = 	71500	if `var'==	13620	//Berlin, NH-VT
					qui replace `var' = 	71650	if `var'==	14460	//Boston-Cambridge-Quincy, MA-NH
					qui replace `var' = 	71950	if `var'==	14860	//Bridgeport-Stamford-Norwalk, CT
					qui replace `var' = 	72400	if `var'==	15540	//Burlington-South Burlington, VT
					qui replace `var' = 	72500	if `var'==	17200	//Claremont, NH
					qui replace `var' = 	72700	if `var'==	18180	//Concord, NH
					qui replace `var' = 	73450	if `var'==	25540	//Hartford-West Hartford-East Hartford, CT
					qui replace `var' = 	73750	if `var'==	28300	//Keene, NH
					qui replace `var' = 	73900	if `var'==	29060	//Laconia, NH
					qui replace `var' = 	74350	if `var'==	30100	//Lebanon, NH-VT
					qui replace `var' = 	74650	if `var'==	30340	//Lewiston-Auburn, ME
					qui replace `var' = 	74950	if `var'==	31700	//Manchester-Nashua, NH
					qui replace `var' = 	75700	if `var'==	35300	//New Haven-Milford, CT
					qui replace `var' = 	76450	if `var'==	35980	//Norwich-New London, CT
					qui replace `var' = 	76600	if `var'==	38340	//Pittsfield, MA
					qui replace `var' = 	76750	if `var'==	38860	//Portland-South Portland-Biddeford, ME
					qui replace `var' = 	77200	if `var'==	39300	//Providence-New Bedford-Fall River, RI-MA
					qui replace `var' = 	77500	if `var'==	40500	//Rockland, ME
					qui replace `var' = 	77650	if `var'==	40860	//Rutland, VT
					qui replace `var' = 	78100	if `var'==	44140	//Springfield, MA
					qui replace `var' = 	78400	if `var'==	45860	//Torrington, CT
					qui replace `var' = 	79300	if `var'==	48740	//Willimantic, CT
					qui replace `var' = 	79600	if `var'==	49340	//Worcester, MA
				}
*}}}

drop if msa==0

merge m:1 msa using "$data_output/bartiks"
***the only one that does not merge is unidentified metro area
***but there are some MSAs that are not in the ACS. 
**these are the same 117 MSAs that do not match from the ACS sample (M_ACS==1)
assert _merge!=1
keep if _merge==3
drop _merge
**somehow unidentified are still included
drop if metarea==0

ren shock_mean_sa_bartik9010 shock9010
ren shock_sa_bartik9010 shock_bw_9010
ren shock_mean_sa_level9010 level_9010
ren shock_mean_sa_bartik19010 shock1_9010 


*bring in MSA lf in 2006
merge m:1 msa using "$data_output/msa_LF_2006"
drop if _merge==2
assert _merge==3
drop _merge

***bring in ACS controls
merge m:1 msa using "$data_output/ACSvars0506_msa"
	drop if _merge==2
	gen M_ACS = (_merge==1)
	foreach var of varlist ACS* {
		replace `var' = 0 if M_ACS==1
	}
	capture drop miss_ACS
	drop _merge

**in case there is not a one-to-one match, need weighted average of Bartiks	
**person weighted average within year, unweighted average across year
collapse lf2006 ACS* M_ACS shock9010 level_9010 shock_bw_9010 shock1_9010  [aw=perwt], by(metarea year)
collapse lf2006 ACS* M_ACS shock9010 level_9010 shock_bw_9010 shock1_9010  , by(metarea)
*ren metaread metarea
save "$data_output/Bartiks_metarea", replace
*}}}


** clean CPS data for economic variables				 					**
*{{{
* NOTE: You need to set the Stata working directory to the path
* where the data file is located.

set more off

clear
quietly infix                    ///
  int     year          1-4      ///
  long    serial        5-9      ///
  double  hwtfinl       10-19    ///
  double  hwtsupp       20-29    ///
  double  cpsid         30-43    ///
  byte    asecflag      44-44    ///
  int     metarea       45-48    ///
  byte    month         49-50    ///
  byte    pernum        51-52    ///
  double  cpsidp        53-66    ///
  double  wtsupp        67-76    ///
  double  wtfinl        77-90    ///
  byte    age           91-92    ///
  byte    sex           93-93    ///
  int     race          94-96    ///
  int     hispan        97-99    ///
  byte    educ99        100-101  ///
  byte    schlcoll      102-102  ///
  byte    empstat       103-104  ///
  int     occ2010       105-108  ///
  int     occ1990       109-111  ///
  int     ind           112-115  ///
  byte    classwkr      116-117  ///
  int     uhrsworkt     118-120  ///
  int     ahrsworkt     121-123  ///
  int     durunemp      124-126  ///
  double  hourwage      127-130  ///
  byte    paidhour      131-131  ///
  byte    whyunemp      132-132  ///
  double  earnweek      133-140  ///
  int     uhrsworkorg   141-143  ///
  byte    wksworkorg    144-145  ///
  byte    quhrsworkorg  146-146  ///
  byte    quhrsworkt    147-148  ///
  byte    qempstat      149-149  ///
  byte    qahrsworkt    150-151  ///
  byte    qpaidhou      152-153  ///
  byte    qearnwee      154-154  ///
  using "$raw_MSA/cps_00038.dat"
  
replace hwtfinl      = hwtfinl      / 10000
replace hwtsupp      = hwtsupp      / 10000
replace wtsupp       = wtsupp       / 10000
replace wtfinl       = wtfinl       / 10000
replace hourwage     = hourwage     / 100
replace earnweek     = earnweek     / 100

format hwtfinl      %10.4f
format hwtsupp      %10.4f
format cpsid        %14.0f
format cpsidp       %14.0f
format wtsupp       %10.4f
format wtfinl       %14.4f
format hourwage     %4.2f
format earnweek     %8.2f

**label vars
*{{{
label var year         `"Survey year"'
label var serial       `"Household serial number"'
label var hwtfinl      `"Household weight, Basic Monthly"'
label var hwtsupp      `"Household weight, Supplement"'
label var cpsid        `"CPSID, household record"'
label var asecflag     `"Flag for ASEC"'
label var metarea      `"Metropolitan area"'
label var month        `"Month"'
label var pernum       `"Person number in sample unit"'
label var cpsidp       `"CPSID, person record"'
label var wtsupp       `"Supplement Weight"'
label var wtfinl       `"Final Basic Weight"'
label var age          `"Age"'
label var sex          `"Sex"'
label var race         `"Race"'
label var hispan       `"Hispanic origin"'
label var educ99       `"Educational attainment, 1990"'
label var schlcoll     `"School or college attendance"'
label var empstat      `"Employment status"'
label var occ2010      `"Occupation, 2010 basis"'
label var occ1990      `"Occupation, 1990 basis"'
label var ind          `"Industry"'
label var classwkr     `"Class of worker"'
label var uhrsworkt    `"Hours usually worked per week at all jobs"'
label var ahrsworkt    `"Hours worked last week"'
label var durunemp     `"Continuous weeks unemployed"'
label var hourwage     `"Hourly wage"'
label var paidhour     `"Paid by the hour"'
label var whyunemp     `"Reason for unemployment"'
label var earnweek     `"Weekly earnings"'
