clear
set more off

*****************************************
*****************************************
***---Prep baseline data
*****************************************
*****************************************
use figure5, clear /*in contrast to the data in table2.dta, the panel of homicides is unbalanced in figure5.dta. Beyond four quarters (twelve months) into the second mayor cycle, the panel is no longer balanced b/c homicide data ends in 2012. Quarters 5-7 of the second mayor cycle are nevetheless plotted for completeness and show a similar pattern to quarters 1-4*/

******************Obs during first election cycle, before mayor becomes lame duck
keep if in_term_nold==1

*collapse to quarterly data 

g T=""
foreach L of num 1(3)205 {
	local U=`L'+2
	local C=`U'/3
	quietly replace T="-`C'" if (DiffNLd<=-`L' & DiffNLd>=-`U')
}

foreach L of num 1(3)22 {
	local U=`L'+2
	local C=`U'/3
	quietly replace T="`C'" if (DiffNLd>=`L' & DiffNLd<=`U')
}

replace T="9" if (DiffNLd>=25 & DiffNLd!=.)
drop if T==""

collapse (mean) hom spread PANwin pob_total, by(T id_mun)

tempfile t1
save `t1', replace

******* first lame duck period 
use figure5, clear
keep if LameDuck==1

egen start=min(YMEv), by(id_m)
g temp=YMEv-start+1

g T=""	
replace T="LD1a" if (temp>0) 

collapse (mean) hom spread PANwin pob_total, by(T id_mun)
tempfile ld1
save `ld1', replace

***************************************Then get observations during 2nd lame duck
use figure5, clear
keep if lame_duck2==1

egen start=min(YMEv), by(id_m)
g temp=YMEv-start+1

g T=""	
replace T="LD1b" if (temp>0) 

collapse (mean) hom spread PANwin pob_total, by(T id_mun)
tempfile ld2
save `ld2', replace


***************************************Then get observations after new mayor takes office
use figure5, clear
keep if in_term==0

egen start=min(DiffNLd), by(id_m)
replace DiffNLd=DiffNLd-start+1

g T=""
foreach L of num 1(3)16 {
	local U=`L'+2
	local C=`U'/3
	quietly replace T="`C'_b" if (DiffNLd>=`L' & DiffNLd<=`U')
}
quietly replace T="7_b" if (DiffNLd>=19 & DiffNLd!=.)

collapse (mean) hom spread PANwin pob_total, by(T id_mun)
append using `ld2'
append using `ld1'
append using `t1'

*rates
g xhom=(hom/pob_t)*12*100000

save ViolenceTemp, replace

**********************************************************
****************average # of drug-related homicides
*********************************************************

use ViolenceTemp, clear

local counter=0 /*for saving output*/

levelsof T, local(levels) 
foreach period of local levels {
	
	*******************************************5% bw
	
	*************quadratic 
	use ViolenceTemp, clear
	keep if abs(spread)<.05
	di "`period'"
	quietly keep if T=="`period'"			
	di "limited sample to a single period"

	g spreadPW=spread*PANwin
	g spread2=spread^2
	g spreadPW2=spreadPW^2
	di "variables generated"
	
	reg xhom PANwin spread spreadPW spread2 spreadPW2 [aw=pob_t], robust
	di "regression completed"
	
	*save output
	g indexnum = _n 
	keep if indexnum==1
	keep indexnum
	g bw="5%"
	g RDpoly="quadnofe"
	g depvar="deathsx"
	g period="`period'"
	g coeff=_b[PANwin]
	g se=_se[PANwin]
	di "output saved"
	
	drop ind
	local ++counter
	tempfile F`counter'
	save `F`counter'', replace	
}


use `F1', clear
forvalues i=2/`counter' {
	append using `F`i''
}		

g cp5=coeff+1.96*se
g cn5=coeff-1.96*se

g cp10=coeff+1.65*se
g cn10=coeff-1.65*se

outsheet using allQ.csv, comma replace	


	


